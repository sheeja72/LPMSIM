@page "/lpm/reports/wh-items"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.AnyRole)]
@* 1.14.47 — Reports → WH SKU Investigation (renamed from "WH Items" in 1.14.54).
   Per-item view of warehouse + stores + SkuMax. *@
@using LpmSim.Data.Reports
@using LpmSim.Data.Warehouse
@using LpmSim.Data.Auditing
@using ClosedXML.Excel
@using LpmSim.Web.Components.Pages.Uploads
@using LpmSim.Data.LpmSim
@inject WhItemsReportService Report
@inject WarehouseQueryService Warehouse
@inject LpmSimReportService SimReports
@inject IActionLogger ActionLog
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>WH SKU Investigation</PageTitle>

<div class="lpm-page-title">WH SKU Investigation</div>
<div class="lpm-page-subtitle">
    Per-item view of every warehouse-resident itemcode, with the item's master metadata
    (Division / Department / Brand) and the quantity columns that drive planning:
    <strong>WH Qty</strong> (warehouse stock), <strong>Stores SOH</strong> (current stock at country's
    active stores), <strong>Total SKU Max</strong> (per-item ceiling sum across stores, latest period),
    <strong>Avg SKU Max</strong> (per-store mean across stores that have a rule), and
    <strong>To Fill Qty</strong> (room left before hitting SKU Max). Country switches the whboxitems
    source (UAE → <code>racks.dbo.whboxitems</code>; other countries → <code>[&lt;DataName&gt;].dbo.WHBoxItemsExport</code>).
</div>

<div class="lpm-section lpm-filter-bar lpm-filter-bar-lg">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="string" Label="Country" Value="_country"
                       ValueChanged="@OnCountryChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="@(string.Equals(_country, "UAE", StringComparison.OrdinalIgnoreCase) ? "" : "lpm-filter-active")">
                @foreach (var c in _countries)
                {
                    <MudSelectItem T="string" Value="@c">@c</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @* Season — single. All / Summer / Winter. 1.14.50.
           1.14.84 — Label renamed to "Item Season" to make it explicit that the
           filter is on the item's seasonality (whboxitems.Season) and to
           differentiate it from SIM Generate's "PalletType Season" filter,
           which reads pallettype.Season. *@
        <MudItem xs="6" sm="4" md="2">
            <MudSelect T="WhHoSeason" Label="Item Season" Value="_season"
                       ValueChanged="v => { _season = v; StateHasChanged(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="@(_season == WhHoSeason.All ? "" : "lpm-filter-active")">
                <MudSelectItem T="WhHoSeason" Value="WhHoSeason.All">All</MudSelectItem>
                <MudSelectItem T="WhHoSeason" Value="WhHoSeason.Summer">Summer</MudSelectItem>
                <MudSelectItem T="WhHoSeason" Value="WhHoSeason.Winter">Winter</MudSelectItem>
            </MudSelect>
        </MudItem>

        @* Box Source — LPM / Non-LPM / All. 1.14.50. *@
        <MudItem xs="6" sm="4" md="2">
            <MudSelect T="WhItemsBoxSource" Label="Box Source" Value="_boxSource"
                       ValueChanged="v => { _boxSource = v; StateHasChanged(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="@(_boxSource == WhItemsBoxSource.All ? "" : "lpm-filter-active")">
                <MudSelectItem T="WhItemsBoxSource" Value="WhItemsBoxSource.All">All</MudSelectItem>
                <MudSelectItem T="WhItemsBoxSource" Value="WhItemsBoxSource.LpmOnly">LPM</MudSelectItem>
                <MudSelectItem T="WhItemsBoxSource" Value="WhItemsBoxSource.NonLpmOnly">Non-LPM</MudSelectItem>
            </MudSelect>
        </MudItem>

        @* LPM Months — multi-select. Only shown / usable when Box Source = LPM,
           matching SIM Generate's pattern. 1.14.50. *@
        @if (_boxSource == WhItemsBoxSource.LpmOnly)
        {
            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="DateTime" Label="LPM Months"
                           SelectedValues="_selectedLpmMonths"
                           SelectedValuesChanged="(IEnumerable<DateTime> vs) => { _selectedLpmMonths = vs?.ToHashSet() ?? new HashSet<DateTime>(); StateHasChanged(); }"
                           MultiSelection="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable
                           Placeholder="(All months)"
                           SelectAll="true" SelectAllText="All months"
                           MultiSelectionTextFunc="@(new Func<List<string>, string>(SelectedLpmMonthsText))">
                    @foreach (var m in _allLpmMonths)
                    {
                        <MudSelectItem T="DateTime" Value="m">@m.ToString("MMM-yy")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        }

        @* Division — multi-select. Empty = all divisions. 1.14.52. *@
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Division"
                               Items="_divisions"
                               Selected="_selectedDivisions"
                               SelectedChanged="@((HashSet<string> s) => { _selectedDivisions = s; StateHasChanged(); })" />
        </MudItem>

        @* Pallet Categories — multi-select. Empty = all categories. *@
        <MudItem xs="12" sm="6" md="@(_boxSource == WhItemsBoxSource.LpmOnly ? 12 : 3)">
            <MultiSelectFilter Label="Pallet Categories"
                               Items="_palletCategories"
                               Selected="_selectedPalletCategories"
                               SelectedChanged="@((HashSet<string> s) => { _selectedPalletCategories = s; StateHasChanged(); })" />
        </MudItem>

        <MudItem xs="12" md="@(_boxSource == WhItemsBoxSource.LpmOnly ? 1 : 1)" Class="d-flex align-center justify-end gap-2">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       Disabled="_loading" OnClick="LoadAsync">
                Load
            </MudButton>
            <MudButton Color="Color.Success" Variant="Variant.Outlined" DropShadow="false" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@(_loading || _rows.Count == 0)" OnClick="ExportExcelAsync">
                Excel
            </MudButton>
        </MudItem>
    </MudGrid>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
}

@if (_rows.Count > 0)
{
    @* Per-page totals across all loaded rows — appear in cards above and as
       a TOTAL row at the bottom of the table. *@
    var totWh    = _rows.Sum(r => r.WhQty);
    var totSoh   = _rows.Sum(r => r.StoresSoh);
    var totSku   = _rows.Sum(r => r.SkuMax);
    var totFill  = _rows.Sum(r => r.ToFillQty);
    // 1.14.82 — Totals for the four new columns. HO Price is averaged
    // (not summed — adding prices across items is meaningless); the
    // three Qty/Count columns are summed.
    var totSlash = _rows.Sum(r => r.SlashedQty);
    var totBlk   = _rows.Sum(r => r.BlockedQty);
    var totBlkSt = _rows.Sum(r => r.BlockedStores);
    var avgPrice = _rows.Count > 0 ? _rows.Average(r => r.HoPrice) : 0m;

    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-blue">
            <div class="lpm-metric-label">Items</div>
            <div class="lpm-metric-value">@_rows.Count.ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-green">
            <div class="lpm-metric-label">WH Qty (total)</div>
            <div class="lpm-metric-value">@totWh.ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-purple">
            <div class="lpm-metric-label">Stores SOH (total)</div>
            <div class="lpm-metric-value">@totSoh.ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-amber">
            <div class="lpm-metric-label">To Fill Qty (total)</div>
            <div class="lpm-metric-value">@totFill.ToString("N0")</div>
        </div></MudItem>
    </MudGrid>

    <MudTable Items="_rows" Dense="true" Striped="true" Hover="true" Bordered="true"
              SortLabel="Sort" Class="lpm-table" FixedHeader="true"
              Filter="new Func<WhItemsReportRow, bool>(FilterRow)">
        <ToolBarContent>
            <MudTextField T="string" Value="_textFilter"
                          ValueChanged="(string v) => { _textFilter = v ?? string.Empty; }"
                          Placeholder="Filter by Itemcode / name / Division / Brand…"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true" Immediate="true" DebounceInterval="200" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="WhItemsReportRow"
                                       SortBy="r => r.ItemCode">Itemcode</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="WhItemsReportRow"
                                       SortBy="r => r.ItemName">Item Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="WhItemsReportRow"
                                       InitialDirection="SortDirection.Ascending"
                                       SortBy="r => r.Division">Division</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="WhItemsReportRow"
                                       SortBy="r => r.Department">Department</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="WhItemsReportRow"
                                       SortBy="r => r.Brand">Brand</MudTableSortLabel></MudTh>
            @* 1.14.82 — HO Price (from whboxitems.HOPrice) right after Brand
               so the per-item identifiers stay grouped before the qty columns. *@
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.HoPrice">HO Price</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.WhQty">WH Qty</MudTableSortLabel>
            </MudTh>
            @* 1.14.82 — Slashed Qty (SUM(whboxitems.Slashed)) right after WH Qty,
               grouping the warehouse-source quantity columns together. *@
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.SlashedQty">Slashed Qty</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.StoresSoh">Stores SOH</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.SkuMax">Total SKU Max</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.AvgSkuMax">Avg SKU Max</MudTableSortLabel>
            </MudTh>
            @* 1.14.82 — Blocked Qty + Blocked Stores from LPM_SimItemSkuMaxExcluded
               (selected country, latest period). Sits next to the SKU Max columns
               because the values explain *why* the SKU Max is reduced for stores. *@
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.BlockedQty">Blocked Qty</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.BlockedStores">Blocked Stores</MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align:right;">
                <MudTableSortLabel T="WhItemsReportRow" SortBy="r => r.ToFillQty">To Fill Qty</MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><code>@context.ItemCode</code></MudTd>
            <MudTd>@context.ItemName</MudTd>
            <MudTd>@context.Division</MudTd>
            <MudTd>@context.Department</MudTd>
            <MudTd>@context.Brand</MudTd>
            @* 1.14.82 — HO Price cell. Shows "—" when zero so a blank price
               doesn't masquerade as a real 0.00 reading. *@
            <MudTd Style="text-align:right;">@(context.HoPrice > 0 ? context.HoPrice.ToString("N2") : "—")</MudTd>
            <MudTd Style="text-align:right;">@context.WhQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.SlashedQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.StoresSoh.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.SkuMax.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.AvgSkuMax.ToString("N1")</MudTd>
            @* 1.14.82 — Blocked Qty + Blocked Stores cells. *@
            <MudTd Style="text-align:right;">@context.BlockedQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.BlockedStores.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.ToFillQty.ToString("N0")</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 50, 100, 250, 500 }" />
        </PagerContent>
        <FooterContent>
            <MudTd Style="font-weight:600;" colspan="5">TOTAL (@_rows.Count.ToString("N0") rows)</MudTd>
            @* 1.14.82 — HO Price footer = average across loaded items (summing
               prices is meaningless). Shows "—" when the loaded set is all
               zero-priced. *@
            <MudTd Style="text-align:right;font-weight:600;">@(avgPrice > 0 ? avgPrice.ToString("N2") + " avg" : "—")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@totWh.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@totSlash.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@totSoh.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@totSku.ToString("N0")</MudTd>
            @* Avg-of-averages across loaded rows — equal weight per item.
               Not a SUM (the per-row metric is already an average) so the
               footer column shows the typical per-store ceiling, not a total. *@
            <MudTd Style="text-align:right;font-weight:600;">@(_rows.Count > 0 ? _rows.Average(r => r.AvgSkuMax).ToString("N1") : "0.0")</MudTd>
            @* 1.14.82 — Blocked Qty + Blocked Stores totals. *@
            <MudTd Style="text-align:right;font-weight:600;">@totBlk.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@totBlkSt.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@totFill.ToString("N0")</MudTd>
        </FooterContent>
    </MudTable>
}
else if (_loadedOnce && !_loading)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
        No items matched the filters. Try widening the pallet category selection.
    </MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
        Pick filters and click <b>Load</b> to run the report.
    </MudAlert>
}

@code {
    // ─── Dropdown sources ───────────────────────────────────────────────
    private List<string>   _countries        = new() { "UAE" };
    private List<string>   _palletCategories = new();
    private List<DateTime> _allLpmMonths     = new();    // 1.14.50
    private List<string>   _divisions        = new();    // 1.14.52

    // ─── Filter values ──────────────────────────────────────────────────
    private string             _country                  = "UAE";
    private HashSet<string>    _selectedPalletCategories = new(StringComparer.OrdinalIgnoreCase);
    private WhHoSeason         _season                   = WhHoSeason.All;           // 1.14.50
    private WhItemsBoxSource   _boxSource                = WhItemsBoxSource.All;     // 1.14.50
    private HashSet<DateTime>  _selectedLpmMonths        = new();                    // 1.14.50
    private HashSet<string>    _selectedDivisions        = new(StringComparer.OrdinalIgnoreCase); // 1.14.52
    private string             _textFilter               = "";

    // ─── Result + UI state ──────────────────────────────────────────────
    private List<WhItemsReportRow> _rows       = new();
    private bool                   _loading;
    private bool                   _loadedOnce;

    protected override async Task OnInitializedAsync()
    {
        // Filter-list queries in parallel (different sources).
        var countriesTask = Warehouse.GetCountriesAsync();
        var palletsTask   = Warehouse.GetPalletCategoriesAsync();
        var lpmMonthsTask = SimReports.GetDistinctLpmMonthsAsync();
        var divisionsTask = Warehouse.GetDistinctDivisionsAsync();    // 1.14.52
        try
        {
            _countries        = await countriesTask;
            _palletCategories = await palletsTask;
            try { _allLpmMonths = await lpmMonthsTask; }
            catch { _allLpmMonths = new(); }    // best-effort; LPM Months dropdown just stays empty
            try { _divisions = await divisionsTask; }
            catch { _divisions = new(); }       // best-effort; Division dropdown just stays empty
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load filter lists: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Compact display text for the LPM Months multi-select chip — mirrors
    /// the SIM Generate page pattern. (1.14.50)
    /// </summary>
    private string SelectedLpmMonthsText(List<string> selected)
    {
        if (selected is null || selected.Count == 0) return "(All months)";
        if (selected.Count == _allLpmMonths.Count)   return "All months";
        if (selected.Count == 1)                     return selected[0];
        return $"{selected.Count} months";
    }

    private void OnCountryChanged(string? v)
    {
        _country = string.IsNullOrWhiteSpace(v) ? "UAE" : v;
        StateHasChanged();
    }

    /// <summary>Client-side filter for the in-table search box.</summary>
    private bool FilterRow(WhItemsReportRow r)
    {
        if (string.IsNullOrWhiteSpace(_textFilter)) return true;
        var f = _textFilter.Trim();
        return r.ItemCode.Contains(f, StringComparison.OrdinalIgnoreCase)
            || (r.ItemName?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
            || (r.Division?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
            || (r.Department?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
            || (r.Brand?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        var started = DateTime.Now;
        _rows.Clear();
        var filter = new WhItemsReportFilter(
            Country:          _country,
            PalletCategories: _selectedPalletCategories.Count == 0 ? null : _selectedPalletCategories.ToList(),
            Season:           _season,
            BoxSource:        _boxSource,
            LpmMonths:        _selectedLpmMonths.Count == 0 ? null : _selectedLpmMonths.ToList(),
            Divisions:        _selectedDivisions.Count == 0 ? null : _selectedDivisions.ToList());
        try
        {
            _rows = await Report.GetAsync(filter);
            _loadedOnce = true;
            await ActionLog.LogAsync(
                "Reports.WhItems.Load",
                $"{started:yyyyMMddHHmmss}",
                new { filter, rows = _rows.Count, elapsedMs = (int)(DateTime.Now - started).TotalMilliseconds });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load failed: {ex.Message}", Severity.Error);
            await ActionLog.LogAsync(
                "Reports.WhItems.Load",
                $"{started:yyyyMMddHHmmss}-error",
                new { filter, error = ex.Message });
        }
        finally
        {
            _loading = false; StateHasChanged();
        }
    }

    /// <summary>
    /// Build a single-sheet workbook of the current result rows and trigger
    /// a browser download. Columns mirror the on-screen table; a bold TOTAL
    /// row caps the bottom.
    /// </summary>
    private async Task ExportExcelAsync()
    {
        if (_rows.Count == 0)
        {
            Snackbar.Add("Nothing to export — Load a result first.", Severity.Info);
            return;
        }
        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("WH SKU Investigation");
            // 1.14.82 — Four new columns inserted to match the on-screen order:
            //   HO Price after Brand (col 6); Slashed Qty after WH Qty (col 8);
            //   Blocked Qty + Blocked Stores after Avg SKU Max (cols 12-13).
            // To Fill Qty shifts from col 10 → col 14.
            string[] headers = { "Itemcode", "Item Name", "Division", "Department", "Brand",
                                 "HO Price", "WH Qty", "Slashed Qty", "Stores SOH",
                                 "Total SKU Max", "Avg SKU Max", "Blocked Qty", "Blocked Stores",
                                 "To Fill Qty" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            for (int i = 0; i < _rows.Count; i++)
            {
                var r = _rows[i]; var row = i + 2;
                ws.Cell(row, 1).Value  = r.ItemCode;
                ws.Cell(row, 2).Value  = r.ItemName;
                ws.Cell(row, 3).Value  = r.Division;
                ws.Cell(row, 4).Value  = r.Department;
                ws.Cell(row, 5).Value  = r.Brand;
                ws.Cell(row, 6).Value  = r.HoPrice;        // 1.14.82
                ws.Cell(row, 7).Value  = r.WhQty;
                ws.Cell(row, 8).Value  = r.SlashedQty;     // 1.14.82
                ws.Cell(row, 9).Value  = r.StoresSoh;
                ws.Cell(row, 10).Value = r.SkuMax;
                ws.Cell(row, 11).Value = r.AvgSkuMax;
                ws.Cell(row, 12).Value = r.BlockedQty;     // 1.14.82
                ws.Cell(row, 13).Value = r.BlockedStores;  // 1.14.82
                ws.Cell(row, 14).Value = r.ToFillQty;
            }
            // TOTAL row. Avg cols (HO Price + Avg SKU Max) show the average of
            // the row values (equal weight per item) — same as the on-screen
            // footer. The other Qty / Count cols are summed.
            var totalRow = _rows.Count + 2;
            ws.Cell(totalRow, 1).Value  = $"TOTAL ({_rows.Count:N0} items)";
            ws.Cell(totalRow, 1).Style.Font.Bold = true;
            ws.Cell(totalRow, 6).Value  = _rows.Count > 0 ? _rows.Average(r => r.HoPrice) : 0m;
            ws.Cell(totalRow, 7).Value  = _rows.Sum(r => r.WhQty);
            ws.Cell(totalRow, 8).Value  = _rows.Sum(r => r.SlashedQty);
            ws.Cell(totalRow, 9).Value  = _rows.Sum(r => r.StoresSoh);
            ws.Cell(totalRow, 10).Value = _rows.Sum(r => r.SkuMax);
            ws.Cell(totalRow, 11).Value = _rows.Count > 0 ? _rows.Average(r => r.AvgSkuMax) : 0m;
            ws.Cell(totalRow, 12).Value = _rows.Sum(r => r.BlockedQty);
            ws.Cell(totalRow, 13).Value = _rows.Sum(r => r.BlockedStores);
            ws.Cell(totalRow, 14).Value = _rows.Sum(r => r.ToFillQty);
            for (int c = 6; c <= 14; c++) ws.Cell(totalRow, c).Style.Font.Bold = true;
            // Number formats:
            //   HO Price (6)             → currency-style 2dp
            //   Integer cols (7-10, 12-14) → #,##0
            //   Avg SKU Max (11)         → 1dp
            ws.Range(2,  6, totalRow,  6).Style.NumberFormat.Format = "#,##0.00";
            ws.Range(2,  7, totalRow, 10).Style.NumberFormat.Format = "#,##0";
            ws.Range(2, 11, totalRow, 11).Style.NumberFormat.Format = "#,##0.0";
            ws.Range(2, 12, totalRow, 14).Style.NumberFormat.Format = "#,##0";
            ws.Columns().AdjustToContents();

            var fileName = $"WhItems_{_country}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await UploadHelpers.DownloadAsync(JS, wb, fileName);
            Snackbar.Add($"Exported {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }
}
