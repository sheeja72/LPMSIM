    /// </summary>
    private async Task OnWarehousesSelectionChanged(IEnumerable<string>? values)
    {
        _selectedWarehouses = (values ?? Enumerable.Empty<string>())
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        await CheckAsync();
