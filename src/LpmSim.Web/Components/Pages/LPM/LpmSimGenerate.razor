    private async Task ExportGapAsync()
    {
        if (_gapRows.Count == 0)
        {
            Snackbar.Add("Nothing to export — Load the gap diagnostic first.", Severity.Info);
            return;
        }
        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Allocation Gap");
            string[] headers = { "Box No", "Pallet No", "LPM Dt", "Kind",
                                 "Box Qty", "SIM Qty", "Remaining Qty",
                                 "Top Reason", "Reasons" };
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.FromHtml("#0f172a");
                ws.Cell(1, i + 1).Style.Font.FontColor = XLColor.White;
            }
            int row = 2;
            foreach (var r in _gapRows)
            {
                ws.Cell(row, 1).Value = r.BoxNo;
                ws.Cell(row, 2).Value = r.PalletNo ?? "";
                if (r.LPMDt is DateTime d) { ws.Cell(row, 3).Value = d; ws.Cell(row, 3).Style.DateFormat.Format = "yyyy-MM-dd"; }
                ws.Cell(row, 4).Value = r.BoxKind;
                ws.Cell(row, 5).Value = r.BoxQty;
                ws.Cell(row, 6).Value = r.SimQty;
                ws.Cell(row, 7).Value = r.RemainingQty;
                ws.Cell(row, 8).Value = r.TopReason;
                ws.Cell(row, 9).Value = r.Reasons ?? "";
                row++;
            }
            ws.Columns().AdjustToContents();
            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var bytes = ms.ToArray();
            var b64 = Convert.ToBase64String(bytes);
            var url = $"data:application/octet-stream;base64,{b64}";
            var fileName = $"AllocationGap_Batch{_readiness?.CurrentBatchNo}_{DateTime.Now:yyyy-MM-dd_HHmm}.xlsx";
            await JS.InvokeVoidAsync("lpmDownload", url, fileName);
            Snackbar.Add($"Downloaded {_gapRows.Count:N0} row(s) to {fileName}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

