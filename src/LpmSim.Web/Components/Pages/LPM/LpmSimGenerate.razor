                var r = rows[i]; int row = i + 2;
                sheet.Cell(row, 1).Value = r.StoreName;
                sheet.Cell(row, 2).Value = r.DivisionName;
                sheet.Cell(row, 3).Value = (double?)r.EOM;
                sheet.Cell(row, 4).Value = r.SOH;
                sheet.Cell(row, 5).Value = (double?)r.Balance;
                sheet.Cell(row, 6).Value = r.LpmSimQty;
                sheet.Cell(row, 7).Value = r.RoundRobinQty;
                sheet.Cell(row, 8).Value = (double?)SummaryUsability(r);
