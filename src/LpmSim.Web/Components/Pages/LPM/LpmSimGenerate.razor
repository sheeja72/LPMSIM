    private string SelectedWarehousesText(List<string> selected)
    {
        if (selected is null || selected.Count == 0)            return "(All warehouses)";
        if (selected.Count == _allWarehouses.Count)             return "All warehouses";
        if (selected.Count <= 3)                                return string.Join(" → ", selected);
