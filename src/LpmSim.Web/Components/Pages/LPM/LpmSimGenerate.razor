    private async Task ExportSummaryAsync()
    {
        var rows = FilteredSummary.ToList();
        if (rows.Count == 0) { Snackbar.Add("Nothing to export.", Severity.Info); return; }
        var bn = _readiness?.CurrentBatchNo ?? 0;
        await SaveExcelAsync($"LPMSIM_Summary_{bn}.xlsx", "Summary", sheet =>
        {
            string[] headers = { "Store ID", "Store Name", "Rank", "Division", "EOM", "SOH", "Merch Need (Week)", "LPM SIM Qty", "RR Qty", "Override Qty", "Use %" };
            ApplyHeaders(sheet, headers);
            for (int i = 0; i < rows.Count; i++)
            {
                var r = rows[i]; int row = i + 2;
                sheet.Cell(row, 1).Value  = r.StoreID;
                sheet.Cell(row, 2).Value  = r.StoreName;
                if (r.PriorityRank.HasValue) sheet.Cell(row, 3).Value = (double)r.PriorityRank.Value;
                sheet.Cell(row, 4).Value  = r.DivisionName;
                sheet.Cell(row, 5).Value  = (double?)r.EOM;
                sheet.Cell(row, 6).Value  = r.SOH;
                sheet.Cell(row, 7).Value  = r.MerchNeedWeek;
                sheet.Cell(row, 8).Value  = r.LpmSimQty;
                sheet.Cell(row, 9).Value  = r.RoundRobinQty;
                sheet.Cell(row, 10).Value = r.OverrideQty;
                sheet.Cell(row, 11).Value = (double?)SummaryUsability(r);
            }
            FormatNumeric(sheet, rows.Count, new[] { 5, 6, 7, 8, 9, 10 });
            sheet.Range(2, 3,  rows.Count + 1, 3).Style.NumberFormat.Format  = "0.##";
            sheet.Range(2, 11, rows.Count + 1, 11).Style.NumberFormat.Format = "0.0";
        });
    }

