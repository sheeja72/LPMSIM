    /// <summary>
    /// Re-fetch the currently-visible tab using the latest Box Usability
    /// filter values. Called when Min/Max Box Usability % changes on any tab.
    /// Other tabs invalidate their cached data so they refetch on next switch.
    ///
    /// Tab indices MUST stay in sync with the MudTabPanel order in the razor:
    ///   0 = Summary (Store × Division)
    ///   1 = Store Summary
    ///   2 = Division Summary
    ///   3 = SIM Boxes
    ///   4 = Item Details
    ///   5 = Allocation Trace
    /// (Earlier this method only had 5 cases — Division Summary was added
    /// later and the indices drifted by one. The old switch sent Item
    /// Details filter-change events to LoadTraceAsync and CLEARED _itemRows,
    /// which surfaced as Excel export producing the "wrong" tab's data.)
    /// </summary>
    private async Task ReloadActiveTabAsync()
    {
        if (_readiness?.CurrentBatchNo is not long bn) return;
        // Refresh the source-split matrix so it always reflects the same box
        // population the tabs are showing. When _minUsability is null/0 the
        // CTE filter is open-ended so every box is counted (matches the
        // "show all" behaviour the user expects).
        try { _aggregates = await Reports.GetBatchAggregatesAsync(bn, _minUsability, _maxUsability); }
        catch { /* surfaced by tab load below */ }
        try { _sourceWh = await Reports.GetSourceWarehouseBreakdownAsync(bn); }
        catch { _sourceWh = null; /* table just won't render — non-fatal */ }
        // Invalidate every OTHER tab's cached data — next OnTabChanged will
        // refetch. The current tab's list is reloaded below by the switch.
        if (_activeTab != 0) _summary.Clear();
        if (_activeTab != 1) _storeSummary.Clear();
        if (_activeTab != 2) _divisionSummary.Clear();
        if (_activeTab != 3) _boxRows.Clear();
        if (_activeTab != 4) _itemRows.Clear();
        if (_activeTab != 5) _traceRows.Clear();
        // Refresh the visible tab now.
        switch (_activeTab)
        {
            case 0: await LoadSummaryAsync(bn);         break;
            case 1: await LoadStoreSummaryAsync(bn);    break;
            case 2: await LoadDivisionSummaryAsync(bn); break;
            case 3: await LoadBoxesAsync(bn);           break;
            case 4: await LoadItemsAsync(bn);           break;
            case 5: await LoadTraceAsync();             break;
        }
    }

    private bool UsabilityInRange(decimal? pct)
    {
        if (_minUsability is decimal lo && (pct is null || pct < lo)) return false;
        if (_maxUsability is decimal hi && (pct is null || pct > hi)) return false;
        return true;
    }

