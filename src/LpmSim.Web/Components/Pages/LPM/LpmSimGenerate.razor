    /// <summary>Compact "X selected" rendering for the Pallet Categories multi-select chip.</summary>
    private string SelectedPalletCategoriesText(List<string> selected)
    {
        if (selected is null || selected.Count == 0)            return "(All categories)";
        if (selected.Count == _allPalletCategories.Count)       return "All categories";
        if (selected.Count <= 3)                                return string.Join(", ", selected);
        return $"{selected.Count} of {_allPalletCategories.Count} selected";
    }

    /// <summary>
    /// Compact "X selected" rendering for the LPM Months multi-select chip.
    /// MudSelect's MultiSelectionTextFunc is hardcoded to
    /// <c>Func&lt;List&lt;string&gt;, string&gt;</c> regardless of T —
    /// the values get .ToString()'d before reaching us. We parse the
    /// stringified DateTimes back to format them as "MMM-yy".
    /// </summary>
    private string SelectedLpmMonthsText(List<string> selected)
    {
        if (selected is null || selected.Count == 0)    return "(All months)";
        if (selected.Count == _allLpmMonths.Count)      return "All months";
        if (selected.Count <= 3)
        {
            var pretty = selected.Select(s =>
                DateTime.TryParse(s, out var dt) ? dt.ToString("MMM-yy") : s);
            return string.Join(", ", pretty);
        }
        return $"{selected.Count} of {_allLpmMonths.Count} selected";
    }

    /// <summary>
