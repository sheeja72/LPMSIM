    private IEnumerable<EomSummaryRow> FilteredSummary
    {
        get
        {
            // Box Usability filter is now SERVER-side (the SQL only returns rows
            // for qualifying boxes), so we don't apply UsabilityInRange here.
            // Store / Division filters stay client-side.
            //
            // Filters use the new multi-select sets (_filterStoresMulti /
            // _filterDivisionsMulti) — empty set = no filter. Exact match by
            // StoreID / DivisionName (case-insensitive) replaces the older
            // Contains() substring match that incorrectly matched "Menswear"
            // inside "Womenswear".
            IEnumerable<EomSummaryRow> q = _summary;
            if (_filterStoresMulti.Count > 0)
                q = q.Where(r => _filterStoresMulti.Contains(r.StoreID));
            if (_filterDivisionsMulti.Count > 0)
                q = q.Where(r => _filterDivisionsMulti.Contains(r.DivisionName));
            return q;
        }
    }

    /// <summary>
    /// SIM Boxes tab — combined client-side filter: Box No (contains), Kind
    /// (LPM / Non-LPM), Warehouse, plus existing Min/Max Usability %.
    /// </summary>
    private IEnumerable<BoxDetailRow> FilteredBoxes
    {
        get
        {
            IEnumerable<BoxDetailRow> q = _boxRows;
            if (!string.IsNullOrWhiteSpace(_boxNoFilter))
            {
                var f = _boxNoFilter.Trim();
                q = q.Where(r => !string.IsNullOrEmpty(r.BoxNo)
                              && r.BoxNo.Contains(f, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrEmpty(_boxKindFilter))
                q = q.Where(r => string.Equals(r.BoxKind, _boxKindFilter, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(_boxWarehouseFilter))
                q = q.Where(r => string.Equals(r.Warehouse, _boxWarehouseFilter, StringComparison.OrdinalIgnoreCase));
            q = q.Where(r => UsabilityInRange(r.SkuUsabilityPct));
            return q;
        }
    }

