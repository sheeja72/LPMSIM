@page "/lpm/lpm-sim/generate"
@rendermode InteractiveServer
@* 1.14.66 — Page access widened to include the new "SIM Generate/Approve
   Access" role so a user with ONLY that role can reach this page (without
   needing Editor, PlanningManager, or Admin). The button-group AuthorizeView
   below still gates Generate / Approve / Delete. *@
@attribute [Authorize(Roles = Roles.SimGeneratePageAccess)]
@using LpmSim.Data.LpmSim
@using LpmSim.Data.Auditing
@using LpmSim.Core.Entities
@using ClosedXML.Excel
@using System.IO
@using System.Diagnostics
@inject IDbContextFactory<LpmDbContext> DbFactory
@inject LpmSimGenerator Sim
@inject LpmSimReportService Reports
@inject LpmSimInvestigator Investigator
@inject SkuMaxBuildJobManager SkuMaxJobs
@inject ICurrentUser CurrentUser
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IActionLogger ActionLog
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>LPM SIM Generate</PageTitle>

<div class="lpm-page-title">LPM SIM Generate</div>
<div class="lpm-page-subtitle">
    Allocate eligible-pallet items to stores using the current month's EOM rules. Each run produces a Draft batch
    that must be Approved to finalize. To rerun, Delete the existing batch (it's archived to the backup tables).
</div>

<MudExpansionPanels Elevation="0" Class="mb-3">
    <MudExpansionPanel Text="SIM logic — how the allocator works" Icon="@Icons.Material.Filled.Info">
        <div style="font-size:0.86rem;line-height:1.55;color:#1f2937;">

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Inputs the engine reads</h4>
            <table style="width:100%;border-collapse:collapse;margin-bottom:.9rem;">
                <thead>
                    <tr style="background:#f1f5f9;">
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;width:22%;">Source</th>
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;">What it provides</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Source boxes</strong> — <code>racks.dbo.whboxitems</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Filters: <code>pt.PalletCategory = 'ELIGIBLE'</code>, <code>ShopEligible &lt;&gt; 'E'</code>, season clause,
                            warehouse multi-select, and LPMDt clause (LPM = current/elapsed, Non-LPM = NULL).
                        </td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Candidate stores</strong> — <code>LPM_EOM_Output</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <code>WHERE Country = @@country AND Year1=@@y AND Month1=@@m</code>, plus a defensive
                            <code>INNER JOIN DataSettings (Country)</code> so non-UAE stores cannot leak in.
                            Provides <code>SKUMax</code>, <code>TargetEOM</code>, <code>PriorityRank</code>, <code>WtAvgSoldQty</code>.
                        </td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>SOH per (Store, Item)</strong> — <code>racks.LPM_LocStock</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Country resolved via <code>DataSettings</code> JOIN (LocStock.Country has empty-string drift). Used to compute SKU and Div balance headroom.</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Item → Division map</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Primary: <code>LocStock.DivCode</code>. Fallback for new items not yet stocked: <code>upc_subclass → subclassmaster → Division MIN(DivCode)</code>.</td></tr>
                </tbody>
            </table>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">The two caps (always honoured)</h4>
            <ul style="margin:0 0 .9rem 1.1rem;">
                <li><strong>SKU Max balance</strong> &nbsp;= <code>SKUMax − SOH(Store,Item) − cumItem</code> &nbsp;
                    where <code>cumItem</code> is everything already allocated to this (Store,Item) across all phases (normal + RR + every prior box).</li>
                <li><strong>EOM Div balance</strong> &nbsp;= <code>TargetEOM − DivSOH(Store,Div) − cumDiv</code> &nbsp;
                    where <code>cumDiv</code> spans every phase. <strong>Hard ceiling</strong> — leftover qty in a box stays unallocated when this hits zero.</li>
            </ul>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Box read-order — warehouse priority</h4>
            <p style="margin:.1rem 0 .5rem;">
                The allocator reads boxes in this order:
                <strong>(1)</strong> warehouse priority from <code>dbo.LPM_WarehousePriority</code> — lower number first; warehouses missing from that table sort last,
                <strong>(2)</strong> larger-qty boxes first within a warehouse, then
                <strong>(3)</strong> deterministic tiebreak on Box No / Item code.
                The <strong>Warehouses</strong> dropdown at the top of the filter bar is a <em>filter</em> — it controls which warehouses participate in this run; it does not change priority order.
                The order does not change <em>which</em> boxes get allocated — only <em>which one is processed first</em>; per-(Store, Item) caps and SKU Max ceilings still apply identically across all warehouses.
            </p>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Phase 1a / 2a fill strategies</h4>
            <p style="margin:.1rem 0 .5rem;">
                The radio in the filter bar controls how each box-line spreads units across the eligible
                stores in its Division. Both modes honour SKU Max + EOM Div caps every cycle — they only
                differ in <em>which</em> store gets the next unit.
            </p>
            <table style="width:100%;border-collapse:collapse;margin-bottom:.6rem;">
                <thead>
                    <tr style="background:#f1f5f9;">
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;width:22%;">Strategy</th>
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;">How a unit is placed</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;vertical-align:top;">
                            <strong>Ranking + RR</strong><br/>
                            <span style="color:#64748b;font-size:.78rem;">(default)</span>
                        </td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>Recipe:</strong> walk stores in <code>PriorityRank ASC, WtAvgSoldQty DESC</code> order
                            and give <strong>1 unit per store per cycle</strong>. Repeat cycles until the line is exhausted
                            or every store is capped.
                            <br/><strong>Aim:</strong> equal <em>shipment qty</em> across stores per item line.
                            <br/><strong>What it produces:</strong> stores receive the same per-line qty until their
                            SKUMax/EOM caps stop them. Stores with smaller caps top out first; stores with bigger caps keep
                            taking. Division-level FillRate% can therefore vary widely.
                            <br/><strong>Pick this when:</strong> planning wants every store to carry roughly the same
                            number of pieces of the same item — fairest by shipment count.
                        </td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;vertical-align:top;">
                            <strong>Equal fill-rate %</strong>
                        </td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>Recipe:</strong> on every cycle, scan eligible stores, compute
                            <code>FillRate% = cumDiv ÷ EomBalance</code> for each, and give the unit to the store with the
                            <em>lowest</em> FillRate%. Tie-break: <code>PriorityRank ASC</code>.
                            <br/><strong>Aim:</strong> equal <em>Division-level FillRate%</em> across stores.
                            <br/><strong>What it produces:</strong> the laggard store always gets the next unit, so every
                            store converges toward the same proportional fill of its EOM headroom. Big-EOM stores get more
                            qty, small-EOM stores get less, but the percentages line up.
                            <br/><strong>Pick this when:</strong> planning wants comparable shelf-presence across stores —
                            fairest by share of plan.
                        </td></tr>
                </tbody>
            </table>

            <p style="margin:.4rem 0 .25rem;color:#475569;">
                <strong>Worked example</strong> — Div "Bags", line qty = 80, EomBalance per store = [7000, 4000, 2000]:
            </p>
            <table style="width:100%;border-collapse:collapse;margin-bottom:.9rem;font-size:.82rem;">
                <thead>
                    <tr style="background:#f1f5f9;">
                        <th style="text-align:left;padding:5px 10px;border:1px solid #e2e8f0;">Store</th>
                        <th style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">EomBalance</th>
                        <th style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">Ranking + RR → qty</th>
                        <th style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">Equal fill-rate % → qty</th>
                        <th style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">Ranking+RR FillRate%</th>
                        <th style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">Equal-rate FillRate%</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:5px 10px;border:1px solid #e2e8f0;">A</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">7,000</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">~27</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">~43</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">0.4%</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">0.6%</td></tr>
                    <tr><td style="padding:5px 10px;border:1px solid #e2e8f0;">B</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">4,000</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">~27</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">~25</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">0.7%</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">0.6%</td></tr>
                    <tr><td style="padding:5px 10px;border:1px solid #e2e8f0;">C</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">2,000</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">~26</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">~12</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">1.3%</td>
                        <td style="text-align:right;padding:5px 10px;border:1px solid #e2e8f0;">0.6%</td></tr>
                </tbody>
            </table>
            <p style="margin:.1rem 0 .9rem;color:#64748b;font-size:.78rem;">
                Ranking + RR → all three stores get nearly identical qty (~27 each), but FillRate% spreads from 0.4% to 1.3%.
                Equal fill-rate % → qty scales with EomBalance, so all three stores land at the same ~0.6% fill.
            </p>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Phase order</h4>
            <table style="width:100%;border-collapse:collapse;margin-bottom:.9rem;">
                <thead>
                    <tr style="background:#f1f5f9;">
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;width:14%;">Step</th>
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;width:18%;">Output Phase tag</th>
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;">Logic</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Phase 1a</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>P1</code> &nbsp;<code>IsRoundRobin=0</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>LPM boxes, round-robin fill.</strong> Behaviour depends on the
                            <em>Phase 1a / 2a fill</em> radio in the filter bar:
                            <ul style="margin:.3rem 0 .3rem 1.1rem;">
                                <li><strong>Ranking + RR</strong> (default) — walk stores in
                                    <code>PriorityRank ASC, WtAvgSoldQty DESC</code> order and deal
                                    <strong>1 unit per store per cycle</strong>. Same per-line qty across stores; per-store
                                    cap differences mean Division-level FillRate% can still skew.</li>
                                <li><strong>Equal fill-rate %</strong> — each unit goes to the eligible store with the
                                    <em>lowest current FillRate %</em> (= <code>cumDiv ÷ EomBalance</code>),
                                    tiebreak <code>PriorityRank ASC</code>. This pulls every store toward the same
                                    Division-level fill share rather than the same shipment qty.</li>
                            </ul>
                            Both modes honour SKU Max + EOM Div caps every cycle. Output Phase tag stays <code>P1</code>
                            with <code>IsRoundRobin=0</code> — the round-robin cycling is just the fill mechanism, this is
                            still the "normal" pass.
                        </td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Phase 1b RR</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>P1_RR</code> &nbsp;<code>IsRoundRobin=1</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>Eligibility gate:</strong> only runs when post-1a box usability % ≥
                            <em>Round Robin Box Usability %</em> (user input). Otherwise the box's leftover stays unallocated.
                            <br/>When it runs: deals 1 unit per store per cycle in priority order, honouring
                            <strong>both</strong> caps (SKU Max + EOM Div), cumulative against prior allocations.
                        </td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Phase 2a</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>P2</code> &nbsp;<code>IsRoundRobin=0</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>Non-LPM boxes, round-robin fill.</strong> Same per-line distribution as 1a (1 unit per store per cycle),
                            with two extra outer sorts: box <code>TotalQty DESC</code>, then <code>OverlapWithPhase1Items DESC</code>
                            (boxes whose items already started filling SKU caps in Phase 1 come first among similar-sized boxes).
                        </td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Phase 2b RR</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>P2_RR</code> &nbsp;<code>IsRoundRobin=1</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Same shape as Phase 1b — usability gate, both caps cumulative.
                        </td></tr>
                </tbody>
            </table>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Per-store fill order inside a box</h4>
            <p style="margin:.1rem 0 .9rem;">
                Stores within a Division are sorted by <code>PriorityRank ASC, WtAvgSoldQty DESC</code>. PriorityRank itself
                comes from EOM Generate as <code>(SoldQtyRank + TurnsRank) / 2</code>: lowest = highest priority, gets the first
                unit each cycle. Because both the normal and RR phases now distribute <strong>1 unit per store per cycle</strong>,
                the priority order determines the order within a cycle — every eligible store still receives units even when
                higher-priority stores haven't yet hit their cap.
            </p>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Trace decisions written to <code>LPMSIM_AllocTrace</code></h4>
            <table style="width:100%;border-collapse:collapse;margin-bottom:.9rem;">
                <thead>
                    <tr style="background:#f1f5f9;">
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;width:18%;">Decision</th>
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;">Meaning</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>ALLOC</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Normal allocation succeeded — Phase 1a or 2a.</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>ALLOC_RR</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Round-robin allocation succeeded — Phase 1b or 2b.</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>SKIP_SKUMAX</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">SKU Max cap reached for this (Store, Item). (Suppressed when "Verbose trace" is off.)</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>SKIP_TARGET</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">EOM Div balance reached for this (Store, Div). (Suppressed when "Verbose trace" is off.)</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>SKIP_NO_DIV</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Item couldn't be mapped to a Division (not in LocStock and not in upc_subclass) — line skipped.</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><code>SKIP_NO_EOM</code></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">No EOM rows for the item's Division (no candidate stores) — line skipped.</td></tr>
                </tbody>
            </table>

            <h4 style="margin:.25rem 0 .5rem;color:#0f172a;">Tables written by every run</h4>
            <ul style="margin:0 0 .25rem 1.1rem;">
                <li><code>LPMSIM_Output</code> — final allocation lines (one row per Box × Item × Store), tagged Phase + IsRoundRobin.</li>
                <li><code>LPMSIM_AllocTrace</code> — every decision considered (ALLOC / SKIP_*).</li>
                <li><code>LPMSIM_StoreItemBalance</code> — per-(Store, Item) snapshot: SOH + per-phase allocations + remaining SKU balance.</li>
                <li><code>LPMSIM_StoreDivBalance</code> — per-(Store, Div) snapshot: DivSOH + per-phase allocations + remaining EOM balance.</li>
                <li><code>LPMSIM_BoxBalance</code> — per-Box snapshot: BoxQty + per-phase allocations + Usability % + LeftOver qty.</li>
            </ul>

            <div style="margin-top:0.85rem;padding:0.6rem 0.8rem;background:#fef9c3;border-radius:6px;border:1px solid #facc15;">
                <strong>One-line summary:</strong>
                <em>For each box (LPM first, then Non-LPM), distribute units to UAE stores
                <strong>1 unit per store per cycle</strong> in PriorityRank order — guaranteeing equal fill across stores —
                respecting SKU Max and EOM Div caps cumulatively. If a box is at least
                <code>Round Robin Box Usability %</code> full after the normal pass, top it up via the named
                Round Robin step (same cycling, same caps). Boxes that hit either ceiling stop; no allocation ever crosses them.</em>
            </div>
        </div>
    </MudExpansionPanel>
</MudExpansionPanels>

@if (!string.IsNullOrEmpty(_lastError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-3"
              ShowCloseIcon="true" CloseIconClicked="() => _lastError = string.Empty">
        <MudText Typo="Typo.subtitle2"><strong>Error</strong></MudText>
        <pre style="white-space:pre-wrap; word-break:break-word; margin:0; font-family:inherit;">@_lastError</pre>
    </MudAlert>
}

@if (_lastRunDuration is TimeSpan dur)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mb-3"
              ShowCloseIcon="true" CloseIconClicked="() => _lastRunDuration = null">
        <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" Class="mr-1" />
        Last Generate took <strong>@FormatDuration(dur)</strong>
        @if (_lastRunSummary is string s) { <span> · @s</span> }
        @if (_busy)
        {
            <span style="margin-left:.5rem;color:#ca8a04;font-weight:600;">
                · Loading results…
            </span>
        }
    </MudAlert>
}

<div class="lpm-section lpm-filter-bar lpm-filter-compact">
    <MudGrid Spacing="2" Class="align-center">
        @* ─── Row 1 — six dropdowns, all md=2 (12 cols total) ────────────
           Country, Run Date, Box Source, LPM Months (conditional),
           Pallet Categories, Warehouses. When LPM Months is hidden
           (= Non-LPM-only run) the row falls back to 5 selectors and
           the grid wraps the rest naturally. *@
        <MudItem xs="6" sm="4" md="2">
            <MudSelect T="string" Label="Country" Value="_country"
                       ValueChanged="async v => { _country = v ?? string.Empty; _viewBatchNo = null; await LoadStoresForCountryAsync(); await ReloadCountryFiltersAsync(); await CheckAsync(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                @foreach (var c in _countries)
                {
                    <MudSelectItem Value="@c">@c</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudDatePicker Label="Run Date" Date="_runDate"
                           DateChanged="OnRunDateChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        @* Week dropdown — drives the per-Store × Div weekly cap. The
           allocator reads MerchNeedWeek{N} from LPM_EOM_Output based on
           this value, so the same EOM run can be re-allocated for
           different weeks without re-running EOM. *@
        <MudItem xs="6" sm="4" md="1">
            <MudSelect T="int" Label="Week" Value="_runWeek"
                       ValueChanged="(int v) => { _runWeek = v; }"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem T="int" Value="1">Wk 1</MudSelectItem>
                <MudSelectItem T="int" Value="2">Wk 2</MudSelectItem>
                <MudSelectItem T="int" Value="3">Wk 3</MudSelectItem>
                <MudSelectItem T="int" Value="4">Wk 4</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudSelect T="string" Label="Box Source"
                       SelectedValues="_selectedSources"
                       SelectedValuesChanged="OnBoxSourceChangedAsync"
                       MultiSelection="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Clearable
                       Placeholder="(Pick at least one)">
                <MudSelectItem T="string" Value="@("LPM")">LPM</MudSelectItem>
                <MudSelectItem T="string" Value="@("Non-LPM")">Non-LPM</MudSelectItem>
            </MudSelect>
        </MudItem>
        @if (_srcLpm)
        {
            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="DateTime" Label="LPM Months"
                           SelectedValues="_selectedLpmMonths"
                           SelectedValuesChanged="async (IEnumerable<DateTime> vs) => { _selectedLpmMonths = vs?.ToHashSet() ?? new HashSet<DateTime>(); await CheckAsync(); }"
                           MultiSelection="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable
                           Placeholder="(All)"
                           SelectAll="true" SelectAllText="All months"
                           MultiSelectionTextFunc="@(new Func<List<string>, string>(SelectedLpmMonthsText))">
                    @foreach (var m in _allLpmMonths)
                    {
                        <MudSelectItem T="DateTime" Value="m">@m.ToString("MMM-yy")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        }
        <MudItem xs="6" sm="4" md="2">
            <MudSelect T="string" Label="Pallet Categories"
                       SelectedValues="_selectedPalletCategories"
                       SelectedValuesChanged="async (IEnumerable<string> vs) => { _selectedPalletCategories = vs?.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new(StringComparer.OrdinalIgnoreCase); await CheckAsync(); }"
                       MultiSelection="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Clearable
                       Placeholder="(All)"
                       SelectAll="true" SelectAllText="All categories"
                       MultiSelectionTextFunc="@(new Func<List<string>, string>(SelectedPalletCategoriesText))">
                @foreach (var pc in _allPalletCategories)
                {
                    <MudSelectItem T="string" Value="pc">@pc</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudSelect T="string" Label="Warehouses"
                       SelectedValues="_selectedWarehouses"
                       SelectedValuesChanged="OnWarehousesSelectionChanged"
                       MultiSelection="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Clearable
                       Placeholder="(All)"
                       SelectAll="true" SelectAllText="All warehouses"
                       MultiSelectionTextFunc="@(new Func<List<string>, string>(SelectedWarehousesText))">
                @foreach (var w in _allWarehouses)
                {
                    <MudSelectItem T="string" Value="@w">@w</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @* ─── Row 2 — strategy + flags packed together (12 cols) ─────────
           Phase fill (radios), Box% override (numeric), Season (checkboxes),
           SKU Max only (checkbox), Include Non-Purchased (checkbox), Verbose
           trace (checkbox). Aligned vertically with the row above. *@
        <MudItem xs="12" sm="6" md="3">
            <div class="lpm-fb-group">
                <span class="lpm-fb-label">Phase 1a / 2a fill</span>
                <MudRadioGroup T="LpmSimFillStrategy" Value="_fillStrategy"
                               ValueChanged="(LpmSimFillStrategy v) => _fillStrategy = v"
                               Class="lpm-fb-radio">
                    <MudRadio T="LpmSimFillStrategy" Value="LpmSimFillStrategy.EqualPerStore"
                              Color="Color.Primary" Dense="true" Size="Size.Small">Ranking + RR</MudRadio>
                    <MudRadio T="LpmSimFillStrategy" Value="LpmSimFillStrategy.EqualFillRate"
                              Color="Color.Primary" Dense="true" Size="Size.Small">Equal fill %</MudRadio>
                </MudRadioGroup>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudTooltip Text="Phase 1b / 2b override threshold. Round-robin runs only for boxes whose post-normal usability % is ≥ this value." Placement="Placement.Top">
                <MudNumericField T="int" Label="Box% override"
                                 Value="_overridePct"
                                 ValueChanged="(int v) => _overridePct = v"
                                 Min="0" Max="100" Step="5"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudTooltip>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <div class="lpm-fb-group">
                <span class="lpm-fb-label">Season</span>
                <div class="d-flex flex-wrap gap-1 align-center">
                    <MudCheckBox T="bool" Value="_seasonSummer" ValueChanged="async (bool v) => { _seasonSummer = v; await CheckAsync(); }"
                                 Color="Color.Primary" Dense="true" Size="Size.Small">Summer</MudCheckBox>
                    <MudCheckBox T="bool" Value="_seasonWinter" ValueChanged="async (bool v) => { _seasonWinter = v; await CheckAsync(); }"
                                 Color="Color.Primary" Dense="true" Size="Size.Small">Winter</MudCheckBox>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="5" Class="d-flex flex-wrap align-center gap-2">
            <MudTooltip Text="When ON, the allocator bypasses Merch Need (Week) and uses SKU Max as the only cap. EqualFillRate switches its denominator from MerchNeedWeek to SkuMax."
                        Placement="Placement.Top">
                <MudCheckBox T="bool" Value="_ignoreMerchNeed"
                             ValueChanged="(bool v) => _ignoreMerchNeed = v"
                             Color="Color.Warning" Size="Size.Small" Dense="true"
                             Label="SKU Max only" />
            </MudTooltip>
            <MudTooltip Text="When ON, drops the ShopEligible <> 'E' filter so already-shopped boxes (ShopEligible='E') are also pulled into SIM."
                        Placement="Placement.Top">
                <MudCheckBox T="bool" Value="_includePurchasedBoxes"
                             ValueChanged="async (bool v) => { _includePurchasedBoxes = v; await CheckAsync(); }"
                             Color="Color.Warning" Size="Size.Small" Dense="true"
                             Label="Incl. Non-Purchased" />
            </MudTooltip>
            <MudCheckBox T="bool" @bind-Value="_verboseTrace" Color="Color.Primary"
                         Dense="true" Size="Size.Small">
                Verbose trace
            </MudCheckBox>
        </MudItem>

        @* ─── Row 3 — action buttons (full-width, right-aligned) ───── *@
        <MudItem xs="12" Class="d-flex align-center gap-2 justify-end flex-wrap">
            @* Re-check forces a full refresh by clearing the batch cache. *@
            <MudButton Variant="Variant.Outlined" Size="Size.Small" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@(string.IsNullOrEmpty(_country) || _busy)"
                       OnClick="@(async () => { _loadedBatchNo = null; await CheckAsync(); })">
                Re-check
            </MudButton>
            @* 1.14.57 — Generate / Approve / Delete restricted to Admin.
               Editors and PlanningManagers retain page-view access (readiness,
               summary tabs, exports, batch history) via the page-level
               [Authorize(Roles = AdminOrEditorOrPlanner)] attribute but cannot
               run / approve / delete a SIM batch. Build SKU Max stays open to
               all roles since it's a planning prep step, not a batch
               commitment.
               1.14.66 — Also accept the new "SIM Generate/Approve Access"
               role (RoleCode = "SimGenerateApprove") so an admin can grant
               run-rights without giving full Admin. *@
            <AuthorizeView Roles="Admin,SimGenerateApprove">
                <Authorized>
                    <MudTooltip Text="@(_skuMaxStatus?.LastBuildTS is null ? "Click Build SKU Max first — no snapshot exists for this period" : "")"
                                Disabled="@(_skuMaxStatus?.LastBuildTS is not null)">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" DropShadow="false"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   Disabled="@(_readiness?.CanGenerate != true || _busy || _isBuildingSkuMax || _skuMaxStatus?.LastBuildTS is null)"
                                   OnClick="GenerateAsync">
                            Generate
                        </MudButton>
                    </MudTooltip>
                    <MudButton Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               Disabled="@(_readiness?.CanApprove != true || _busy)" OnClick="ApproveAsync">
                        Approve
                    </MudButton>
                    <MudButton Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               Disabled="@(_readiness?.CanDelete != true || _busy)" OnClick="DeleteAsync">
                        Delete
                    </MudButton>
                </Authorized>
                <NotAuthorized>
                    <MudText Typo="Typo.caption" Style="color:#94a3b8;font-style:italic;">
                        Generate / Approve / Delete restricted to Admin or "SIM Generate/Approve Access" users.
                    </MudText>
                </NotAuthorized>
            </AuthorizeView>
        </MudItem>

        @* ─── Row 3 — Current Batch banner (full-width, centered) ───
           Lives inside the input frame so the planner sees the active
           batch right next to the inputs that produced it. Batch # is
           displayed in a larger, accent-colored font for at-a-glance
           recognition. *@
        @if (_readiness is not null)
        {
            <MudItem xs="12" Class="d-flex align-center justify-center flex-wrap gap-2"
                     Style="padding-top:.25rem;padding-bottom:.25rem;border-top:1px solid #e2e8f0;margin-top:.4rem;">
                <span style="font-weight:700;color:#475569;letter-spacing:.04em;text-transform:uppercase;font-size:0.72rem;">
                    Current Batch
                </span>
                @if (_readiness.CurrentBatchNo is null)
                {
                    <span style="color:#94a3b8;font-size:0.85rem;">
                        No batch yet for @_country on @_runDate?.ToString("yyyy-MM-dd")
                    </span>
                }
                else
                {
                    var _bnNo  = _readiness.CurrentBatchNo;
                    var _bSt   = _readiness.CurrentStatus ?? "";
                    var _bSrc  = _readiness.CurrentBatchSources;
                    var _bSea  = _readiness.CurrentBatchSeasons;
                    var _bRr   = _readiness.CurrentBatchOverrideUsabilityPct;
                    var _bWh   = _readiness.CurrentBatchWarehouses;
                    var _bFs   = _readiness.CurrentBatchFillStrategy;
                    var _stCol = _bSt == "Approved" ? "#16a34a" : (_bSt == "Draft" ? "#d97706" : "#475569");
                    <span style="font-size:1.35rem;font-weight:800;color:#2563eb;line-height:1;">
                        #@_bnNo
                    </span>
                    <span style="font-size:0.85rem;font-weight:700;color:@_stCol;padding:.1rem .5rem;border:1px solid @_stCol;border-radius:999px;">
                        @_bSt
                    </span>
                    @if (_readiness.CurrentRunDate is DateTime _bRunDt)
                    {
                        <span style="color:#475569;font-size:0.78rem;">
                            · RunDate <strong>@_bRunDt.ToString("dd-MMM-yyyy")</strong>
                        </span>
                    }
                    @if (_readiness.CurrentCreateTS is DateTime _bCts)
                    {
                        <span style="color:#475569;font-size:0.78rem;">
                            · Generated <strong>@TimeFormatting.ToGccString(_bCts, "dd-MMM-yyyy HH:mm")</strong>@(string.IsNullOrEmpty(_readiness.CurrentCreatedBy) ? "" : $" by {_readiness.CurrentCreatedBy}")
                        </span>
                    }
                    @if (_readiness.ExistingApproved && _readiness.CurrentApprovedTS is not null)
                    {
                        <span style="color:#16a34a;font-size:0.78rem;">
                            · Approved <strong>@TimeFormatting.ToGccString(_readiness.CurrentApprovedTS, "dd-MMM-yyyy HH:mm")</strong> by @_readiness.CurrentApprovedBy
                        </span>
                    }
                    <span style="color:#cbd5e1;font-size:0.85rem;">|</span>
                    <span style="color:#64748b;font-size:0.78rem;">
                        Sources: <strong style="color:#334155;">@(string.IsNullOrEmpty(_bSrc) ? "(unknown)" : _bSrc)</strong>
                        &nbsp;·&nbsp; Seasons: <strong style="color:#334155;">@(string.IsNullOrEmpty(_bSea) ? "(unknown)" : _bSea)</strong>
                        &nbsp;·&nbsp; Box%: <strong style="color:#334155;">@(_bRr?.ToString() ?? "—")</strong>
                        &nbsp;·&nbsp; Fill: <strong style="color:#334155;">@FillLabel(_bFs)</strong>
                        &nbsp;·&nbsp; WH: <strong style="color:#334155;">@(string.IsNullOrEmpty(_bWh) ? "(All)" : _bWh)</strong>
                    </span>
                    @if (!FilterMatchesCurrent())
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            Checkboxes differ — Generate again to apply
                        </MudChip>
                    }
                }
            </MudItem>
        }
    </MudGrid>
</div>

@if (_busy)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
}

@if (_readiness is not null)
{
    @* ---- SKU Max Build — single compact line at the top ----
       Builds LPM_SimItemSkuMax for the run period. SIM Generate refuses to
       run unless this snapshot is fresh today. Rebuild whenever WH Box
       items, SKU Max Rules, or Volume Group assignments change. *@
    var _sku      = _skuMaxStatus;
    var _skuStale = _sku?.IsFreshToday != true;
    var _inf      = _inputFreshness;
    <div class="lpm-section mb-2 d-flex align-center flex-wrap gap-2"
         style="padding:0.35rem 0.75rem;font-size:0.78rem;">
        <span style="font-weight:700;color:#475569;letter-spacing:.04em;text-transform:uppercase;">
            SKU Max (@_country @_runDate?.ToString("yyyy-MM"))
        </span>
        @if (_sku is null)
        {
            <span style="color:#64748b;">Loading…</span>
        }
        else if (_sku.LastBuildTS is null)
        {
            <span style="color:#dc2626;font-weight:600;">✕ No snapshot — click Build first.</span>
        }
        else if (_skuStale)
        {
            <span style="color:#d97706;font-weight:600;">
                ⚠ Stale — last @_sku.LastBuildTS?.ToString("dd-MMM HH:mm")@(string.IsNullOrEmpty(_sku.LastBuildBy) ? "" : $" · {_sku.LastBuildBy}") · @_sku.RowCount.ToString("N0") rows@(_sku.LastBuildDuration is { } dur1 ? $" · in {FormatDuration(dur1)}" : "")
            </span>
        }
        else
        {
            <span style="color:#16a34a;font-weight:600;">
                ✓ Built @_sku.LastBuildTS?.ToString("dd-MMM HH:mm")@(string.IsNullOrEmpty(_sku.LastBuildBy) ? "" : $" · {_sku.LastBuildBy}") · @_sku.RowCount.ToString("N0") rows@(_sku.LastBuildDuration is { } dur2 ? $" · in {FormatDuration(dur2)}" : "")
            </span>
        }
        @if (_inf is not null)
        {
            <span style="color:#94a3b8;">|</span>
            <span style="color:#64748b;">
                WH Box @(_inf.LastWHBoxLoad?.ToString("dd-MMM") ?? "—")
                &nbsp;·&nbsp; Rule @(_inf.LastSkuMaxRuleChange?.ToString("dd-MMM") ?? "—")
                &nbsp;·&nbsp; EOM @(_inf.LastVolumeGroupChange?.ToString("dd-MMM HH:mm") ?? "—")
            </span>
        }
        @* Scope selector — lets the planner refresh only LPM-items, only
           Non-LPM items, or every item. Each scope's DELETE only removes
           rows for items present in that scope, so building "LPM Only"
           leaves the Non-LPM rows untouched (and vice versa). The scope
           dropdown shows the SKU count for the currently-selected scope
           inline (e.g. "All items · 48,612 SKUs"); the small chip-row
           below shows all three counts at once for comparison. *@
        <MudSelect T="LpmSimSkuMaxScope" Value="_selectedSkuMaxScope"
                   ValueChanged="@(v => _selectedSkuMaxScope = v)"
                   Label="Scope" Variant="Variant.Outlined" Margin="Margin.Dense"
                   Dense="true" Class="ml-auto" Style="max-width:170px;"
                   Disabled="@_isBuildingSkuMax">
            <MudSelectItem Value="LpmSimSkuMaxScope.All">All items</MudSelectItem>
            <MudSelectItem Value="LpmSimSkuMaxScope.LpmOnly">LPM only</MudSelectItem>
            <MudSelectItem Value="LpmSimSkuMaxScope.NonLpmOnly">Non-LPM only</MudSelectItem>
        </MudSelect>
        @if (_skuMaxScopeCounts is { } counts)
        {
            var sel = _selectedSkuMaxScope switch
            {
                LpmSimSkuMaxScope.LpmOnly    => counts.Lpm,
                LpmSimSkuMaxScope.NonLpmOnly => counts.NonLpm,
                _                             => counts.All,
            };
            <span style="font-size:0.78rem;color:#0f172a;font-weight:600;white-space:nowrap;"
                  title="@($"All {counts.All:N0} · LPM {counts.Lpm:N0} · Non-LPM {counts.NonLpm:N0}")">
                @sel.ToString("N0") SKUs
            </span>
            <span style="font-size:0.7rem;color:#64748b;white-space:nowrap;">
                (All @counts.All.ToString("N0") · LPM @counts.Lpm.ToString("N0") · Non-LPM @counts.NonLpm.ToString("N0"))
            </span>
        }
        else if (!string.IsNullOrEmpty(_country))
        {
            <span style="font-size:0.75rem;color:#94a3b8;white-space:nowrap;">…</span>
        }
        <MudButton Color="@(_skuStale ? Color.Warning : Color.Default)"
                   Variant="Variant.Filled" Size="Size.Small" DropShadow="false"
                   StartIcon="@Icons.Material.Filled.Build"
                   Disabled="@(_busy || _isBuildingSkuMax || string.IsNullOrEmpty(_country) || _runDate is null || _readiness?.EomReady != true)"
                   OnClick="BuildSkuMaxAsync">
            @if (_isBuildingSkuMax) { <text>Building…</text> } else { <text>Build SKU Max</text> }
        </MudButton>
    </div>
    @* SKU Max build timing — Start / End / Duration. Live elapsed while
       building; persistent timestamps after the build completes. Tucked
       below the SKU Max status row so it doesn't compete with the
       primary status indicator. *@
    @if (_isBuildingSkuMax && _skuMaxBuildStartTS.HasValue)
    {
        var elapsed = DateTime.Now - _skuMaxBuildStartTS.Value;
        var startedBy = _activeBuildJob?.StartedBy;
        var stage     = _activeBuildJob?.StatusMessage;
        var scopeTag  = SkuMaxScopeLabel(_activeBuildJob?.Scope ?? LpmSimSkuMaxScope.All);
        <div class="lpm-section mb-2 d-flex align-center flex-wrap gap-3"
             style="padding:0.3rem 0.75rem;font-size:0.75rem;background:#fef3c7;border:1px solid #fcd34d;color:#78350f;">
            <span style="font-weight:700;letter-spacing:.04em;text-transform:uppercase;">SKU Max Build — Running</span>
            <span><strong>Scope:</strong> @scopeTag</span>
            <span><strong>Start:</strong> @_skuMaxBuildStartTS.Value.ToString("dd-MMM HH:mm:ss")</span>
            <span><strong>Elapsed:</strong> @FormatDuration(elapsed)</span>
            @if (!string.IsNullOrEmpty(startedBy))
            {
                <span><strong>By:</strong> @startedBy</span>
            }
            @if (!string.IsNullOrEmpty(stage))
            {
                <span style="font-style:italic;color:#92400e;"><strong>Stage:</strong> @stage</span>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       DropShadow="false" StartIcon="@Icons.Material.Filled.Cancel"
                       Class="ml-auto" OnClick="CancelSkuMaxBuildAsync">
                Cancel build
            </MudButton>
        </div>
        <MudProgressLinear Color="Color.Warning" Indeterminate="true" Class="mb-2" />
    }
    else if (_activeBuildJob is { Status: SkuMaxBuildStatus.Cancelled })
    {
        <div class="lpm-section mb-2 d-flex align-center flex-wrap gap-3"
             style="padding:0.3rem 0.75rem;font-size:0.75rem;background:#fef3c7;border:1px solid #fcd34d;color:#92400e;">
            <span style="font-weight:700;letter-spacing:.04em;text-transform:uppercase;">SKU Max Build — Cancelled</span>
            @if (_skuMaxBuildStartTS.HasValue)
            { <span><strong>Start:</strong> @_skuMaxBuildStartTS.Value.ToString("dd-MMM HH:mm:ss")</span> }
            @if (_skuMaxBuildEndTS.HasValue)
            { <span><strong>End:</strong> @_skuMaxBuildEndTS.Value.ToString("dd-MMM HH:mm:ss")</span> }
            @if (_skuMaxBuildDuration.HasValue)
            { <span><strong>Duration:</strong> @FormatDuration(_skuMaxBuildDuration.Value)</span> }
        </div>
    }
    else if (_activeBuildJob is { Status: SkuMaxBuildStatus.Failed })
    {
        <div class="lpm-section mb-2 d-flex align-center flex-wrap gap-3"
             style="padding:0.3rem 0.75rem;font-size:0.75rem;background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;">
            <span style="font-weight:700;letter-spacing:.04em;text-transform:uppercase;">SKU Max Build — Failed</span>
            @if (_skuMaxBuildStartTS.HasValue)
            { <span><strong>Start:</strong> @_skuMaxBuildStartTS.Value.ToString("dd-MMM HH:mm:ss")</span> }
            @if (_skuMaxBuildEndTS.HasValue)
            { <span><strong>End:</strong> @_skuMaxBuildEndTS.Value.ToString("dd-MMM HH:mm:ss")</span> }
            @if (_skuMaxBuildDuration.HasValue)
            { <span><strong>Duration:</strong> @FormatDuration(_skuMaxBuildDuration.Value)</span> }
            @if (!string.IsNullOrEmpty(_activeBuildJob?.Error))
            { <span style="margin-left:.5rem;">— @_activeBuildJob!.Error</span> }
        </div>
    }
    else if (_skuMaxBuildStartTS.HasValue && _skuMaxBuildEndTS.HasValue && _skuMaxBuildDuration.HasValue)
    {
        <div class="lpm-section mb-2 d-flex align-center flex-wrap gap-3"
             style="padding:0.3rem 0.75rem;font-size:0.75rem;background:#ecfdf5;border:1px solid #a7f3d0;color:#065f46;">
            <span style="font-weight:700;letter-spacing:.04em;text-transform:uppercase;">Last SKU Max Build</span>
            <span><strong>Start:</strong> @_skuMaxBuildStartTS.Value.ToString("dd-MMM HH:mm:ss")</span>
            <span><strong>End:</strong> @_skuMaxBuildEndTS.Value.ToString("dd-MMM HH:mm:ss")</span>
            <span><strong>Duration:</strong> @FormatDuration(_skuMaxBuildDuration.Value)</span>
        </div>
    }

    @* Current Batch banner now lives inside the input frame above (Row 3
       of the MudGrid). Removing the duplicate here keeps the page compact. *@

    @* ---- Input Readiness — collapsible toggle (collapsed by default) ----
       The 3 readiness cards (EOM / SOH / Eligible Boxes) plus the per-source
       Box segments table live here. Hidden until the planner needs to
       investigate the inputs — saves vertical space on the everyday flow. *@
    <MudExpansionPanels Elevation="0" Class="mb-3">
        <MudExpansionPanel Text="Input Readiness — EOM, SOH, Eligible Boxes" Icon="@Icons.Material.Filled.Inventory">
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" sm="6" md="4">
                    <div class="lpm-metric-card @(_readiness.EomReady ? "lpm-accent-green" : "lpm-accent-rose")">
                        <div class="lpm-metric-label">EOM Output</div>
                        <div class="lpm-metric-sub">@_readiness.EomDetail</div>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <div class="lpm-metric-card @(_readiness.LocStockReady ? "lpm-accent-green" : "lpm-accent-amber")">
                        <div class="lpm-metric-label">SOH (LPM_LocStock)</div>
                        <div class="lpm-metric-sub">@_readiness.LocStockDetail</div>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <div class="lpm-metric-card @(_readiness.BoxesReady ? "lpm-accent-green" : "lpm-accent-rose")">
                        <div class="lpm-metric-label">Eligible Boxes (Selected)</div>
                        <div class="lpm-metric-sub">@_readiness.BoxesDetail</div>
                    </div>
                </MudItem>
            </MudGrid>

            @if (_readiness.BoxSegments is BoxSegmentCounts seg)
    {
        <div class="lpm-section mb-3" style="padding:0.6rem 1rem;">
            <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                Eligible boxes (@CurrentFilterCaption())
            </MudText>
            <MudText Typo="Typo.caption" Style="display:block;color:#64748b;font-size:0.72rem;margin-top:.15rem;">
                <strong>LPM</strong>: LPMDt is set (all months — past, current, and future) &nbsp;·&nbsp;
                <strong>Non-LPM</strong>: LPMDt IS NULL &nbsp;·&nbsp;
                <strong>Non-Purchased</strong>: <code>ShopEligible = 'E'</code> (still in-process).
                Season is read from <code>pallettype.Season</code> (<code>'W'</code> = Winter, otherwise Summer).
            </MudText>
            <MudSimpleTable Dense Hover Bordered Class="lpm-seg-table mt-1" Style="font-size:0.82rem;">
                <thead>
                    <tr>
                        <th></th>
                        <th class="text-right">LPM</th>
                        <th class="text-right">LPM Non-Purchased</th>
                        <th class="text-right">Non-LPM</th>
                        <th class="text-right" style="background:#f1f5f9;font-weight:600;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Summer</strong></td>
                        <td class="text-right">@seg.LpmSummerBoxes.ToString("N0") <span class="text-muted">(@seg.LpmSummerQty.ToString("N0"))</span></td>
                        <td class="text-right">@seg.LpmSummerNpBoxes.ToString("N0") <span class="text-muted">(@seg.LpmSummerNpQty.ToString("N0"))</span></td>
                        <td class="text-right">@seg.NonLpmSummerBoxes.ToString("N0") <span class="text-muted">(@seg.NonLpmSummerQty.ToString("N0"))</span></td>
                        <td class="text-right" style="background:#f1f5f9;">
                            <strong>@((seg.LpmSummerBoxes + seg.LpmSummerNpBoxes + seg.NonLpmSummerBoxes).ToString("N0"))</strong>
                            <span class="text-muted">(@((seg.LpmSummerQty + seg.LpmSummerNpQty + seg.NonLpmSummerQty).ToString("N0")))</span>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Winter</strong></td>
                        <td class="text-right">@seg.LpmWinterBoxes.ToString("N0") <span class="text-muted">(@seg.LpmWinterQty.ToString("N0"))</span></td>
                        <td class="text-right">@seg.LpmWinterNpBoxes.ToString("N0") <span class="text-muted">(@seg.LpmWinterNpQty.ToString("N0"))</span></td>
                        <td class="text-right">@seg.NonLpmWinterBoxes.ToString("N0") <span class="text-muted">(@seg.NonLpmWinterQty.ToString("N0"))</span></td>
                        <td class="text-right" style="background:#f1f5f9;">
                            <strong>@((seg.LpmWinterBoxes + seg.LpmWinterNpBoxes + seg.NonLpmWinterBoxes).ToString("N0"))</strong>
                            <span class="text-muted">(@((seg.LpmWinterQty + seg.LpmWinterNpQty + seg.NonLpmWinterQty).ToString("N0")))</span>
                        </td>
                    </tr>
                    <tr style="background:#f8fafc;font-weight:600;">
                        <td>Total</td>
                        <td class="text-right">@((seg.LpmSummerBoxes + seg.LpmWinterBoxes).ToString("N0")) <span class="text-muted">(@((seg.LpmSummerQty + seg.LpmWinterQty).ToString("N0")))</span></td>
                        <td class="text-right">@((seg.LpmSummerNpBoxes + seg.LpmWinterNpBoxes).ToString("N0")) <span class="text-muted">(@((seg.LpmSummerNpQty + seg.LpmWinterNpQty).ToString("N0")))</span></td>
                        <td class="text-right">@((seg.NonLpmSummerBoxes + seg.NonLpmWinterBoxes).ToString("N0")) <span class="text-muted">(@((seg.NonLpmSummerQty + seg.NonLpmWinterQty).ToString("N0")))</span></td>
                        <td class="text-right" style="background:#e2e8f0;">
                            @((seg.LpmSummerBoxes + seg.LpmSummerNpBoxes + seg.NonLpmSummerBoxes + seg.LpmWinterBoxes + seg.LpmWinterNpBoxes + seg.NonLpmWinterBoxes).ToString("N0"))
                            <span class="text-muted">(@((seg.LpmSummerQty + seg.LpmSummerNpQty + seg.NonLpmSummerQty + seg.LpmWinterQty + seg.LpmWinterNpQty + seg.NonLpmWinterQty).ToString("N0")))</span>
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>
            <MudText Typo="Typo.caption" Style="color:#64748b;">Counts are Boxes; quantity in parentheses.</MudText>
        </div>
            }
        </MudExpansionPanel>
    </MudExpansionPanels>

    @if (_readiness.ExistingApproved)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
            This run is <strong>Approved</strong> &mdash; rerun is blocked. Click <strong>Delete</strong> to archive it
            to the backup tables, then Generate again.
        </MudAlert>
    }
    else if (_readiness.ExistingDraft)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
            A <strong>Draft</strong> batch already exists. Click <strong>Generate</strong> to overwrite it,
            or <strong>Approve</strong> to finalize.
        </MudAlert>
    }
    else if (!_readiness.EomReady)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
            EOM Output must be generated for @_country @_runDate?.ToString("yyyy-MM") before LPM SIM can run.
        </MudAlert>
    }
}

@if (_readiness?.CurrentBatchNo is long currentBn)
{
    @* Snapshot of inputs (Sources / Seasons / Box% / Fill / Warehouses) lives
       in the always-visible "Current Batch" line above. Result preview keeps
       just the section header to anchor the result tabs below + the Batch #
       lookup so the planner can jump to a previous run without first
       knowing its (Country, RunDate). *@
    <div class="d-flex flex-wrap align-center gap-3 mb-2">
        <MudText Typo="Typo.h6" Class="ma-0">
            Result preview &mdash; batch #@currentBn (@(_readiness?.CurrentStatus))
        </MudText>
        @if (_viewBatchNo.HasValue)
        {
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Secondary"
                       DropShadow="false" StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="BackToLatestBatchAsync">
                Back to latest
            </MudButton>
        }
        <span style="color:#cbd5e1;">|</span>
        <MudText Typo="Typo.caption" Style="color:#64748b;">View another batch:</MudText>
        <MudNumericField T="long?" Value="_loadByBatchNo"
                         ValueChanged="(long? v) => _loadByBatchNo = v"
                         Min="1" HideSpinButtons="true" Clearable
                         Placeholder="Batch #"
                         Variant="Variant.Outlined" Margin="Margin.Dense"
                         Style="max-width:140px;" />
        <MudButton Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                   DropShadow="false" StartIcon="@Icons.Material.Filled.Search"
                   Disabled="@(_loadByBatchNo is null)"
                   OnClick="LoadByBatchNoAsync">Load</MudButton>
        @if (!string.IsNullOrEmpty(_loadByBatchError))
        {
            <span style="color:#dc2626;font-size:0.78rem;">@_loadByBatchError</span>
        }
    </div>

    @* Pill list of every batch for this (Country, RunDate) — Draft + all
       Approved. Click a pill to switch the result preview to that batch.
       The currently-viewed batch's pill is filled; others are outlined. *@
    @if (_periodBatches.Count > 1)
    {
        <div class="d-flex flex-wrap align-center gap-2 mb-3"
             style="font-size:0.78rem;">
            <span style="color:#64748b;">All batches for @_country @_runDate?.ToString("yyyy-MM-dd"):</span>
            @foreach (var b in _periodBatches)
            {
                var isCurrent = b.LPMBatchNo == currentBn;
                var statusCol = b.Status == "Approved" ? "Color.Success"
                              : b.Status == "Draft"    ? "Color.Warning"
                              : "Color.Default";
                <MudButton Variant="@(isCurrent ? Variant.Filled : Variant.Outlined)"
                           Color="@(b.Status == "Approved" ? Color.Success : (b.Status == "Draft" ? Color.Warning : Color.Default))"
                           Size="Size.Small" DropShadow="false"
                           OnClick="@(() => ViewBatchAsync(b.LPMBatchNo))">
                    #@b.LPMBatchNo @b.Status
                    <span style="margin-left:.4rem;color:#94a3b8;font-weight:400;">@TimeFormatting.ToGccString(b.CreateTS, "dd-MMM HH:mm")</span>
                </MudButton>
            }
        </div>
    }

    @if (_sourceWh is { Count: > 0 } swRows)
    {
        var swTotalSku   = swRows.Sum(r => r.SkuCount);   // sum across rows (same item across WHs counted multiple times)
        var swTotalBoxes = swRows.Sum(r => r.BoxCount);
        var swTotalBoxQty = swRows.Sum(r => r.BoxQty);
        var swTotalSimQty = swRows.Sum(r => r.SimQty);
        <div class="lpm-section mb-3" style="padding:0.6rem 1rem;">
            <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                Allocation result — split by source × warehouse
            </MudText>
            <MudSimpleTable Dense Hover Bordered Class="lpm-seg-table mt-1" Style="font-size:0.85rem;">
                <thead>
                    <tr>
                        <th>Kind</th>
                        <th>Warehouse</th>
                        <th class="text-right">SKU Count</th>
                        <th class="text-right">Boxes</th>
                        <th class="text-right">Box Qty</th>
                        <th class="text-right">Output SIM Qty</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in swRows)
                    {
                        <tr>
                            <td>
                                @if (r.Kind == "LPM")
                                {
                                    <span class="lpm-status lpm-accent-blue">LPM</span>
                                }
                                else
                                {
                                    <span class="lpm-status lpm-accent-amber">Non-LPM</span>
                                }
                            </td>
                            <td><code>@r.Warehouse</code></td>
                            <td class="text-right">@r.SkuCount.ToString("N0")</td>
                            <td class="text-right">@r.BoxCount.ToString("N0")</td>
                            <td class="text-right">@r.BoxQty.ToString("N0")</td>
                            <td class="text-right">@r.SimQty.ToString("N0")</td>
                        </tr>
                    }
                    <tr style="background:#f8fafc;font-weight:600;">
                        <td colspan="2">Total</td>
                        <td class="text-right">@swTotalSku.ToString("N0")</td>
                        <td class="text-right">@swTotalBoxes.ToString("N0")</td>
                        <td class="text-right">@swTotalBoxQty.ToString("N0")</td>
                        <td class="text-right" style="background:#fef9c3;">@swTotalSimQty.ToString("N0")</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
            <MudText Typo="Typo.caption" Style="color:#64748b;">
                One row per (Kind, Warehouse) pair that participated in this batch. <strong>SKU Count</strong>
                = distinct itemcodes; <strong>Boxes</strong> = distinct BoxNos; <strong>Box Qty</strong> =
                warehouse-side stock total of those boxes; <strong>Output SIM Qty</strong> = qty actually
                allocated. SKU/Boxes totals can double-count when the same item or box appears in multiple
                warehouses — Output SIM Qty is the only sum guaranteed not to double-count.
            </MudText>
        </div>
    }

    <MudTabs Elevation="0" Rounded="true" Border="true"
             ApplyEffectsToContainer="true" PanelClass="pa-4" Class="mud-paper lpm-sim-tabs"
             ActivePanelIndexChanged="OnTabChanged">

        <MudTabPanel Text="Summary (per Store × Division)" Icon="@Icons.Material.Filled.Insights">
            @if (_loadingSummary)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            <MudGrid Spacing="2" Class="mb-2">
                @* Search + checkbox filters via MultiSelectFilter component.
                   Combines free-text search with per-item checkboxes — solves
                   the "long division/store list is hard to scan" problem
                   while keeping exact-match (so "Menswear" doesn't also match
                   "Womenswear" the way the old Contains-based filter did). *@
                <MudItem xs="12" md="3">
                    <MultiSelectFilter Label="Filter Store" Placeholder="All stores"
                                       Items="@(_allStores.OrderBy(s => s.StoreID).Select(s => s.StoreID).ToList())"
                                       LabelOf="@(id => { var match = _allStores.FirstOrDefault(s => s.StoreID == id); return string.IsNullOrEmpty(match.StoreName) ? id : $"{id} · {match.StoreName}"; })"
                                       Selected="_filterStoresMulti"
                                       SelectedChanged="@((HashSet<string> s) => { _filterStoresMulti = s; StateHasChanged(); })" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MultiSelectFilter Label="Filter Division" Placeholder="All divisions"
                                       Items="@(_allDivisions.OrderBy(d => d, StringComparer.OrdinalIgnoreCase).ToList())"
                                       Selected="_filterDivisionsMulti"
                                       SelectedChanged="@((HashSet<string> s) => { _filterDivisionsMulti = s; StateHasChanged(); })" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Min Box Usability %"
                                     Value="_minUsability"
                                     ValueChanged="async (decimal? v) => { _minUsability = v; await ReloadActiveTabAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Max="100m" Step="5m" Clearable
                                     HelperText="Server-side filter applied to all tabs" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Max Box Usability %"
                                     Value="_maxUsability"
                                     ValueChanged="async (decimal? v) => { _maxUsability = v; await ReloadActiveTabAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex align-end justify-end">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_summary.Count == 0)" OnClick="ExportSummaryAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_summary.Count > 0)
            {
                var sumEom    = FilteredSummary.Sum(r => r.EOM ?? 0m);
                var sumSoh    = FilteredSummary.Sum(r => (long)r.SOH);
                var sumMnw    = FilteredSummary.Sum(r => (long)(r.MerchNeedWeek ?? 0));
                var sumSimQty = FilteredSummary.Sum(r => r.LpmSimQty);
                var sumRrQty  = FilteredSummary.Sum(r => r.RoundRobinQty);
                var sumOvr    = FilteredSummary.Sum(r => r.OverrideQty);

                <MudTable T="EomSummaryRow" Items="FilteredSummary" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false"
                          Class="lpm-eom-preview">
                    <HeaderContent>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.StoreID" InitialDirection="SortDirection.Ascending">Store</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:right;"><div class="th-total">&nbsp;</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.PriorityRank ?? decimal.MaxValue">Rank</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumEom.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.EOM ?? 0m">EOM</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumSoh.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Σ Merch Need (Week) = SIM cap (replaced legacy EOM Balance).">@sumMnw.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.MerchNeedWeek ?? 0">Merch Need<br />(Week)</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumSimQty.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.LpmSimQty">LPM SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumRrQty.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.RoundRobinQty">RR Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Subset of SIM Qty produced by P1b/P2b OVERRIDE round-robin (above SKU Max / Merch Need caps).">@sumOvr.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.OverrideQty">Override<br />Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>Use %</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            @* StoreID prefix means a row still identifies a store
                               even when DataSettings.PBFullname is null/empty
                               (which is what produced the "blank store" rows in
                               the Summary view). Same pattern as Item Details. *@
                            <code>@context.StoreID</code>@if (!string.IsNullOrEmpty(context.StoreName)) { <text> </text><MudText Typo="Typo.caption" Color="Color.Secondary" Inline="true">@context.StoreName</MudText> }
                        </MudTd>
                        <MudTd Style="text-align:right;">@(context.PriorityRank?.ToString("0.##") ?? "—")</MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd>@(context.EOM?.ToString("N0"))</MudTd>
                        <MudTd>@context.SOH.ToString("N0")</MudTd>
                        <MudTd>@(context.MerchNeedWeek?.ToString("N0") ?? "—")</MudTd>
                        <MudTd>@context.LpmSimQty.ToString("N0")</MudTd>
                        <MudTd>@(context.RoundRobinQty > 0 ? context.RoundRobinQty.ToString("N0") : "—")</MudTd>
                        <MudTd style="@(context.OverrideQty > 0 ? "color:#d97706;font-weight:600;" : "")">@(context.OverrideQty > 0 ? context.OverrideQty.ToString("N0") : "—")</MudTd>
                        <MudTd>@(SummaryUsability(context)?.ToString("0.0") ?? "—")%</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_loadingSummary)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No summary rows. The batch may have produced 0 allocations.
                </MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="Store Summary" Icon="@Icons.Material.Filled.Store">
            @if (_loadingStoreSummary)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Label="Store (contains)" @bind-Value="_storeSummaryFilter"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Clearable Immediate="true" DebounceInterval="300" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Min Box Usability %"
                                     Value="_minUsability"
                                     ValueChanged="async (decimal? v) => { _minUsability = v; await ReloadStoreSummaryAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Min="0m" Max="100m" Step="5m" Clearable
                                     HelperText="e.g. 50 to count only boxes ≥50% used" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Max Box Usability %"
                                     Value="_maxUsability"
                                     ValueChanged="async (decimal? v) => { _maxUsability = v; await ReloadStoreSummaryAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="12" md="5" Class="d-flex align-end justify-end gap-2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.FilterAltOff"
                               Disabled="@(_minUsability is null && _maxUsability is null && string.IsNullOrEmpty(_storeSummaryFilter))"
                               OnClick="ClearStoreSummaryFilters">
                        Clear filters
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_storeSummary.Count == 0)" OnClick="ExportStoreSummaryAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_storeSummary.Count > 0)
            {
                var ssRows  = FilteredStoreSummary.ToList();
                var sumEom  = ssRows.Sum(r => r.EOM);
                var sumSoh  = ssRows.Sum(r => r.SOH);
                var sumMnw  = ssRows.Sum(r => r.MerchNeedWeek);
                var sumSim  = ssRows.Sum(r => r.SimQty);
                var sumRr   = ssRows.Sum(r => r.RrQty);
                var sumOvr  = ssRows.Sum(r => r.OverrideQty);

                <MudTable T="StoreSummaryRow" Items="ssRows" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false"
                          Class="lpm-eom-preview">
                    <HeaderContent>
                        <MudTh><div class="th-total">@ssRows.Count.ToString("N0") rows</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.StoreID" InitialDirection="SortDirection.Ascending">Store ID</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.StoreName">Store Name</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumEom.ToString("N0")</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.EOM">EOM</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumSoh.ToString("N0")</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Σ Merch Need (Week) for this store = SIM cap.">@sumMnw.ToString("N0")</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.MerchNeedWeek">Merch Need<br />(Week)</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumSim.ToString("N0")</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.SimQty">SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@sumRr.ToString("N0")</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.RrQty">RR Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Subset of SIM Qty above SKU Max / Merch Need caps (P1b/P2b override).">@sumOvr.ToString("N0")</div><MudTableSortLabel T="StoreSummaryRow" SortBy="r => r.OverrideQty">Override<br />Qty</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.StoreID</code></MudTd>
                        <MudTd>@context.StoreName</MudTd>
                        <MudTd>@context.EOM.ToString("N0")</MudTd>
                        <MudTd>@context.SOH.ToString("N0")</MudTd>
                        <MudTd>@context.MerchNeedWeek.ToString("N0")</MudTd>
                        <MudTd>@context.SimQty.ToString("N0")</MudTd>
                        <MudTd>@(context.RrQty > 0 ? context.RrQty.ToString("N0") : "—")</MudTd>
                        <MudTd style="@(context.OverrideQty > 0 ? "color:#d97706;font-weight:600;" : "")">@(context.OverrideQty > 0 ? context.OverrideQty.ToString("N0") : "—")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
                <MudText Typo="Typo.caption" Class="mt-2" Style="color:#64748b;">
                    <strong>Merch Need (Week)</strong> = weekly open-to-receive that drives the SIM cap.
                    <strong>SIM Qty</strong> = total allocated to this store this run; <strong>RR Qty</strong> = subset from round-robin.
                    <strong>Override Qty</strong> = qty allocated above SKU Max / Merch Need caps (P1b/P2b override mode).
                </MudText>
            }
            else if (!_loadingStoreSummary)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No store rows for this batch.</MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="Division Summary" Icon="@Icons.Material.Filled.Category">
            @if (_loadingDivisionSummary)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" md="3">
                    @* 1.14.14: MudSelect → MultiSelectFilter so long
                       division lists are searchable (type-ahead). Empty =
                       "All". Items list built from the rows currently
                       loaded for this batch. *@
                    <MultiSelectFilter Label="Divisions"
                                       Items="@(_divisionSummary
                                                    .Select(r => r.DivisionName ?? string.Empty)
                                                    .Where(n => !string.IsNullOrWhiteSpace(n))
                                                    .Distinct(StringComparer.OrdinalIgnoreCase)
                                                    .OrderBy(n => n, StringComparer.OrdinalIgnoreCase)
                                                    .ToList())"
                                       Selected="_divisionSummaryFilter"
                                       SelectedChanged="@((HashSet<string> s) => { _divisionSummaryFilter = s; StateHasChanged(); })" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Min Box Usability %"
                                     Value="_minUsability"
                                     ValueChanged="async (decimal? v) => { _minUsability = v; await ReloadDivisionSummaryAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Min="0m" Max="100m" Step="5m" Clearable
                                     HelperText="e.g. 50 to count only boxes ≥50% used" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Max Box Usability %"
                                     Value="_maxUsability"
                                     ValueChanged="async (decimal? v) => { _maxUsability = v; await ReloadDivisionSummaryAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="12" md="5" Class="d-flex align-end justify-end gap-2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.FilterAltOff"
                               Disabled="@(_minUsability is null && _maxUsability is null && _divisionSummaryFilter.Count == 0)"
                               OnClick="ClearDivisionSummaryFilters">
                        Clear filters
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_divisionSummary.Count == 0)" OnClick="ExportDivisionSummaryAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_divisionSummary.Count > 0)
            {
                var dsRows  = FilteredDivisionSummary.ToList();
                var dsumEom = dsRows.Sum(r => r.EOM);
                var dsumSoh = dsRows.Sum(r => r.SOH);
                var dsumMnw = dsRows.Sum(r => r.MerchNeedWeek);
                // 1.14.33: source Box Qty (whboxitems.Qty) for the qualifying
                // boxes, same Min/Max Box Usability % filter as SIM Qty so the
                // two columns line up.
                var dsumBox = dsRows.Sum(r => r.BoxQty);
                var dsumSim = dsRows.Sum(r => r.SimQty);
                var dsumRr  = dsRows.Sum(r => r.RrQty);
                var dsumOvr = dsRows.Sum(r => r.OverrideQty);

                // Footer totals derived from the totals already computed above.
                // Division-wide Fill Rate uses Σ SOH / Σ EOM (true weighted
                // total, not avg of avgs). EOM Balance is just Σ EOM − Σ SOH.
                // Merch Need (Day) total = Σ MerchNeedWeek / 6.
                decimal totalEomBalance = dsumEom - dsumSoh;
                decimal? totalFillRate  = dsumEom > 0m
                    ? Math.Round((decimal)dsumSoh * 100m / dsumEom, 1)
                    : (decimal?)null;
                long totalMerchDay      = (long)Math.Round((decimal)dsumMnw / 6m, MidpointRounding.AwayFromZero);
                <MudTable T="DivisionSummaryRow" Items="dsRows" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false"
                          Class="lpm-eom-preview">
                    <HeaderContent>
                        <MudTh><div class="th-total">@dsRows.Count.ToString("N0") rows</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.DivCode" InitialDirection="SortDirection.Ascending">Div Code</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@dsumEom.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.EOM">EOM</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@dsumSoh.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Σ EOM − Σ SOH. Positive = headroom; negative = overstocked vs plan.">@totalEomBalance.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.EomBalance"><span title="EOM Balance = EOM − SOH">EOM<br />Balance</span></MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Total SOH ÷ Total EOM × 100 across all rows in view.">@(totalFillRate?.ToString("0.0") ?? "—")%</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.CurrentFillRate ?? -1m"><span title="Current Fill Rate % = SOH ÷ EOM × 100">Current<br />Fill Rate %</span></MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Σ Merch Need (Week) for this division = SIM cap.">@dsumMnw.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.MerchNeedWeek">Merch Need<br />(Week)</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Σ Merch Need (Week) ÷ 6 (fixed 6-day production week).">@totalMerchDay.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.MerchNeedDay"><span title="Merch Need (Day) = Merch Need (Week) ÷ 6">Merch Need<br />(Day)</span></MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Σ full warehouse Box Qty from racks.dbo.whboxitems for items in this division. Matches the Summary tab's Box Qty semantics — includes 'phantom' items in contributing boxes that got 0 allocation (capped, filtered, or not picked).">@dsumBox.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.BoxQty"><span title="Full warehouse Box Qty (whboxitems.Qty) summed across every item in every qualifying box for this division — matches Summary tab semantics">Box Qty</span></MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@dsumSim.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.SimQty">SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@dsumRr.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.RrQty">RR Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" title="Subset of SIM Qty above SKU Max / Merch Need caps (P1b/P2b override).">@dsumOvr.ToString("N0")</div><MudTableSortLabel T="DivisionSummaryRow" SortBy="r => r.OverrideQty">Override<br />Qty</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.DivCode</code></MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd>@context.EOM.ToString("N0")</MudTd>
                        <MudTd>@context.SOH.ToString("N0")</MudTd>
                        <MudTd style="@(context.EomBalance < 0m ? "color:#dc2626;" : "")">@context.EomBalance.ToString("N0")</MudTd>
                        <MudTd>@(context.CurrentFillRate?.ToString("0.0") ?? "—")%</MudTd>
                        <MudTd>@context.MerchNeedWeek.ToString("N0")</MudTd>
                        <MudTd>@context.MerchNeedDay.ToString("N0")</MudTd>
                        <MudTd>@context.BoxQty.ToString("N0")</MudTd>
                        <MudTd>@context.SimQty.ToString("N0")</MudTd>
                        <MudTd>@(context.RrQty > 0 ? context.RrQty.ToString("N0") : "—")</MudTd>
                        <MudTd style="@(context.OverrideQty > 0 ? "color:#d97706;font-weight:600;" : "")">@(context.OverrideQty > 0 ? context.OverrideQty.ToString("N0") : "—")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 200 }" />
                    </PagerContent>
                </MudTable>
                <MudText Typo="Typo.caption" Class="mt-2" Style="color:#64748b;">
                    Aggregated across all stores. <strong>Merch Need (Week)</strong> drives the SIM cap.
                    <strong>Override Qty</strong> = qty allocated above SKU Max / Merch Need caps (P1b/P2b override mode).
                </MudText>
            }
            else if (!_loadingDivisionSummary)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No division rows for this batch.</MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="SIM Boxes" Icon="@Icons.Material.Filled.Inventory2">
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" md="2">
                    <MudTextField T="string" Label="Box No (contains)" @bind-Value="_boxNoFilter"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Clearable Immediate="true" DebounceInterval="300" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudSelect T="string" Label="Kind" @bind-Value="_boxKindFilter"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                        <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                        <MudSelectItem T="string" Value="@("LPM")">LPM</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Non-LPM")">Non-LPM</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudSelect T="string" Label="Warehouse" @bind-Value="_boxWarehouseFilter"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                        <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                        @foreach (var w in BoxWarehouseOptions)
                        {
                            <MudSelectItem T="string" Value="@w">@w</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Min Use %"
                                     Value="_minUsability"
                                     ValueChanged="async (decimal? v) => { _minUsability = v; await ReloadActiveTabAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Max Use %"
                                     Value="_maxUsability"
                                     ValueChanged="async (decimal? v) => { _maxUsability = v; await ReloadActiveTabAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex align-end gap-2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.FilterAltOff"
                               OnClick="ClearBoxFilters">
                        Clear filters
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_boxRows.Count == 0)" OnClick="ExportBoxesAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_loadingBoxes)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            @if (_boxRows.Count > 0)
            {
                var filteredBoxes = FilteredBoxes.ToList();
                var totalBoxQty  = filteredBoxes.Sum(r => r.BoxQty ?? 0);
                var totalSimQty  = filteredBoxes.Sum(r => r.LpmSimQty);
                var totalRrQty   = filteredBoxes.Sum(r => r.RoundRobinQty);
                var avgUsability = totalBoxQty > 0 ? Math.Round((decimal)totalSimQty * 100m / totalBoxQty, 1) : 0m;

                <MudTable T="BoxDetailRow" Items="filteredBoxes" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false">
                    <HeaderContent>
                        <MudTh><div class="th-total">@filteredBoxes.Count.ToString("N0") rows</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.BoxNo">Box No</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.PalletNo ?? string.Empty">Pallet No</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.BoxKind ?? string.Empty">Kind</MudTableSortLabel></MudTh>
                        @* 1.14.65 — Division column added after Kind (top-1 mapping per box). *@
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.DivisionName ?? string.Empty">Division</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>Pallet Type</MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>Type Name</MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.TrnDate ?? DateTime.MinValue">Trn Date</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.Warehouse ?? string.Empty">Warehouse</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.Rack ?? string.Empty">Rack</MudTableSortLabel></MudTh>
                        @* 1.14.65 — Tote ID column after Rack (physical-location group). *@
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.ToteId ?? string.Empty">Tote ID</MudTableSortLabel></MudTh>
                        @* 1.14.70 — Pallet-purchase / GIN columns from whboxitems. Same data group
                           as Tote ID (per-pallet meta) so kept adjacent. *@
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.PurDate ?? DateTime.MinValue">Purchase Dt</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.GINNo ?? string.Empty">GIN No</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.GinDate ?? DateTime.MinValue">GIN Date</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.FromTo ?? string.Empty">From/To</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalBoxQty.ToString("N0")</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.BoxQty ?? 0">Total Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalSimQty.ToString("N0")</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.LpmSimQty">SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalRrQty.ToString("N0")</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.RoundRobinQty">RR Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@avgUsability.ToString("0.0")%</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.SkuUsabilityPct ?? 0m">Usability %</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.BoxNo</code></MudTd>
                        <MudTd><code>@context.PalletNo</code></MudTd>
                        <MudTd>
                            @if (context.BoxKind == "LPM")
                            {
                                <span class="lpm-status lpm-status-ok">LPM</span>
                            }
                            else if (context.BoxKind == "Non-LPM")
                            {
                                <span class="lpm-status lpm-status-warn">Non-LPM</span>
                            }
                        </MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd>@context.PalletType</MudTd>
                        <MudTd>@context.TypeName</MudTd>
                        <MudTd>@(context.TrnDate?.ToString("yyyy-MM-dd"))</MudTd>
                        <MudTd>@context.Warehouse</MudTd>
                        <MudTd>@context.Rack</MudTd>
                        <MudTd><code>@context.ToteId</code></MudTd>
                        @* 1.14.70 — Pallet-purchase / GIN cells. Empty when NULL. *@
                        <MudTd>@(context.PurDate?.ToString("yyyy-MM-dd") ?? string.Empty)</MudTd>
                        <MudTd>@(context.GINNo ?? string.Empty)</MudTd>
                        <MudTd>@(context.GinDate?.ToString("yyyy-MM-dd") ?? string.Empty)</MudTd>
                        <MudTd>@(context.FromTo ?? string.Empty)</MudTd>
                        <MudTd>@(context.BoxQty?.ToString("N0"))</MudTd>
                        <MudTd>@context.LpmSimQty.ToString("N0")</MudTd>
                        <MudTd>@(context.RoundRobinQty > 0 ? context.RoundRobinQty.ToString("N0") : "—")</MudTd>
                        <MudTd>@(context.SkuUsabilityPct?.ToString("0.0") ?? "—")%</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_loadingBoxes)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No box rows for this batch.</MudAlert>
            }
        </MudTabPanel>

        @* ─────────────────────────────────────────────────────────────────
           1.14.26 — Allocation Gap tab. One row per eligible box where
           RemainingQty > 0. Driven by dbo.LPMSIM_UnallocatedDiagnostic,
           populated at the end of every SIM Generate run from 1.14.26 on.
           Forward-fill only — pre-1.14.26 batches show "No diagnostic data".
           ───────────────────────────────────────────────────────────── *@
        <MudTabPanel Text="Allocation Gap" Icon="@Icons.Material.Filled.ReportProblem" OnClick="LoadGapAsync">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Why each eligible box wasn't fully allocated</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-3">
                Per-box diagnostic for boxes where <code>RemainingQty &gt; 0</code>. Hover the <strong>Top Reason</strong>
                chip for the plain-language explanation. For boxes attributed to <code>CAP</code> (SKU Max or EOM Merch
                Need), enable <strong>Verbose Trace</strong> on the run and look at the existing Allocation Trace tab to
                see the SKU vs Target split per (Store, Item).
            </MudText>

            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" md="2">
                    <MudTextField T="string" Label="Box No (contains)" @bind-Value="_gapBoxNoFilter"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Clearable Immediate="true" DebounceInterval="300" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudSelect T="string" Label="Kind" @bind-Value="_gapKindFilter"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                        <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                        <MudSelectItem T="string" Value="@("LPM")">LPM</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Non-LPM")">Non-LPM</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudSelect T="string" Label="Top Reason" @bind-Value="_gapReasonFilter"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                        <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                        <MudSelectItem T="string" Value="@("FILTERED_SEASON")">FILTERED_SEASON</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SKIP_NO_DIV")">SKIP_NO_DIV</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SKIP_NO_EOM")">SKIP_NO_EOM</MudSelectItem>
                        @* 1.14.28 — distinguish explicit Rule 1-7 exclusions from generic cap saturation. *@
                        <MudSelectItem T="string" Value="@("EXCLUDED_BY_RULE")">EXCLUDED_BY_RULE (SKUMax=0)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("CAP")">CAP (SKU Max / Merch Need)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("UNKNOWN")">UNKNOWN</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="long?" Label="Min Remaining"
                                     Value="_gapMinRemaining"
                                     ValueChanged="(long? v) => { _gapMinRemaining = v; StateHasChanged(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Step="10" Clearable />
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex align-end gap-2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Disabled="_loadingGap" OnClick="LoadGapAsync">
                        Load
                    </MudButton>
                    <MudButton Variant="Variant.Text" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.FilterAltOff"
                               OnClick="ClearGapFilters">
                        Clear filters
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Success" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_gapRows.Count == 0)" OnClick="ExportGapAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_loadingGap)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            @if (_gapRows.Count > 0)
            {
                var gapTotalBoxQty    = _gapRows.Sum(r => r.BoxQty);
                var gapTotalSimQty    = _gapRows.Sum(r => r.SimQty);
                var gapTotalRemaining = _gapRows.Sum(r => r.RemainingQty);

                <MudTable T="UnallocatedDiagnosticRow" Items="_gapRows" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false">
                    <HeaderContent>
                        <MudTh><div class="th-total">@_gapRows.Count.ToString("N0") boxes</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" SortBy="r => r.BoxNo">Box No</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" SortBy="r => r.PalletNo ?? string.Empty">Pallet No</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" SortBy="r => r.BoxKind">Kind</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@gapTotalBoxQty.ToString("N0")</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" SortBy="r => r.BoxQty">Box Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@gapTotalSimQty.ToString("N0")</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" SortBy="r => r.SimQty">SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total" style="background:#fef9c3;">@gapTotalRemaining.ToString("N0")</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" InitialDirection="SortDirection.Descending"
                                               SortBy="r => r.RemainingQty">Remaining Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>
                            <MudTableSortLabel T="UnallocatedDiagnosticRow" SortBy="r => r.TopReason">Top Reason</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>Reasons</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.BoxNo</code></MudTd>
                        <MudTd><code>@context.PalletNo</code></MudTd>
                        <MudTd>
                            @if (context.BoxKind == "LPM")
                            {
                                <span class="lpm-status lpm-status-ok">LPM</span>
                            }
                            else
                            {
                                <span class="lpm-status lpm-status-warn">Non-LPM</span>
                            }
                        </MudTd>
                        <MudTd Style="text-align:right;">@context.BoxQty.ToString("N0")</MudTd>
                        <MudTd Style="text-align:right;">@context.SimQty.ToString("N0")</MudTd>
                        <MudTd Style="text-align:right;font-weight:600;background:#fffbeb;">@context.RemainingQty.ToString("N0")</MudTd>
                        <MudTd>
                            <MudTooltip Text="@GapReasonTooltip(context.TopReason)" Placement="Placement.Left">
                                @{
                                    var (chipColor, chipLabel) = GapReasonChip(context.TopReason);
                                }
                                <MudChip T="string" Size="Size.Small" Color="@chipColor">@chipLabel</MudChip>
                            </MudTooltip>
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.caption" Style="font-family:monospace;font-size:0.75rem;color:#475569;">
                                @context.Reasons
                            </MudText>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (_gapLoadedOnce && !_loadingGap)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No allocation gap rows for this batch. Either every eligible box was fully allocated, OR the batch
                    was generated before 1.14.26 (diagnostic only fills forward; re-Generate to populate).
                </MudAlert>
            }
            else if (!_gapLoadedOnce)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Click <strong>Load</strong> to fetch the per-box allocation gap diagnostic for batch #@_readiness?.CurrentBatchNo.
                </MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="Item Details" Icon="@Icons.Material.Filled.ListAlt">
            @if (_loadingItems)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Min Box Usability %"
                                     Value="_minUsability"
                                     ValueChanged="async (decimal? v) => { _minUsability = v; await ReloadActiveTabAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal?" Label="Max Box Usability %"
                                     Value="_maxUsability"
                                     ValueChanged="async (decimal? v) => { _maxUsability = v; await ReloadActiveTabAsync(); }"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Max="100m" Step="5m" Clearable />
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex align-end">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_itemRows.Count == 0)" OnClick="ExportItemsAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_itemRows.Count > 0)
            {
                var filteredItems  = FilteredItems.ToList();
                // Qty column shows BoxItemQty (warehouse stock for the
                // (Box, Item) pair). Each Item Details row is keyed by
                // (Box, Item, Store), so the SAME BoxItemQty repeats across
                // every store that received an allocation from that
                // (Box, Item). Summing across rows would inflate the total
                // by the number of receiving stores per (Box, Item).
                // De-duplicate by (BoxNo, Itemcode) so the column total
                // reflects the true warehouse stock that backed this batch
                // (which for an LPM-only run is the total LPM-box stock).
                var totalItemQty   = filteredItems
                                        .GroupBy(r => (r.BoxNo, r.Itemcode))
                                        .Sum(g => g.First().BoxItemQty ?? 0);
                // SKU Max and SOH are per-(Store, Item) values that repeat
                // across every Box-row for the same (Store, Item) pair, so
                // they're de-duplicated the same way as Qty. LPM Qty and
                // RR Qty are genuine per-row allocation amounts (one number
                // per (Box, Item, Store) ship), so they sum directly.
                var totalSkuMax    = filteredItems
                                        .GroupBy(r => (r.StoreID, r.Itemcode))
                                        .Sum(g => (long)(g.First().SKUMax ?? 0));
                var totalSohItem   = filteredItems
                                        .GroupBy(r => (r.StoreID, r.Itemcode))
                                        .Sum(g => (long)g.First().SOH);
                var totalLpmQty    = filteredItems.Sum(r => (long)r.LpmQty);
                var totalRrItem    = filteredItems.Sum(r => (long)r.RoundRobinQty);

                <MudTable T="ItemDetailRow" Items="filteredItems" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false">
                    <HeaderContent>
                        <MudTh><div class="th-total">@filteredItems.Count.ToString("N0") rows</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.StoreID">Store</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:right;"><div class="th-total">&nbsp;</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.PriorityRank ?? decimal.MaxValue">Rank</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.Itemcode">Item</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.PalletNo ?? string.Empty">Pallet No</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalItemQty.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.BoxItemQty ?? 0">BoxQty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.BoxKind">LPM</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalSkuMax.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.SKUMax ?? 0">SKU Max</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalSohItem.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalLpmQty.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.LpmQty">SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalRrItem.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.RoundRobinQty">RR Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.Phase ?? string.Empty">Phase</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">&nbsp;</div>Use %</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <code>@context.StoreID</code><br />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.StoreName</MudText>
                        </MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd Style="text-align:right;">@(context.PriorityRank?.ToString("0.##") ?? "—")</MudTd>
                        <MudTd><code>@context.Itemcode</code></MudTd>
                        <MudTd><code>@context.PalletNo</code></MudTd>
                        <MudTd>@(context.BoxItemQty?.ToString("N0"))</MudTd>
                        <MudTd>
                            @if (context.BoxKind == "LPM")
                            {
                                <span class="lpm-status lpm-accent-blue">LPM</span>
                            }
                            else
                            {
                                <span class="lpm-status lpm-accent-amber">Non-LPM</span>
                            }
                        </MudTd>
                        <MudTd>@(context.SKUMax?.ToString("N0"))</MudTd>
                        <MudTd>@context.SOH.ToString("N0")</MudTd>
                        <MudTd>@context.LpmQty.ToString("N0")</MudTd>
                        <MudTd>@(context.RoundRobinQty > 0 ? context.RoundRobinQty.ToString("N0") : "—")</MudTd>
                        <MudTd><span class="lpm-status @PhaseClass(context.Phase)">@(context.Phase ?? "—")</span></MudTd>
                        <MudTd>@(ItemUsability(context)?.ToString("0.0") ?? "—")%</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_loadingItems)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No item rows for this batch.</MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="Custom Report" Icon="@Icons.Material.Filled.Tune">
            @* The planner picks Group By + Columns, then clicks Run.
               Field names come from a server-side whitelist (CustomReportField
               enum) so the dynamic SQL stays injection-safe by construction.
               Empty Columns = nothing to show. Dimensions in Columns are
               auto-included in Group By by the SQL builder, so the planner
               doesn't have to remember to tick them in both places. *@
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" md="5">
                    <MudSelect T="CustomReportField" Label="Group By"
                               SelectedValues="_customGroupBy"
                               SelectedValuesChanged="@((IEnumerable<CustomReportField> v) => _customGroupBy = v?.ToList() ?? new())"
                               MultiSelection="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Placeholder="(none — single aggregate row)"
                               MultiSelectionTextFunc="@(new Func<List<string>, string>(SelectedFieldsText))">
                        @foreach (var f in CustomReportDimensionFields)
                        {
                            <MudSelectItem T="CustomReportField" Value="@f">@CustomReportFieldLabel(f)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudSelect T="CustomReportField" Label="Columns"
                               SelectedValues="_customColumns"
                               SelectedValuesChanged="@((IEnumerable<CustomReportField> v) => _customColumns = v?.ToList() ?? new())"
                               MultiSelection="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Placeholder="Pick fields to display"
                               MultiSelectionTextFunc="@(new Func<List<string>, string>(SelectedFieldsText))">
                        @foreach (var f in CustomReportAllFields)
                        {
                            <MudSelectItem T="CustomReportField" Value="@f">@CustomReportFieldLabel(f)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex align-end gap-1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Disabled="@(_loadingCustom || _customColumns.Count == 0 || _readiness?.CurrentBatchNo is null)"
                               OnClick="RunCustomReportAsync">
                        Run
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_customResult is null || _customResult.Rows.Count == 0)"
                               OnClick="ExportCustomReportAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_loadingCustom)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            @if (_customResult is { Columns.Count: > 0 } cr && cr.Rows.Count > 0)
            {
                <MudText Typo="Typo.caption" Style="color:#475569;margin-bottom:.4rem;">
                    @cr.Rows.Count.ToString("N0") rows
                </MudText>
                <MudTable T="Dictionary<string, object?>" Items="cr.Rows" Hover Striped Dense
                          FixedHeader Height="55vh">
                    <HeaderContent>
                        @foreach (var col in cr.Columns)
                        {
                            <MudTh Style="@(col.IsNumeric ? "text-align:right;" : "")">@col.DisplayName</MudTh>
                        }
                    </HeaderContent>
                    <RowTemplate>
                        @foreach (var col in cr.Columns)
                        {
                            <MudTd Style="@(col.IsNumeric ? "text-align:right;" : "")">@FormatCustomCell(context, col)</MudTd>
                        }
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (_customResult is { Rows.Count: 0 } && !_loadingCustom)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No rows for this combination of Group By and Columns. Try a different selection or confirm the batch has data.
                </MudAlert>
            }
            else if (!_loadingCustom)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Pick Group By + Columns and click <strong>Run</strong>. Numeric columns are summed at the chosen grain. Field list is a whitelist — no raw SQL exposed.
                </MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="Allocation Trace" Icon="@Icons.Material.Filled.FactCheck">
            @if (_traceCounts is AllocTraceCounts tc)
            {
                <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                    Decision counts (per Box × Item × Store attempt)
                </MudText>
                <MudGrid Spacing="2" Class="mb-2 mt-1">
                    <MudItem xs="6" md="2"><div class="lpm-metric-card-sm lpm-accent-green">
                        <div class="lpm-metric-label">ALLOC</div>
                        <div class="lpm-metric-value-sm">@tc.Alloc.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="2"><div class="lpm-metric-card-sm lpm-accent-green">
                        <div class="lpm-metric-label">ALLOC_RR</div>
                        <div class="lpm-metric-value-sm">@tc.AllocRr.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="2"><div class="lpm-metric-card-sm lpm-accent-rose">
                        <div class="lpm-metric-label">SKIP_SKUMAX</div>
                        <div class="lpm-metric-value-sm">@tc.SkipSkuMax.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="2"><div class="lpm-metric-card-sm lpm-accent-amber">
                        <div class="lpm-metric-label">SKIP_TARGET</div>
                        <div class="lpm-metric-value-sm">@tc.SkipTarget.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="2"><div class="lpm-metric-card-sm lpm-accent-purple">
                        <div class="lpm-metric-label">SKIP_NO_DIV</div>
                        <div class="lpm-metric-value-sm">@tc.SkipNoDiv.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="2"><div class="lpm-metric-card-sm lpm-accent-cyan">
                        <div class="lpm-metric-label">SKIP_NO_EOM</div>
                        <div class="lpm-metric-value-sm">@tc.SkipNoEom.ToString("N0")</div>
                    </div></MudItem>
                </MudGrid>

                long inputBoxQty    = _readiness?.EligibleQty ?? 0;
                long allocatedQty   = tc.TotalAllocatedQty;
                long discardedQty   = tc.TotalDiscardedQty;
                long unaccountedQty = inputBoxQty - allocatedQty - discardedQty;
                <MudText Typo="Typo.caption" Class="mt-3" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                    Qty reconciliation (allocated + discarded + unaccounted = input box qty)
                </MudText>
                <MudGrid Spacing="2" Class="mb-3 mt-1">
                    <MudItem xs="6" md="3"><div class="lpm-metric-card-sm lpm-accent-blue">
                        <div class="lpm-metric-label">Input Box Qty (selection)</div>
                        <div class="lpm-metric-value-sm">@inputBoxQty.ToString("N0")</div>
                        <div class="lpm-metric-sub">eligible boxes for current filter</div>
                    </div></MudItem>
                    <MudItem xs="6" md="3"><div class="lpm-metric-card-sm lpm-accent-green">
                        <div class="lpm-metric-label">Allocated Qty</div>
                        <div class="lpm-metric-value-sm">@allocatedQty.ToString("N0")</div>
                        <div class="lpm-metric-sub">ALLOC @tc.AllocQty.ToString("N0") + RR @tc.AllocRrQty.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="3"><div class="lpm-metric-card-sm lpm-accent-purple">
                        <div class="lpm-metric-label">Discarded Qty (Unmappable)</div>
                        <div class="lpm-metric-value-sm">@discardedQty.ToString("N0")</div>
                        <div class="lpm-metric-sub">no-div @tc.DiscardedNoDivQty.ToString("N0") + no-eom @tc.DiscardedNoEomQty.ToString("N0")</div>
                    </div></MudItem>
                    <MudItem xs="6" md="3"><div class="lpm-metric-card-sm @(unaccountedQty == 0 ? "lpm-accent-green" : "lpm-accent-amber")">
                        <div class="lpm-metric-label">Unaccounted</div>
                        <div class="lpm-metric-value-sm">@unaccountedQty.ToString("N0")</div>
                        <div class="lpm-metric-sub">should be 0 if filter matches batch</div>
                    </div></MudItem>
                </MudGrid>
            }

            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="6" md="2">
                    <MudTextField T="string" Label="Box No" @bind-Value="_traceBoxFilter"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Clearable />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudTextField T="string" Label="Item Code" @bind-Value="_traceItemFilter"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Clearable />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudAutocomplete T="string" Label="Store ID" Value="_traceStoreFilter"
                                     ValueChanged="v => _traceStoreFilter = v ?? string.Empty"
                                     SearchFunc="@((s, c) => SearchAllStoreIDs(s))"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     CoerceText="true" ResetValueOnEmptyText="true" Clearable Placeholder="All stores" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudSelect T="string" Label="Decision" Value="_traceDecisionFilter"
                               ValueChanged="v => _traceDecisionFilter = v ?? string.Empty"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                        <MudSelectItem T="string" Value="@string.Empty">(All)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("ALLOC")">ALLOC</MudSelectItem>
                        <MudSelectItem T="string" Value="@("ALLOC_RR")">ALLOC_RR</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SKIP_SKUMAX")">SKIP_SKUMAX</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SKIP_TARGET")">SKIP_TARGET</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SKIP_NO_DIV")">SKIP_NO_DIV</MudSelectItem>
                        <MudSelectItem T="string" Value="@("SKIP_NO_EOM")">SKIP_NO_EOM</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-end gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Search"
                               Disabled="@_loadingTrace" OnClick="LoadTraceAsync">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_loadingTrace || _readiness?.CurrentBatchNo is null)" OnClick="ExportTraceAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_loadingTrace)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            @if (_traceRows.Count > 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                    Showing @_traceRows.Count.ToString("N0") rows (capped at @_traceTop.ToString("N0")).
                    Use the Excel button to download the full filtered set.
                </MudAlert>

                <MudTable T="AllocTraceRow" Items="_traceRows" Hover Striped Dense
                          FixedHeader Height="55vh" AllowUnsorted="false">
                    <HeaderContent>
                        <MudTh>Phase</MudTh>
                        <MudTh>Decision</MudTh>
                        <MudTh>Box</MudTh>
                        <MudTh>Item</MudTh>
                        <MudTh>Division</MudTh>
                        <MudTh>Store</MudTh>
                        <MudTh>SKUMax</MudTh>
                        <MudTh>SOH (Item)</MudTh>
                        <MudTh>SKU Bal</MudTh>
                        <MudTh>Target EOM</MudTh>
                        <MudTh>Div SOH</MudTh>
                        <MudTh>Already</MudTh>
                        <MudTh>Tgt Remain</MudTh>
                        <MudTh>Line Qty</MudTh>
                        <MudTh>Take</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><span class="lpm-status @PhaseClass(context.Phase)">@context.Phase</span></MudTd>
                        <MudTd>
                            <span class="lpm-status @TraceClass(context.Decision)">@context.Decision</span>
                        </MudTd>
                        <MudTd><code>@context.BoxNo</code></MudTd>
                        <MudTd><code>@context.ItemCode</code></MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd>
                            @if (!string.IsNullOrEmpty(context.StoreID))
                            {
                                <code>@context.StoreID</code><br />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.StoreName</MudText>
                            }
                        </MudTd>
                        <MudTd>@(context.SKUMax?.ToString("N0"))</MudTd>
                        <MudTd>@(context.SOH_Item?.ToString("N0"))</MudTd>
                        <MudTd>@(context.SkuBalance?.ToString("N0"))</MudTd>
                        <MudTd>@(context.TargetEOM?.ToString("N0"))</MudTd>
                        <MudTd>@(context.DivSOH?.ToString("N0"))</MudTd>
                        <MudTd>@(context.AlreadyAllocated?.ToString("N0"))</MudTd>
                        <MudTd>@(context.TargetRemain?.ToString("N0"))</MudTd>
                        <MudTd>@context.LineQty.ToString("N0")</MudTd>
                        <MudTd>@context.Take.ToString("N0")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_loadingTrace)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No trace rows. Click Apply to load — or this batch was generated before trace was added (regenerate to populate trace).
                </MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="SKU Max Detail" Icon="@Icons.Material.Filled.Rule">
            @* Per-(Store × Item × Season) SKU Max snapshot — built fresh each
               SIM Generate from LPM_SimItemSkuMax. The filter is mandatory:
               at least one of Division / Store / Item must be supplied to
               keep the result set sane (could be 1M+ rows otherwise). *@
            <MudText Typo="Typo.subtitle2" Class="mb-1">SKU Max per Item</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-3">
                Each row is one (Store × Item × Season) cap that SIM Generate honoured during allocation.
                <code>WHStock</code> is the eligible warehouse stock for that item / season; the
                <code>LPM_SKUMaxRule</code> band that brackets <code>WHStock</code> determines
                <code>SKUMax</code>. Filter by Division <strong>or</strong> Store <strong>or</strong> Item — at least one is required.
            </MudText>

            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" md="3">
                    <MudAutocomplete T="string" Label="Division"
                                     Value="_skuFilterDivisionText"
                                     ValueChanged="OnSkuMaxDivisionChanged"
                                     SearchFunc="SearchDivisionsForSkuMax"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     CoerceText="true" ResetValueOnEmptyText="true" Clearable
                                     Placeholder="(any)" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudAutocomplete T="string" Label="Store"
                                     Value="_skuFilterStoreText"
                                     ValueChanged="OnSkuMaxStoreChanged"
                                     SearchFunc="SearchStoresForSkuMax"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     CoerceText="true" ResetValueOnEmptyText="true" Clearable
                                     Placeholder="(any)" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField T="string" Label="Item code (contains)"
                                  Value="_skuFilterItem"
                                  ValueChanged="(string v) => { _skuFilterItem = v ?? string.Empty; }"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Clearable
                                  Placeholder="(any)" />
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-end gap-2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="LoadSkuMaxDetailAsync"
                               Disabled="@_loadingSkuMax">
                        Apply
                    </MudButton>
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_skuMaxRows.Count == 0)"
                               OnClick="ExportSkuMaxAsync">
                        Excel
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_loadingSkuMax)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            @if (_skuMaxFilterError is string err)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-2">@err</MudAlert>
            }
            else if (_skuMaxRows.Count == 0 && _skuMaxLoaded)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No rows matched. Either the batch wasn't generated yet, or the filter doesn't match anything in
                    <code>LPM_SimItemSkuMax</code>.
                </MudAlert>
            }
            else if (_skuMaxRows.Count > 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">
                    @_skuMaxRows.Count.ToString("N0") row(s) shown@( _skuMaxRows.Count >= 5000 ? " (capped at 5,000 — narrow the filter for the rest)" : "" )
                </MudText>
                <MudTable T="ItemSkuMaxRow" Items="_skuMaxRows" Hover Striped Dense
                          FixedHeader Height="60vh" AllowUnsorted="false">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel T="ItemSkuMaxRow" SortBy="r => r.StoreID" InitialDirection="SortDirection.Ascending">Store ID</MudTableSortLabel></MudTh>
                        <MudTh>Store Name</MudTh>
                        <MudTh><MudTableSortLabel T="ItemSkuMaxRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="ItemSkuMaxRow" SortBy="r => r.ItemCode">Item Code</MudTableSortLabel></MudTh>
                        <MudTh>Season</MudTh>
                        <MudTh class="text-right"><MudTableSortLabel T="ItemSkuMaxRow" SortBy="r => r.WHBoxQty">WH Stock</MudTableSortLabel></MudTh>
                        <MudTh>Vol Group</MudTh>
                        <MudTh class="text-right"><MudTableSortLabel T="ItemSkuMaxRow" SortBy="r => r.SKUMax">SKU Max</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><code>@context.StoreID</code></MudTd>
                        <MudTd>@context.StoreName</MudTd>
                        <MudTd>@context.DivisionName <span style="color:#94a3b8;">(@context.DivCode)</span></MudTd>
                        <MudTd><code>@context.ItemCode</code></MudTd>
                        <MudTd>
                            @if (context.Season == "W")
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Winter</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Summer</MudChip>
                            }
                        </MudTd>
                        <MudTd Class="text-right">@context.WHBoxQty.ToString("N0")</MudTd>
                        <MudTd>@(context.VolumeGroup ?? "")</MudTd>
                        <MudTd Class="text-right"><strong>@context.SKUMax.ToString("N0")</strong></MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 250, 500 }" />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Q&amp;A" Icon="@Icons.Material.Filled.QuestionAnswer">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Investigate this batch's results</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-3">
                Pick a question, fill the parameters, and click Ask. The answer is computed live from this batch's data
                (Output, AllocTrace, StoreItem/StoreDivBalance) — no LLM calls; everything stays on-prem.
            </MudText>

            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Question" Value="_qaQuestion"
                               ValueChanged="v => { _qaQuestion = v ?? string.Empty; _qaResult = null; StateHasChanged(); }"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("StoreDivGap")">Why did (Store, Division) get partial allocation?</MudSelectItem>
                        <MudSelectItem T="string" Value="@("BoxLow")">Why is this Box under-utilised?</MudSelectItem>
                        <MudSelectItem T="string" Value="@("StoreOverview")">What did this Store receive overall?</MudSelectItem>
                        <MudSelectItem T="string" Value="@("BatchBlockers")">What's blocking allocation in this batch?</MudSelectItem>
                    </MudSelect>
                </MudItem>

                @if (_qaQuestion is "StoreDivGap" or "StoreOverview")
                {
                    <MudItem xs="12" md="3">
                        <MudAutocomplete T="string" Label="Store"
                                         Value="_qaStoreInput"
                                         ValueChanged="v => _qaStoreInput = v ?? string.Empty"
                                         SearchFunc="@((s, c) => SearchAllStores(s))"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         CoerceText="true" Clearable />
                    </MudItem>
                }
                @if (_qaQuestion == "StoreDivGap")
                {
                    <MudItem xs="12" md="3">
                        <MudAutocomplete T="string" Label="Division"
                                         Value="_qaDivisionInput"
                                         ValueChanged="v => _qaDivisionInput = v ?? string.Empty"
                                         SearchFunc="@((s, c) => SearchAllDivisions(s))"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         CoerceText="true" Clearable />
                    </MudItem>
                }
                @if (_qaQuestion == "BoxLow")
                {
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Box No" @bind-Value="_qaBoxInput"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Clearable />
                    </MudItem>
                }
                <MudItem xs="12" md="2" Class="d-flex align-end gap-2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false"
                               StartIcon="@Icons.Material.Filled.Search"
                               Disabled="@(_qaBusy || string.IsNullOrEmpty(_qaQuestion))"
                               OnClick="AskInvestigationAsync">
                        Ask
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_qaBusy)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            }

            @if (_qaResult is InvestigationResult ir)
            {
                <div class="lpm-section mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                        Question
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-2">@ir.Question</MudText>

                    <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                        Answer
                    </MudText>
                    <MudText Typo="Typo.body1" Class="mb-3" Style="font-weight:600;color:#0f172a;">@ir.Headline</MudText>

                    @if (ir.Metrics.Count > 0)
                    {
                        <MudGrid Spacing="2" Class="mb-3">
                            @foreach (var m in ir.Metrics)
                            {
                                <MudItem xs="6" md="2">
                                    <div class="lpm-metric-card-sm @m.Accent">
                                        <div class="lpm-metric-label">@m.Label</div>
                                        <div class="lpm-metric-value-sm">@m.Value</div>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    }

                    @if (ir.Findings.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                            Findings
                        </MudText>
                        <ul style="font-size:0.88rem;color:#334155;padding-left:1.2rem;margin-bottom:1rem;">
                            @foreach (var f in ir.Findings)
                            {
                                <li class="mb-1">@f</li>
                            }
                        </ul>
                    }

                    @if (ir.Rows.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Style="font-weight:600;color:#475569;letter-spacing:.05em;text-transform:uppercase;">
                            Supporting data (@ir.Rows.Count rows)
                        </MudText>
                        <MudSimpleTable Dense Hover Bordered Class="mt-1" Style="font-size:0.82rem;">
                            <thead>
                                <tr>
                                    @foreach (var col in ir.Columns)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in ir.Rows)
                                {
                                    <tr>
                                        @foreach (var cell in row)
                                        {
                                            <td>@cell</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </div>
            }
            else if (!_qaBusy)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Pick a question and click <strong>Ask</strong>. Each answer is computed live from this batch's data —
                    no AI / LLM calls, everything stays inside your network.
                </MudAlert>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
