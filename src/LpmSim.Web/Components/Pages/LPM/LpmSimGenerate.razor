    private static void ApplyHeaders(IXLWorksheet sheet, string[] headers)
    {
        for (int i = 0; i < headers.Length; i++)
        {
            var cell = sheet.Cell(1, i + 1);
            cell.Value = headers[i];
            cell.Style.Font.Bold = true;
            cell.Style.Font.FontColor = XLColor.White;
            cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#0f172a");
            cell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
        }
        sheet.SheetView.FreezeRows(1);
    }

    private static void FormatNumeric(IXLWorksheet sheet, int dataRowCount, int[] cols)
    {
        if (dataRowCount <= 0) return;
        foreach (var c in cols)
            sheet.Range(2, c, dataRowCount + 1, c).Style.NumberFormat.Format = "#,##0";
    }

    private async Task SaveExcelAsync(string fileName, string sheetName, Action<IXLWorksheet> populate)
    {
        try
        {
            using var wb = new XLWorkbook();
            var sheet = wb.Worksheets.Add(sheetName);
            populate(sheet);
            sheet.Columns().AdjustToContents();
            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var url = $"data:application/octet-stream;base64,{b64}";
            await JS.InvokeVoidAsync("lpmDownload", url, fileName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Excel export failed: {ex.Message}", Severity.Error);
        }
    }

    // ── SKU Max Detail tab handlers ─────────────────────────────────────────
    private Task<IEnumerable<string>> SearchDivisionsForSkuMax(string? value, CancellationToken ct)
    {
        // Pull divisions for which any allocation exists in this batch, formatted "Womenswear (419)".
        var all = _summary
            .Select(r => $"{r.DivisionName}  ({r.DivCode})")
            .Distinct()
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(all.Take(50));
        return Task.FromResult<IEnumerable<string>>(all
            .Where(s => s.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(50));
    }

    private void OnSkuMaxDivisionChanged(string? v)
    {
        _skuFilterDivisionText = v ?? "";
        _skuFilterDiv = 0;
        if (!string.IsNullOrWhiteSpace(v))
        {
            var s = v.Trim();
            var open  = s.LastIndexOf('(');
            var close = s.LastIndexOf(')');
            if (open >= 0 && close > open && close == s.Length - 1
                && int.TryParse(s.Substring(open + 1, close - open - 1).Trim(), out var div))
            {
                _skuFilterDiv = div;
            }
        }
        StateHasChanged();
    }

    private Task<IEnumerable<string>> SearchStoresForSkuMax(string? value, CancellationToken ct)
    {
        var all = _allStores
            .Select(p => $"{p.Item2}  ({p.Item1})")
            .Distinct()
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(all.Take(50));
        return Task.FromResult<IEnumerable<string>>(all
            .Where(s => s.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(50));
    }

    private void OnSkuMaxStoreChanged(string? v)
    {
        _skuFilterStoreText = v ?? "";
        _skuFilterStore     = "";
        if (!string.IsNullOrWhiteSpace(v))
        {
            var s = v.Trim();
            var open  = s.LastIndexOf('(');
            var close = s.LastIndexOf(')');
            _skuFilterStore = (open >= 0 && close > open && close == s.Length - 1)
                ? s.Substring(open + 1, close - open - 1).Trim()
                : s;
        }
        StateHasChanged();
    }

    private async Task LoadSkuMaxDetailAsync()
    {
        _skuMaxFilterError = null;
        if (_skuFilterDiv <= 0
            && string.IsNullOrWhiteSpace(_skuFilterStore)
            && string.IsNullOrWhiteSpace(_skuFilterItem))
        {
            _skuMaxFilterError = "Pick at least one of Division, Store, or Item code before applying.";
            _skuMaxRows.Clear();
            _skuMaxLoaded = true;
            StateHasChanged();
            return;
        }
        if (_runDate is null || string.IsNullOrEmpty(_country))
        {
            _skuMaxFilterError = "Country / Run date are required.";
            return;
        }

        _loadingSkuMax = true; StateHasChanged();
        try
        {
            var d = _runDate.Value.Date;
            _skuMaxRows = await Reports.GetItemSkuMaxAsync(
                _country, d.Year, d.Month,
                _skuFilterDiv > 0 ? _skuFilterDiv : (int?)null,
                string.IsNullOrWhiteSpace(_skuFilterStore) ? null : _skuFilterStore,
                string.IsNullOrWhiteSpace(_skuFilterItem)  ? null : _skuFilterItem,
                top: 5000);
            _skuMaxLoaded = true;
        }
        catch (Exception ex)
        {
            _skuMaxFilterError = $"Load failed: {ex.Message}";
        }
        finally
        {
            _loadingSkuMax = false; StateHasChanged();
        }
    }

    private async Task ExportSkuMaxAsync()
    {
        if (_skuMaxRows.Count == 0) return;
        var fileName = $"SKU_Max_Detail_{_country}_{_runDate?.Year:0000}-{_runDate?.Month:00}.xlsx";
        await SaveExcelAsync(fileName, "SKU Max Detail", ws =>
        {
            string[] headers = { "Store ID", "Store Name", "Division", "Item Code", "Season", "WH Stock", "Vol Group", "SKU Max" };
            for (int c = 0; c < headers.Length; c++) ws.Cell(1, c + 1).Value = headers[c];
            ws.Range(1, 1, 1, headers.Length).Style.Font.Bold = true;
            ws.Range(1, 1, 1, headers.Length).Style.Fill.BackgroundColor = XLColor.LightGray;

            int row = 2;
            foreach (var r in _skuMaxRows)
            {
                ws.Cell(row, 1).Value = r.StoreID;
                ws.Cell(row, 2).Value = r.StoreName;
                ws.Cell(row, 3).Value = $"{r.DivisionName} ({r.DivCode})";
                ws.Cell(row, 4).Value = r.ItemCode;
                ws.Cell(row, 5).Value = r.Season == "W" ? "Winter" : "Summer";
                ws.Cell(row, 6).Value = r.WHBoxQty;
                ws.Cell(row, 7).Value = r.VolumeGroup ?? "";
                ws.Cell(row, 8).Value = r.SKUMax;
                row++;
            }
            ws.Range(2, 6, row - 1, 6).Style.NumberFormat.Format = "#,##0";
            ws.Range(2, 8, row - 1, 8).Style.NumberFormat.Format = "#,##0";
        });
    }
