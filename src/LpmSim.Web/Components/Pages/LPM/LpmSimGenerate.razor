                sheet.Cell(row, 1).Value  = r.BoxNo;
                sheet.Cell(row, 2).Value  = r.PalletNo ?? "";
                sheet.Cell(row, 3).Value  = r.BoxKind ?? "";
                sheet.Cell(row, 4).Value  = r.DivisionName ?? "";
                sheet.Cell(row, 5).Value  = r.PalletType ?? "";
                sheet.Cell(row, 6).Value  = r.TypeName ?? "";
