            sheet.Range(2, 7, rows.Count + 1, 7).Style.NumberFormat.Format = "yyyy-mm-dd";
            // 1.14.70 — Format the two new date columns (Purchase Dt at 11, GIN Date at 13).
            sheet.Range(2, 11, rows.Count + 1, 11).Style.NumberFormat.Format = "yyyy-mm-dd";
            sheet.Range(2, 13, rows.Count + 1, 13).Style.NumberFormat.Format = "yyyy-mm-dd";
