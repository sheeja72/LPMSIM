    {
        if (_readiness?.CurrentBatchNo is not long bn)
        {
            Snackbar.Add("No batch selected.", Severity.Info);
            return;
        }
        if (_customColumns.Count == 0)
        {
            Snackbar.Add("Pick at least one Column.", Severity.Info);
            return;
        }
        _loadingCustom = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var spec = new CustomReportSpec(_customGroupBy.ToList(), _customColumns.ToList());
            _customResult = await Reports.RunCustomReportAsync(bn, spec);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Custom Report failed: {(ex.InnerException?.Message ?? ex.Message)}",
                         Severity.Error, cfg => cfg.VisibleStateDuration = 8000);
            _customResult = null;
        }
        finally
        {
            _loadingCustom = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Render a single cell for the Custom Report table. Numeric values get
    /// the N0 format; dates render as dd-MMM-yyyy; everything else uses
    /// ToString. Null becomes blank.
    /// </summary>
    private static string FormatCustomCell(Dictionary<string, object?> row, CustomReportColumnInfo col)
    {
        if (!row.TryGetValue(col.Key, out var v) || v is null) return "";
        return v switch
        {
            DateTime dt   => dt.ToString("dd-MMM-yyyy"),
            decimal dec   => dec.ToString("N0"),
            double dbl    => dbl.ToString("N0"),
            float flt     => flt.ToString("N0"),
            long l        => l.ToString("N0"),
            int i         => i.ToString("N0"),
            short s       => s.ToString("N0"),
            byte by       => by.ToString("N0"),
            _             => v.ToString() ?? "",
        };
    }

    private async Task ExportCustomReportAsync()
    {
        if (_customResult is null || _customResult.Rows.Count == 0)
        {
            Snackbar.Add("Nothing to export — Run the report first.", Severity.Info);
            return;
        }
        var bn  = _readiness?.CurrentBatchNo ?? 0;
        var ts  = DateTime.Now.ToString("yyyyMMdd-HHmm");
        var cr  = _customResult;
        await SaveExcelAsync($"LPMSIM_Custom_{bn}_{ts}.xlsx", "Custom", sheet =>
        {
            for (int c = 0; c < cr.Columns.Count; c++)
            {
                var cell = sheet.Cell(1, c + 1);
                cell.Value = cr.Columns[c].DisplayName;
                cell.Style.Font.Bold = true;
                cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.White;
                cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromArgb(0x0F, 0x17, 0x2A);
                cell.Style.Alignment.Horizontal = cr.Columns[c].IsNumeric
                    ? ClosedXML.Excel.XLAlignmentHorizontalValues.Right
                    : ClosedXML.Excel.XLAlignmentHorizontalValues.Left;
            }
            for (int r = 0; r < cr.Rows.Count; r++)
            {
                var row = cr.Rows[r];
                for (int c = 0; c < cr.Columns.Count; c++)
                {
                    var col = cr.Columns[c];
                    var cell = sheet.Cell(r + 2, c + 1);
                    if (row.TryGetValue(col.Key, out var v) && v is not null)
                    {
                        switch (v)
                        {
                            case DateTime dt: cell.Value = dt; cell.Style.NumberFormat.Format = "dd-mmm-yyyy"; break;
                            case decimal dec: cell.Value = (double)dec; if (col.IsNumeric) cell.Style.NumberFormat.Format = "#,##0"; break;
                            case double dbl:  cell.Value = dbl;          if (col.IsNumeric) cell.Style.NumberFormat.Format = "#,##0"; break;
                            case long l:      cell.Value = l;            if (col.IsNumeric) cell.Style.NumberFormat.Format = "#,##0"; break;
                            case int i:       cell.Value = i;            if (col.IsNumeric) cell.Style.NumberFormat.Format = "#,##0"; break;
                            default:          cell.Value = v.ToString(); break;
                        }
                    }
                }
            }
        });
        Snackbar.Add($"Exported {cr.Rows.Count:N0} rows to LPMSIM_Custom_{bn}_{ts}.xlsx",
                     Severity.Success, cfg => cfg.VisibleStateDuration = 4000);
    }

    private string CurrentBatchAccent() =>
        _readiness?.ExistingApproved == true ? "lpm-accent-purple"
        : _readiness?.ExistingDraft == true ? "lpm-accent-amber"
        : "lpm-accent-blue";

    private async Task OnRunDateChanged(DateTime? date)
    {
        var prev = _runDate;
        _runDate = date;
        // Changing run date drops out of any "viewing specific batch" mode —
        // the user is asking for a different period; the override only made
        // sense for the previous period.
        _viewBatchNo = null;
        // Day-of-month doesn't affect any readiness counter (the box / EOM /
        // SOH queries all key on Year+Month), so when the user just changes
        // the day inside the same month we can skip the heavy readiness
        // re-query and only refresh the existing-batch lookup. The full path
        // still runs on Country / Year / Month / Sources / Season changes.
        if (date is DateTime nd && prev is DateTime pd
            && nd.Year == pd.Year && nd.Month == pd.Month
            && _readiness is not null)
        {
            await RefreshExistingBatchOnlyAsync();
            return;
        }
        await CheckAsync();
    }

    // Cheap follow-up: just look up the (Country, RunDate) batch row to
    // refresh the bottom-line "Current batch" card. The expensive box /
    // SOH counters are reused from the previous CheckAsync result.
    private async Task RefreshExistingBatchOnlyAsync()
    {
        if (string.IsNullOrEmpty(_country) || _runDate is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var rd = _runDate.Value.Date;
        var existing = await db.LpmSimBatches.AsNoTracking()
            .Where(b => b.Country == _country && b.RunDate == rd)
            .OrderByDescending(b => b.LPMBatchNo)
            .FirstOrDefaultAsync();
        if (_readiness is not null)
        {
            _readiness = _readiness with
            {
                ExistingDraft     = existing is { Status: "Draft"    },
                ExistingApproved  = existing is { Status: "Approved" },
                CurrentBatchNo    = existing?.LPMBatchNo,
                CurrentStatus     = existing?.Status,
                CurrentApprovedTS = existing?.ApprovedTS,
                CurrentApprovedBy = existing?.ApprovedBy,
            };
        }
        // Keep tab data in sync with whichever batch is now "current".
        if (existing?.LPMBatchNo != _loadedBatchNo)
        {
            if (existing is not null)
            {
                _summary.Clear(); _storeSummary.Clear(); _divisionSummary.Clear(); _boxRows.Clear(); _itemRows.Clear(); _traceRows.Clear();
                _traceCounts = null;
                _aggregates = await Reports.GetBatchAggregatesAsync(existing.LPMBatchNo, _minUsability, _maxUsability);
                try { _sourceWh = await Reports.GetSourceWarehouseBreakdownAsync(existing.LPMBatchNo); } catch { _sourceWh = null; }
                _ = LoadSummaryAsync(existing.LPMBatchNo);
            }
            else
            {
                _summary = new(); _storeSummary = new(); _divisionSummary = new(); _boxRows = new();
                _itemRows = new(); _traceRows = new(); _traceCounts = null;
                _aggregates = null;
                _sourceWh   = null;
            }
            _loadedBatchNo = existing?.LPMBatchNo;
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _countries = await db.DataSettings
            .Where(s => s.ActiveStore == "Y" && s.Country != null && s.Country != "")
            .Select(s => s.Country!).Distinct().OrderBy(c => c).ToListAsync();
        // 1.14.55 — Active divisions only in the SIM Generate filter dropdown.
        _allDivisions = await db.Divisions.AsNoTracking()
            .Where(d => d.IsActive)
            .Select(d => d.Name ?? "")
            .Where(n => n != "")
            .OrderBy(n => n)
            .ToListAsync();
        if (!_countries.Contains(_country, StringComparer.OrdinalIgnoreCase))
            _country = _countries.FirstOrDefault() ?? "";
        // 1.14.64 — Distinct warehouses + LPM months are country-aware now
        // (1.14.61 added the optional country parameter to the service
        // methods; this loads them for the initially-selected country and
        // ReloadCountryFiltersAsync below refreshes them whenever the user
        // switches country).
        await ReloadCountryFiltersAsync();
        // Distinct pallet categories (from bfldata.dbo.pallettype) — this
        // master is shared across countries, so no country parameter.
        try { _allPalletCategories = await Reports.GetDistinctPalletCategoriesAsync(); }
        catch { _allPalletCategories = new(); }
        await LoadStoresForCountryAsync();
        if (!string.IsNullOrEmpty(_country)) await CheckAsync();
    }

    /// <summary>
    /// 1.14.64 — Reloads the country-specific filter sources (warehouses,
    /// LPM months) for the currently-selected country and clears any
    /// previous selections that no longer apply. Called from OnInitializedAsync
    /// for the initial load and from the Country dropdown's ValueChanged
    /// handler whenever the planner switches country.
    /// </summary>
    private async Task ReloadCountryFiltersAsync()
    {
        var country = string.IsNullOrEmpty(_country) ? "UAE" : _country;
        try { _allWarehouses = await Reports.GetDistinctWarehousesAsync(country); }
        catch { _allWarehouses = new(); }
        try { _allLpmMonths  = await Reports.GetDistinctLpmMonthsAsync(country); }
        catch { _allLpmMonths = new(); }
        // Drop selections that no longer exist in the new country's source —
        // keeps the multi-selects consistent so the planner doesn't
        // accidentally allocate a UAE-only warehouse to KSA.
        if (_selectedWarehouses is not null)
            _selectedWarehouses = _selectedWarehouses.Where(w => _allWarehouses.Contains(w, StringComparer.OrdinalIgnoreCase)).ToList();
        if (_selectedLpmMonths is not null)
            _selectedLpmMonths  = _selectedLpmMonths .Where(m => _allLpmMonths .Contains(m)).ToHashSet();
        StateHasChanged();
    }

    private async Task LoadStoresForCountryAsync()
    {
        if (string.IsNullOrEmpty(_country)) { _allStores = new(); return; }
        await using var db = await DbFactory.CreateDbContextAsync();
        var rows = await db.DataSettings.AsNoTracking()
            .Where(s => s.ActiveStore == "Y" && s.Country == _country
                     && s.StoreID != null && s.PBFullname != null)
            .Select(s => new { s.StoreID, s.PBFullname })
            .Distinct()
            .OrderBy(s => s.PBFullname)
            .ToListAsync();
        _allStores = rows.Select(x => (x.StoreID!, x.PBFullname!)).ToList();
    }

    // Tracks "user changed something while a Check was running" — when the
    // current call finishes we pass through the loop one more time so the
    // final readiness reflects the latest filter state. Without this, rapid
    // clicks during a slow Check would land on stale data.
    private bool _checkPending;

    private async Task CheckAsync()
    {
        if (string.IsNullOrEmpty(_country) || _runDate is null) { _readiness = null; _lines.Clear(); _skuMaxStatus = null; _inputFreshness = null; _skuMaxScopeCounts = null; StateHasChanged(); return; }

        // Reload the SKU Max panel alongside readiness so the user sees the
        // current build status when they change Country / RunDate. This is
        // a cheap query (max + count) so doing it on every Check is fine.
        _ = LoadSkuMaxStatusAsync();

        // Reentrancy guard. If a Check is already running, just flag that one
        // more pass is needed and return — the in-flight call will loop again.
        if (_busy) { _checkPending = true; return; }
        _busy = true; StateHasChanged();
        try
        {
            // Trailing-debounce loop: re-run while the user kept changing
            // inputs during a Check. Reads filter state fresh on every pass
            // so the final readiness reflects the latest UI.
            do
            {
                _checkPending = false;
                var d = _runDate.Value.Date;
                // 1.14.67 — Pass CurrentUser.Name so any in-flight "Running"
                // batch started by a different user is hidden from this viewer
                // (no half-built CURRENT BATCH pill, no premature flip). The
                // creator still sees their own Running batch.
                _readiness = await Sim.CheckAsync(_country, d.Year, d.Month, d, CurrentSources, CurrentSeasons, _selectedWarehouses.ToList(), _includePurchasedBoxes, _selectedPalletCategories.ToList(), _selectedLpmMonths.ToList(), _viewBatchNo, CurrentUser.Name);
                // Refresh the list of batches for this period so the result-preview
                // pills show every Draft + Approved the planner can flip to.
                try { _periodBatches = await Reports.GetBatchesForPeriodAsync(_country, d, CurrentUser.Name); }
                catch { _periodBatches = new(); }
                var bnNow = _readiness.CurrentBatchNo;

                // Only reload the heavy result tabs when the batch number
                // actually changes (new draft, switched country/date, batch
                // deleted). Filter tweaks like Box Source / Season / Warehouse
                // change the readiness counters at the top but do NOT change
                // the existing batch's tab data — re-running LoadSummaryAsync
                // on every checkbox click was costing a round-trip per click.
                if (bnNow != _loadedBatchNo)
                {
                    if (bnNow is long bn)
                    {
                        _summary.Clear(); _storeSummary.Clear(); _divisionSummary.Clear(); _boxRows.Clear(); _itemRows.Clear(); _traceRows.Clear();
                        _traceCounts = null;
                        _aggregates = await Reports.GetBatchAggregatesAsync(bn, _minUsability, _maxUsability);
                        try { _sourceWh = await Reports.GetSourceWarehouseBreakdownAsync(bn); } catch { _sourceWh = null; }

                        // Summary tab load runs in the background — its own
                        // _loadingSummary flag drives the progress bar inside
                        // the tab. We don't await it here so changing the
                        // run-date doesn't lock the page on the heavy Summary
                        // CTE; the user can switch to other tabs, click
                        // Generate, etc., while Summary fills in.
                        _ = LoadSummaryAsync(bn);
                    }
                    else
                    {
                        _lines = new List<LpmSimOutput>();
                        _summary = new List<EomSummaryRow>();
                        _storeSummary = new List<StoreSummaryRow>();
                        _divisionSummary = new List<DivisionSummaryRow>();
                        _boxRows = new List<BoxDetailRow>();
                        _itemRows = new List<ItemDetailRow>();
                        _traceRows = new List<AllocTraceRow>();
                        _traceCounts = null;
                        _aggregates = null;
                        _sourceWh   = null;
                    }
                    _loadedBatchNo = bnNow;
                }
            } while (_checkPending);
        }
        catch (Exception ex)
        {
            _lastError = FormatError("Check failed", ex);
            Snackbar.Add($"Check failed: {(ex.InnerException?.Message ?? ex.Message)}", Severity.Error,
                cfg => { cfg.RequireInteraction = true; cfg.HideTransitionDuration = 0; });
        }
        finally { _busy = false; StateHasChanged(); }
    }

    private async Task GenerateAsync()
    {
        if (_runDate is null || string.IsNullOrEmpty(_country)) return;

        // 1.14.24 — IMMEDIATE feedback so the user sees their click registered
        // even before the schedule-existence probe runs. 1.14.22 introduced
        // the probe but didn't surface any UI state during it, so a slow probe
        // (network blip, transient DB issue) looked exactly like "nothing
        // happens" to the user.
        Snackbar.Add("Checking for existing batch…", Severity.Info,
            cfg => cfg.VisibleStateDuration = 1500);

        // 1.14.22 — when an existing Draft batch is present, also peek at
        // whether it has a Production Schedule attached. If so, the dialog
        // text below names the schedule that will be deleted and the user's
        // OK passes DeleteExistingSchedule=true into the service call. The
        // service throws if the flag is false and a schedule exists, so
        // skipping the dialog (or saying No) still keeps schedule data safe.
        bool deleteExistingSchedule = false;
        if (_readiness?.ExistingDraft == true)
        {
            bool hasSchedule = false;
            long? existingDraftNo = null;
            bool probeTimedOut = false;
            // 1.14.24 — strict 3s timeout on the probe. The two queries
            // are simple indexed seeks (Batch PK + Schedule PK on
            // LPMBatchNo) and complete in <500ms normally. If they take
            // longer than 3 seconds something is genuinely wrong (pool
            // exhaustion / network blip / transient DB issue), and we
            // bail to the legacy dialog instead of leaving the user
            // staring at a frozen page.
            try
            {
                using var probeCts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                await using var probeDb = await DbFactory.CreateDbContextAsync(probeCts.Token);
                existingDraftNo = await probeDb.LpmSimBatches.AsNoTracking()
                    .Where(b => b.Country == _country
                             && b.RunDate == _runDate.Value.Date
                             && b.Status == "Draft")
                    .OrderByDescending(b => b.LPMBatchNo)
                    .Select(b => (long?)b.LPMBatchNo)
                    .FirstOrDefaultAsync(probeCts.Token);
                if (existingDraftNo.HasValue)
                {
                    hasSchedule = await probeDb.LpmSimProductionSchedules.AsNoTracking()
                        .AnyAsync(s => s.LPMBatchNo == existingDraftNo.Value, probeCts.Token);
                }
            }
            catch (OperationCanceledException)
            {
                // Probe timed out — surface so the user knows we're falling
                // back. The dialog still appears; service-side guard still
                // protects schedule data even if the user picks "Generate".
                probeTimedOut = true;
                Snackbar.Add(
                    "Schedule check timed out — opening dialog. If a Production Schedule exists, Generate may fail; delete the schedule on the Production Schedule page first.",
                    Severity.Warning, cfg => cfg.VisibleStateDuration = 8000);
            }
            catch (Exception ex)
            {
                // Other probe failures are non-fatal: fall back to legacy
                // dialog. The service-side guard at LpmSimGenerator.cs:522
                // still throws if a schedule exists and the flag is false.
                Snackbar.Add($"Schedule check failed ({ex.Message}). Falling back to legacy dialog.",
                    Severity.Warning, cfg => cfg.VisibleStateDuration = 8000);
            }

            bool? ok;
            if (hasSchedule && existingDraftNo.HasValue)
            {
                ok = await DialogService.ShowMessageBox("Replace Draft + delete Production Schedule",
                    $"Draft batch #{existingDraftNo} has an attached Production Schedule. "
                    + "Generate will REPLACE the batch AND DELETE the Production Schedule. Continue?",
                    yesText: "Generate (delete schedule)", cancelText: "Cancel");
            }
            else
            {
                var legacyTitle = probeTimedOut ? "Overwrite Draft (schedule check skipped)" : "Overwrite Draft";
                ok = await DialogService.ShowMessageBox(legacyTitle,
                    "A Draft batch already exists for this country and date. Generate will replace it. Continue?",
                    yesText: "Generate", cancelText: "Cancel");
            }
            if (ok != true) return;
            deleteExistingSchedule = hasSchedule;
        }

        _lastError = "";
        _lastRunDuration = null;
        _lastRunSummary = null;
        _busy = true; StateHasChanged();
        var sw = Stopwatch.StartNew();
        try
        {
            var d = _runDate.Value.Date;
            var result = await Sim.GenerateAsync(new LpmSimGenerateRequest
            {
                Country              = _country,
                RunYear              = d.Year,
                RunMonth             = d.Month,
                RunDate              = d,
                User                 = CurrentUser.Name,
                Sources              = CurrentSources,
                Seasons              = CurrentSeasons,
                OverrideUsabilityPct = _overridePct,
                Warehouses           = _selectedWarehouses.ToList(),
                VerboseTrace         = _verboseTrace,
                FillStrategy         = _fillStrategy,
                IgnoreMerchNeed      = _ignoreMerchNeed,
                IncludePurchasedBoxes = _includePurchasedBoxes,
                PalletCategories     = _selectedPalletCategories.ToList(),
                LpmMonths            = _selectedLpmMonths.ToList(),
                WeekNo               = (byte)_runWeek,
                DeleteExistingSchedule = deleteExistingSchedule,   // 1.14.22 — true only when the user confirmed the schedule-delete dialog
            });
            sw.Stop();
            _lastRunDuration = sw.Elapsed;
            // Show qty + per-phase + timing breakdown so the user can see where
            // the time went without leaving the page.
            _lastRunSummary  =
                $"Batch #{result.LPMBatchNo} · {result.LinesGenerated:N0} lines · {result.BoxesProcessed:N0} boxes · qty {result.TotalQty:N0} · " +
                $"P1 normal {result.P1NormalQty:N0} / RR {result.P1RrQty:N0} · P2 normal {result.P2NormalQty:N0} / RR {result.P2RrQty:N0} · " +
                $"⏱ readBoxes {result.MsReadBoxes:N0}ms / itemDiv {result.MsReadItemDiv:N0}ms / SOH {result.MsReadSoh:N0}ms / EOM {result.MsReadEom:N0}ms / " +
                $"alloc {result.MsAllocate:N0}ms / output {result.MsPersistOutput:N0}ms / trace {result.MsPersistTrace:N0}ms ({result.TraceRowsWritten:N0} rows) / balances {result.MsPersistBalances:N0}ms";

            Snackbar.Add(
                $"Batch #{result.LPMBatchNo} ready in {FormatDuration(sw.Elapsed)} — {result.LinesGenerated:N0} lines, {result.BoxesProcessed:N0} boxes, qty {result.TotalQty:N0}.",
                Severity.Success,
                cfg => cfg.VisibleStateDuration = 12000);
            if (result.ItemsWithoutDivision > 0 || result.BoxesSkipped > 0)
                Snackbar.Add(
                    $"Skipped {result.ItemsWithoutDivision:N0} items without division mapping; {result.BoxesSkipped:N0} item lines had no EOM rows for their division.",
                    Severity.Warning,
                    cfg => cfg.VisibleStateDuration = 15000);

            // 1.14.29 — audit-log this user-initiated action.
            await ActionLog.LogAsync(
                "LpmSimGenerate.Generate",
                $"#{result.LPMBatchNo}",
                new
                {
                    batchNo            = result.LPMBatchNo,
                    country            = _country,
                    runDate            = d.ToString("yyyy-MM-dd"),
                    weekNo             = _runWeek,
                    sources            = CurrentSources.ToString(),
                    seasons            = CurrentSeasons.ToString(),
                    overrideUsabilityPct = _overridePct,
                    fillStrategy       = _fillStrategy.ToString(),
                    ignoreMerchNeed    = _ignoreMerchNeed,
                    includePurchased   = _includePurchasedBoxes,
                    palletCategories   = _selectedPalletCategories.ToList(),
                    warehouses         = _selectedWarehouses.ToList(),
                    lpmMonths          = _selectedLpmMonths.ToList(),
                    deleteExistingSchedule = deleteExistingSchedule,
                    lines              = result.LinesGenerated,
                    boxes              = result.BoxesProcessed,
                    totalQty           = result.TotalQty,
                    elapsedMs          = (int)sw.Elapsed.TotalMilliseconds,
                },
                action: 'X');

            // Release the busy flag BEFORE awaiting CheckAsync. CheckAsync's
            // reentrancy guard returns early when _busy is true (it's the
            // shared "another op is running" gate), which would otherwise
            // leave _readiness stale and the Current Batch line stuck on the
            // pre-Generate state. The finally below still re-clears _busy
            // for safety on the catch paths.
            _busy = false;
            // A successful Generate produces the new latest batch — drop any
            // "viewing older batch" override so the result preview snaps to
            // the brand-new run.
            _viewBatchNo = null;
            await CheckAsync();
        }
        catch (SkuMaxStaleException sse)
        {
            // Refresh the panel so the user sees the same status the engine saw,
            // then nudge them to click Build SKU Max.
            sw.Stop();
            _skuMaxStatus = sse.Status;
            Snackbar.Add(sse.Message, Severity.Warning,
                cfg => { cfg.RequireInteraction = true; cfg.VisibleStateDuration = 15000; });
        }
        catch (Exception ex)
        {
            sw.Stop();
            // Walk the InnerException chain — DbUpdateException's Message is
            // generic ("An error occurred while saving..."); the real SQL error
            // (constraint name, column, etc.) lives a couple of levels deep.
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"Generate failed after {FormatDuration(sw.Elapsed)}.").AppendLine();
            var cur = ex; var depth = 0;
            while (cur is not null && depth < 5)
            {
                sb.AppendLine($"[{depth}] {cur.GetType().Name}: {cur.Message}");
                cur = cur.InnerException; depth++;
            }
            sb.AppendLine().AppendLine(ex.StackTrace);
            _lastError = sb.ToString();
            Snackbar.Add(
                $"Generate failed: {(ex.InnerException?.Message ?? ex.Message)}",
                Severity.Error,
                cfg => { cfg.RequireInteraction = true; cfg.HideTransitionDuration = 0; });
        }
        finally { _busy = false; StateHasChanged(); }
    }

    /// <summary>
    /// Reloads SKU Max build status + input freshness for the current
    /// Country / RunDate.
    ///
    /// Status (count + max ts on our local table) is cheap and drives the
    /// status badge — fetched first and rendered immediately. Input freshness
    /// (MAX(LPMDt) on whboxitems, MAX(CreateTS) on rules / EOM) takes longer
    /// on cold cache and is informational only — fetched second so the user
    /// isn't staring at "Loading…" while the slow queries complete.
    ///
    /// Both stages call <see cref="ComponentBase.InvokeAsync"/> +
    /// <see cref="ComponentBase.StateHasChanged"/> so the panel re-renders
    /// even when this method is fired with <c>_ = LoadSkuMaxStatusAsync()</c>
    /// from outside an event handler.
    /// </summary>
    private async Task LoadSkuMaxStatusAsync()
    {
        if (_runDate is null || string.IsNullOrEmpty(_country))
        {
            _skuMaxStatus   = null;
            _inputFreshness = null;
            // Detach from any prior period's job — the manager keeps it; only
            // the page-side reference + ticker need to clear.
            _activeBuildJob = null;
            _skuMaxLiveTimer?.Dispose();
            _skuMaxLiveTimer = null;
            _skuMaxBuildStartTS = null;
            _skuMaxBuildEndTS = null;
            _skuMaxBuildDuration = null;
            await InvokeAsync(StateHasChanged);
            return;
        }
        var d = _runDate.Value.Date;

        // Reattach to the singleton manager's job state for this period —
        // covers both the "build still running after navigation" case and
        // the "build finished while user was elsewhere" case.
        var existingJob = SkuMaxJobs.Get(_country, d.Year, d.Month);
        if (existingJob is not null)
        {
            AttachJob(existingJob);
        }
        else
        {
            // No active job for this period — clear the banner state.
            _activeBuildJob = null;
            _skuMaxLiveTimer?.Dispose();
            _skuMaxLiveTimer = null;
            _skuMaxBuildStartTS = null;
            _skuMaxBuildEndTS = null;
            _skuMaxBuildDuration = null;
        }

        // Stage 1 — status badge (sub-second; LPM_SimItemSkuMax has good indexes).
        try
        {
            _skuMaxStatus = await Sim.GetLastSkuMaxBuildAsync(_country, d.Year, d.Month);
        }
        catch (Exception ex)
        {
            _skuMaxStatus = null;
            await InvokeAsync(() =>
            {
                Snackbar.Add($"Could not load SKU Max status: {(ex.InnerException?.Message ?? ex.Message)}",
                             Severity.Warning, cfg => cfg.VisibleStateDuration = 8000);
                StateHasChanged();
            });
            return;
        }
        await InvokeAsync(StateHasChanged);

        // Stage 2 — input freshness (informational; runs after status renders).
        try
        {
            _inputFreshness = await Sim.GetInputFreshnessAsync(_country, d.Year, d.Month);
        }
        catch
        {
            // Non-fatal — panel just won't show input timestamps until next reload.
            _inputFreshness = null;
        }
        await InvokeAsync(StateHasChanged);

        // Stage 3 — distinct-item counts per scope (drives the "10,408 SKUs"
        // chip next to the Scope dropdown). Independent of period — depends
        // only on whboxitems × upc_subclass — so we don't refetch when the
        // RunDate changes (Country still triggers a refresh because the
        // underlying tables can vary by deployment).
        try
        {
            _skuMaxScopeCounts = await Sim.GetSkuMaxScopeCountsAsync(_country);
        }
        catch
        {
            // Non-fatal — chip just won't show until next page load.
            _skuMaxScopeCounts = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// User-triggered Build SKU Max for the current Country / RunDate. The
    /// run can take several minutes for large catalogs (UAE: ~1-7M rows).
    ///
    /// Flow:
    ///   1. If a snapshot already exists, ask "Rebuild?" (skip-rebuild prompt).
    ///   2. Run a quick preview query (PreviewSkuMaxBuildAsync) so the
    ///      planner sees how many items will be processed and how many
    ///      existing rows are about to be replaced vs preserved (the
    ///      scope-aware DELETE only touches items in scope).
    ///   3. On confirm, kick the build off in the background.
    /// </summary>
    private async Task BuildSkuMaxAsync()
    {
        if (_runDate is null || string.IsNullOrEmpty(_country)) return;

        var d = _runDate.Value.Date;
        if (SkuMaxJobs.IsRunning(_country, d.Year, d.Month))
        {
            Snackbar.Add("A SKU Max build is already running for this period.", Severity.Info);
            return;
        }

        // Skip-rebuild prompt: any time a SKU Max snapshot already exists for
        // this period (today's or older), ask the user whether they want to
        // pay for a fresh build or reuse the existing one. SIM Generate
        // accepts stale snapshots — the multi-million-row rebuild is only
        // needed when WHBox items / SKU Max Rules / Volume Group changed.
        if (_skuMaxStatus is { LastBuildTS: not null } sExist)
        {
            var when     = sExist.LastBuildTS?.ToString("dd-MMM HH:mm") ?? "earlier";
            var who      = string.IsNullOrEmpty(sExist.LastBuildBy) ? "" : $" by {sExist.LastBuildBy}";
            var freshTag = sExist.IsFreshToday ? "" : " (older than today — stale)";
            var ok       = await DialogService.ShowMessageBox(
                "SKU Max snapshot exists",
                $"SKU Max for {_country} {_runDate.Value:yyyy-MM} was last built {when}{who}{freshTag}, with {sExist.RowCount:N0} rows.\n\n" +
                "You can use the existing snapshot to generate SIM right away. Rebuild only if WH Box items, SKU Max Rules, or Volume Group assignments changed since.\n\n" +
                "Rebuild anyway?",
                yesText: "Rebuild", cancelText: "Use existing");
            if (ok != true)
            {
                Snackbar.Add($"Using existing SKU Max ({sExist.RowCount:N0} rows). Click Generate to run SIM.",
                             Severity.Info, cfg => cfg.VisibleStateDuration = 6000);
                return;
            }
        }

        // Pre-build preview: count how many items the build will process
        // for the chosen scope, plus how many existing rows will be replaced
        // vs preserved. Surfaces the scale of the operation so the planner
        // can sanity-check before paying for the multi-minute rebuild.
        SkuMaxBuildPreview? preview = null;
        try
        {
            _busy = true;            // disables Generate while we count
            await InvokeAsync(StateHasChanged);
            preview = await Sim.PreviewSkuMaxBuildAsync(_country, d.Year, d.Month, _selectedSkuMaxScope);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not preview SKU Max build: {ex.Message}", Severity.Error);
            return;
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }

        // Different message per scope — keeps the planner from second-guessing
        // what the build will and won't touch.
        string msg;
        switch (_selectedSkuMaxScope)
        {
            case LpmSimSkuMaxScope.LpmOnly:
                msg =
                    $"Build SKU Max — LPM items only (LPMDt IS NOT NULL)\n" +
                    $"Country: {_country}   Period: {_runDate.Value:yyyy-MM}\n\n" +
                    $"LPM items to rebuild: {preview.ItemsInScope:N0}" +
                    (preview.DroppedNoMaster > 0
                        ? $"  ({preview.DroppedNoMaster:N0} skipped — not in upc_subclass)"
                        : "") + "\n" +
                    $"Existing LPM rows that will be REPLACED: {preview.ExistingRowsInScope:N0}\n" +
                    $"Non-LPM rows that will be PRESERVED (untouched): {preview.ExistingRowsKept:N0}\n\n" +
                    "Proceed?";
                break;

            case LpmSimSkuMaxScope.NonLpmOnly:
                msg =
                    $"Build SKU Max — Non-LPM items only (LPMDt IS NULL)\n" +
                    $"Country: {_country}   Period: {_runDate.Value:yyyy-MM}\n\n" +
                    $"Non-LPM items to rebuild: {preview.ItemsInScope:N0}" +
                    (preview.DroppedNoMaster > 0
                        ? $"  ({preview.DroppedNoMaster:N0} skipped — not in upc_subclass)"
                        : "") + "\n" +
                    $"Existing Non-LPM rows that will be REPLACED: {preview.ExistingRowsInScope:N0}\n" +
                    $"LPM rows that will be PRESERVED (untouched): {preview.ExistingRowsKept:N0}\n\n" +
                    "Proceed?";
                break;

            default: // All
                msg =
                    $"Build SKU Max — ALL items (full rebuild)\n" +
                    $"Country: {_country}   Period: {_runDate.Value:yyyy-MM}\n\n" +
                    $"Items to rebuild: {preview.ItemsInScope:N0}" +
                    (preview.DroppedNoMaster > 0
                        ? $"  ({preview.DroppedNoMaster:N0} skipped — not in upc_subclass)"
                        : "") + "\n" +
                    $"Existing rows for the period (will all be DELETED + rebuilt): {preview.ExistingRowsInScope:N0}\n\n" +
                    "Proceed?";
                break;
        }

        var go = await DialogService.ShowMessageBox(
            "Confirm SKU Max Build", msg,
            yesText: "Build", cancelText: "Cancel");
        if (go != true) return;
        var scopeLabel = SkuMaxScopeLabel(_selectedSkuMaxScope);

        _lastError = "";
        try
        {
            // Hand the build off to the singleton manager — it owns the
            // task lifecycle and uses its own CancellationTokenSource, so
            // the build keeps running if the user navigates to a different
            // page. Returning to SIM Generate re-attaches via OnInitialized.
            var job = SkuMaxJobs.Start(_country, d.Year, d.Month, CurrentUser?.Name ?? "", _selectedSkuMaxScope);
            AttachJob(job);
            Snackbar.Add(
                $"SKU Max build started in background ({scopeLabel}, {preview.ItemsInScope:N0} items). " +
                "You can navigate away — it'll keep running.",
                Severity.Success, cfg => cfg.VisibleStateDuration = 6000);

            // 1.14.29 — audit-log this user-initiated action.
            await ActionLog.LogAsync(
                "LpmSimGenerate.BuildSkuMax",
                $"{_country}/{d:yyyy-MM}/{scopeLabel}",
                new
                {
                    country         = _country,
                    runDate         = d.ToString("yyyy-MM-dd"),
                    scope           = _selectedSkuMaxScope.ToString(),
                    itemsInScope    = preview.ItemsInScope,
                    droppedNoMaster = preview.DroppedNoMaster,
                    rowsReplaced    = preview.ExistingRowsInScope,
                    rowsPreserved   = preview.ExistingRowsKept,
                },
                action: 'X');
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task CancelSkuMaxBuildAsync()
    {
        if (_runDate is null || string.IsNullOrEmpty(_country)) return;
        var d = _runDate.Value.Date;
        var ok = await DialogService.ShowMessageBox(
            "Cancel SKU Max build?",
            $"Stop the SKU Max build for {_country} {d:yyyy-MM}? Any rows already inserted will remain " +
            "in the table (the next Build will wipe them and start over).",
            yesText: "Cancel build", cancelText: "Keep running");
        if (ok != true) return;

        if (SkuMaxJobs.Cancel(_country, d.Year, d.Month))
            Snackbar.Add("Cancelling SKU Max build…", Severity.Info);
        else
            Snackbar.Add("No active SKU Max build to cancel.", Severity.Warning);
    }

    /// <summary>
    /// Attach the page UI to a job: keep its reference, start a 1s ticker
    /// while running so the elapsed time refreshes, and subscribe to the
    /// manager's JobChanged event so the UI updates the moment the build
    /// finishes (Completed / Failed / Cancelled).
    /// </summary>
    private void AttachJob(SkuMaxBuildJob job)
    {
        _activeBuildJob = job;
        _skuMaxBuildStartTS  = job.StartedAt;
        _skuMaxBuildEndTS    = job.CompletedAt;
        _skuMaxBuildDuration = job.Duration;

        // Subscribe (idempotent — DetachJob clears prior handler reference).
        SkuMaxJobs.JobChanged -= OnSkuMaxJobChanged;
        SkuMaxJobs.JobChanged += OnSkuMaxJobChanged;

        if (job.Status == SkuMaxBuildStatus.Running)
        {
            _skuMaxLiveTimer?.Dispose();
            _skuMaxLiveTimer = new System.Threading.Timer(
                _ => InvokeAsync(StateHasChanged), null, 1000, 1000);
        }
        else
        {
            _skuMaxLiveTimer?.Dispose();
            _skuMaxLiveTimer = null;
        }
    }

    private void OnSkuMaxJobChanged(object? sender, SkuMaxBuildJob job)
    {
        // Only react to events for the period currently shown on screen.
        if (_runDate is null || string.IsNullOrEmpty(_country)) return;
        var d = _runDate.Value.Date;
        if (!string.Equals(job.Country, _country, StringComparison.OrdinalIgnoreCase) ||
            job.Year != d.Year || job.Month != d.Month) return;

        InvokeAsync(async () =>
        {
            _activeBuildJob       = job;
            _skuMaxBuildStartTS   = job.StartedAt;
            _skuMaxBuildEndTS     = job.CompletedAt;
            _skuMaxBuildDuration  = job.Duration;

            if (job.Status == SkuMaxBuildStatus.Completed)
            {
                // Refresh the SKU Max status row + input freshness from DB.
                try
                {
                    _skuMaxStatus = await Sim.GetLastSkuMaxBuildAsync(_country, d.Year, d.Month);
                    _inputFreshness = await Sim.GetInputFreshnessAsync(_country, d.Year, d.Month);
                }
                catch { /* non-fatal */ }
                Snackbar.Add(job.StatusMessage ?? "SKU Max build completed.",
                    Severity.Success, cfg => cfg.VisibleStateDuration = 8000);
                _skuMaxLiveTimer?.Dispose();
                _skuMaxLiveTimer = null;
            }
            else if (job.Status == SkuMaxBuildStatus.Cancelled)
            {
                Snackbar.Add(job.StatusMessage ?? "SKU Max build cancelled.",
                    Severity.Warning, cfg => cfg.VisibleStateDuration = 6000);
                _skuMaxLiveTimer?.Dispose();
                _skuMaxLiveTimer = null;
            }
            else if (job.Status == SkuMaxBuildStatus.Failed)
            {
                _lastError = job.Error ?? "Unknown error";
                Snackbar.Add($"SKU Max build failed: {job.Error}",
                    Severity.Error, cfg => { cfg.RequireInteraction = true; cfg.HideTransitionDuration = 0; });
                _skuMaxLiveTimer?.Dispose();
                _skuMaxLiveTimer = null;
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        // Unsubscribe so the manager doesn't hold a dead delegate reference.
        // The build itself is OWNED by the manager — it keeps running.
        SkuMaxJobs.JobChanged -= OnSkuMaxJobChanged;
        _skuMaxLiveTimer?.Dispose();
        _skuMaxLiveTimer = null;
    }

    private static string FormatDuration(TimeSpan t)
    {
        if (t.TotalMinutes >= 1) return $"{(int)t.TotalMinutes}m {t.Seconds}s";
        if (t.TotalSeconds >= 1) return $"{t.TotalSeconds:0.0}s";
        return $"{t.TotalMilliseconds:0}ms";
    }

    /// <summary>Short, planner-friendly label for the SKU Max build scope.</summary>
    private static string SkuMaxScopeLabel(LpmSimSkuMaxScope scope) => scope switch
    {
        LpmSimSkuMaxScope.LpmOnly    => "LPM only",
        LpmSimSkuMaxScope.NonLpmOnly => "Non-LPM only",
        _                             => "All items",
    };

    /// <summary>
    /// Render the FillStrategy column from LPMSIM_Batch into a planner-friendly
    /// label. The DB value can carry the "(SM)" suffix when the batch was
    /// generated with IgnoreMerchNeed=true (compact tag fits in varchar(20)).
    /// We expand "(SM)" → "(SKU Max only)" for display.
    /// </summary>
    private static string FillLabel(string? raw)
    {
        if (string.IsNullOrEmpty(raw)) return "—";
        bool skuOnly = raw.EndsWith("(SM)", StringComparison.Ordinal);
        var name = skuOnly ? raw[..raw.IndexOf("(SM)", StringComparison.Ordinal)].TrimEnd() : raw;
        var pretty = name switch
        {
            "EqualFillRate" => "Equal fill %",
            "EqualPerStore" => "Ranking + RR",
            _               => name,
        };
        return skuOnly ? $"{pretty} (SKU Max only)" : pretty;
    }

    /// <summary>
    /// Format any exception with up to 5 levels of InnerException so the real
    /// SQL constraint / column name (which is hidden behind generic EF wrapper
    /// messages like "An error occurred while saving the entity changes") shows
    /// up in the error banner. Without this we'd be debugging blind.
    /// </summary>
    private static string FormatError(string title, Exception ex)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"{title}.").AppendLine();
        var cur = ex; var depth = 0;
        while (cur is not null && depth < 5)
        {
            sb.AppendLine($"[{depth}] {cur.GetType().Name}: {cur.Message}");
            cur = cur.InnerException; depth++;
        }
        sb.AppendLine().AppendLine(ex.StackTrace);
        return sb.ToString();
    }

    /// <summary>True when the current checkbox state matches the snapshot stored on the existing batch.</summary>
    private bool FilterMatchesCurrent()
    {
        var batchSrc  = _readiness?.CurrentBatchSources;
        var batchSeas = _readiness?.CurrentBatchSeasons;
        if (string.IsNullOrEmpty(batchSrc) || string.IsNullOrEmpty(batchSeas))
            return true;   // snapshot missing — don't nag the user
        var curSrc = SourceLabelStatic(CurrentSources);
        var curSea = SeasonLabelStatic(CurrentSeasons);
        if (!string.Equals(batchSrc, curSrc, StringComparison.OrdinalIgnoreCase)) return false;
        if (!string.Equals(batchSeas, curSea, StringComparison.OrdinalIgnoreCase)) return false;
        // Warehouses: empty current = "all" matches empty/null snapshot. Otherwise compare canonical.
        var curWh   = WarehousesLabelStatic(_selectedWarehouses);
        var batchWh = string.IsNullOrEmpty(_readiness?.CurrentBatchWarehouses) ? "" : _readiness!.CurrentBatchWarehouses;
        return string.Equals(curWh, batchWh, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Canonicalised label for "current selection" — sorted alphabetically
    /// so it compares cleanly against the saved batch's
    /// <see cref="LpmSimReadiness.CurrentBatchWarehouses"/>. Order doesn't
    /// matter (priority moved to dbo.LPM_WarehousePriority).
    /// </summary>
    private static string WarehousesLabelStatic(IReadOnlyCollection<string>? selected)
    {
        if (selected is null || selected.Count == 0) return "";
        return string.Join(",", selected
            .Where(w => !string.IsNullOrWhiteSpace(w))
            .Select(w => w.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(w => w, StringComparer.OrdinalIgnoreCase));
    }

    private static string SourceLabelStatic(LpmSimSourceFlags f)
    {
        if (f == LpmSimSourceFlags.None) return "no sources";
        var parts = new List<string>(2);
        if (f.HasFlag(LpmSimSourceFlags.LpmBoxes))    parts.Add("LPM");
        if (f.HasFlag(LpmSimSourceFlags.NonLpmBoxes)) parts.Add("Non-LPM");
        return string.Join(" + ", parts);
    }
    private static string SeasonLabelStatic(LpmSimSeasonFlags f)
    {
        if (f == LpmSimSeasonFlags.None || f == LpmSimSeasonFlags.Both) return "All seasons";
        var parts = new List<string>(2);
        if (f.HasFlag(LpmSimSeasonFlags.Summer)) parts.Add("Summer");
        if (f.HasFlag(LpmSimSeasonFlags.Winter)) parts.Add("Winter");
        return string.Join(" + ", parts);
    }

    private async Task ApproveAsync()
    {
        if (_readiness?.CurrentBatchNo is not long bn) return;
        var ok = await DialogService.ShowMessageBox("Approve batch",
            $"Approve batch #{bn}? Once approved, it cannot be re-generated until you Delete it.",
            yesText: "Approve", cancelText: "Cancel");
        if (ok != true) return;

        _busy = true; StateHasChanged();
        try
        {
            await Sim.ApproveAsync(bn, CurrentUser.Name);
            Snackbar.Add($"Batch #{bn} approved.", Severity.Success);
            // 1.14.29 — audit-log this user-initiated action.
            await ActionLog.LogAsync(
                "LpmSimGenerate.Approve",
                $"#{bn}",
                new { batchNo = bn, country = _country },
                action: 'X');
            _busy = false;          // release before CheckAsync (see GenerateAsync note)
            await CheckAsync();
        }
        catch (Exception ex)
        {
            _lastError = FormatError("Approve failed", ex);
            Snackbar.Add($"Approve failed: {(ex.InnerException?.Message ?? ex.Message)}", Severity.Error,
                cfg => { cfg.RequireInteraction = true; cfg.HideTransitionDuration = 0; });
        }
        finally { _busy = false; StateHasChanged(); }
    }

    /// <summary>
    /// Click handler for the per-period batch pills. Sets _viewBatchNo and
    /// re-runs CheckAsync — that surfaces the chosen batch's Sources /
    /// Seasons / FillStrategy / etc. as the "current" readiness even when
    /// a newer batch exists for the same period.
    /// </summary>
    private async Task ViewBatchAsync(long batchNo)
    {
        if (_viewBatchNo == batchNo) return;     // already viewing this one
        _viewBatchNo = batchNo;
        await CheckAsync();
    }

    /// <summary>Drops the override and re-renders the period's actual latest batch.</summary>
    private async Task BackToLatestBatchAsync()
    {
        if (_viewBatchNo is null) return;
        _viewBatchNo = null;
        await CheckAsync();
    }

    /// <summary>
    /// "View another batch" handler. Looks up the supplied LPMBatchNo on
    /// LPMSIM_Batch, reads its Country + RunDate, and navigates the page to
    /// that period — the existing CheckAsync flow then loads the readiness +
    /// result tabs as if the planner had picked Country/RunDate manually.
    /// </summary>
    private async Task LoadByBatchNoAsync()
    {
        _loadByBatchError = "";
        if (_loadByBatchNo is not long bn || bn <= 0)
        {
            _loadByBatchError = "Enter a valid Batch # > 0.";
            return;
        }
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var batch = await db.LpmSimBatches.AsNoTracking()
                .Where(b => b.LPMBatchNo == bn)
                .Select(b => new { b.LPMBatchNo, b.Country, b.RunDate })
                .FirstOrDefaultAsync();
            if (batch is null)
            {
                _loadByBatchError = $"Batch #{bn} not found.";
                StateHasChanged();
                return;
            }
            // Navigate to the batch's (Country, RunDate) AND set _viewBatchNo
            // so CheckAsync surfaces THIS specific batch — even if a newer
            // batch exists for the same period (e.g., the period has both an
            // Approved and a later Draft, and the user wants to look at
            // the older Approved).
            _country     = batch.Country;
            _runDate     = batch.RunDate;
            _viewBatchNo = bn;
            _loadByBatchNo = null;        // clear the input so the user can try another
            await LoadStoresForCountryAsync();
            await CheckAsync();
            Snackbar.Add($"Loaded batch #{bn} — {batch.Country} {batch.RunDate:dd-MMM-yyyy}",
                         Severity.Success, cfg => cfg.VisibleStateDuration = 5000);
        }
        catch (Exception ex)
        {
            _loadByBatchError = $"Lookup failed: {ex.InnerException?.Message ?? ex.Message}";
        }
        StateHasChanged();
    }

    private async Task DeleteAsync()
    {
        if (_readiness?.CurrentBatchNo is not long bn) return;
        var ok = await DialogService.ShowMessageBox("Delete batch",
            $"Move batch #{bn} (and all its lines) to backup tables and remove from active? You'll be able to Generate again.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;

        _busy = true; StateHasChanged();
        try
        {
            await Sim.DeleteAsync(bn, CurrentUser.Name);
            Snackbar.Add($"Batch #{bn} archived.", Severity.Success);
            // 1.14.29 — audit-log this user-initiated action.
            await ActionLog.LogAsync(
                "LpmSimGenerate.Delete",
                $"#{bn}",
                new { batchNo = bn, country = _country },
                action: 'X');
            _busy = false;          // release before CheckAsync (see GenerateAsync note)
            await CheckAsync();
        }
        catch (Exception ex)
        {
            _lastError = FormatError("Delete failed", ex);
            Snackbar.Add($"Delete failed: {(ex.InnerException?.Message ?? ex.Message)}", Severity.Error,
                cfg => { cfg.RequireInteraction = true; cfg.HideTransitionDuration = 0; });
        }
        finally { _busy = false; StateHasChanged(); }
    }

