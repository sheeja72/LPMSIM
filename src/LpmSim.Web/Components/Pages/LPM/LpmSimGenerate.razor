    /// reflects whatever the user has picked in the filter strip so the
    /// table heading matches the numbers shown below it.
    /// </summary>
    private string CurrentFilterCaption()
    {
        var parts = new List<string>(4);
        if (_selectedPalletCategories.Count == 0)
            parts.Add("PalletCategory: All");
        else if (_selectedPalletCategories.Count == 1)
            parts.Add($"PalletCategory = '{_selectedPalletCategories.First()}'");
        else
            parts.Add($"PalletCategory IN ({string.Join(", ", _selectedPalletCategories.Select(c => $"'{c}'"))})");

        parts.Add(_includePurchasedBoxes
            ? "incl. ShopEligible='E'"
            : "ShopEligible <> 'E'");

        if (_srcLpm && _selectedLpmMonths.Count > 0 && _selectedLpmMonths.Count <= 4)
            parts.Add($"LPM Months: {string.Join(", ", _selectedLpmMonths.OrderBy(m => m).Select(m => m.ToString("MMM-yy")))}");
        else if (_srcLpm && _selectedLpmMonths.Count > 4)
            parts.Add($"LPM Months: {_selectedLpmMonths.Count} selected");

        return string.Join(", ", parts);
    }

