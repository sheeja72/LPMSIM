    private async Task OnTabChanged(int idx)
    {
        _activeTab = idx;
        if (_readiness?.CurrentBatchNo is not long bn) return;
        // Tab indices match the order they're declared in the razor:
        //   0 = Summary (Store × Division)
        //   1 = Store Summary
        //   2 = Division Summary  (NEW — rolled up by Division)
        //   3 = SIM Boxes
        //   4 = Item Details
        //   5 = Allocation Trace
        // (Higher indices for SKU Max Detail / Q&A tabs are not lazy-loaded
        //  here — they handle their own load logic on Apply.)
        switch (idx)
        {
            case 0: if (_summary.Count == 0)         await LoadSummaryAsync(bn);          break;
            case 1: if (_storeSummary.Count == 0)    await LoadStoreSummaryAsync(bn);     break;
            case 2: if (_divisionSummary.Count == 0) await LoadDivisionSummaryAsync(bn);  break;
            case 3: if (_boxRows.Count == 0)         await LoadBoxesAsync(bn);            break;
            case 4: if (_itemRows.Count == 0)        await LoadItemsAsync(bn);            break;
            case 5:
                if (_traceCounts is null) _traceCounts = await Reports.GetAllocTraceCountsAsync(bn);
                if (_traceRows.Count == 0) await LoadTraceAsync();
                break;
        }
    }

