@page "/lpm/warehouse-boxes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.AdminOrEditorOrPlanner)]
@using LpmSim.Data.Warehouse
@using LpmSim.Data.Auditing
@using ClosedXML.Excel
@using LpmSim.Web.Components.Pages.Uploads
@inject WarehouseQueryService Warehouse
@inject IActionLogger ActionLog
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Warehouse Box Details</PageTitle>

<div class="lpm-page-title">Warehouse Box Details</div>
<div class="lpm-page-subtitle">
    Warehouse stock — pick a Country (UAE reads from racks.dbo.whboxitems; others from
    [&lt;DataName&gt;].dbo.WHBoxItemsExport). Use Group By to switch between detailed box rows and
    category summaries. All filters are optional (blank = All). LPM Current = LPMDt in past or
    current month; LPM Future = LPMDt in next month or later; Non-LPM = LPMDt blank.
</div>

<div class="lpm-section lpm-filter-bar lpm-filter-bar-lg">
    <MudGrid Spacing="2">
        @* Row 1 — primary filters. Each MudAutocomplete/MudSelect/MudTextField
           gets the lpm-filter-active class when its bound value is non-default
           so the planner instantly sees which filters are in effect. CSS in
           app.css turns the active filter yellow with a bold label. *@
        @* Country sits FIRST — it determines the data source. Choosing UAE
           reads from racks.dbo.whboxitems (current behaviour); choosing
           another country reads from [<DataName>].dbo.WHBoxItemsExport where
           DataName is looked up from bfldata.dbo.DataSettings.SIMCountry.
           Switching country reloads Warehouse / LPM / ContNo / Brand
           dropdowns from the new source and clears any stale filter values
           via OnCountryChanged below. Master-table-driven dropdowns (Type
           Name, Pallet Category, Division, Department) stay global. *@
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="string" Label="Country" Value="_country"
                       ValueChanged="@OnCountryChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="@(string.Equals(_country, "UAE", StringComparison.OrdinalIgnoreCase) ? "" : "lpm-filter-active")">
                @foreach (var c in _countries)
                {
                    <MudSelectItem T="string" Value="@c">@c</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Warehouse"
                               Items="_warehouses"
                               Selected="_selectedWarehouses"
                               SelectedChanged="@((HashSet<string> s) => { _selectedWarehouses = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Type Name"
                               Items="_typeNames"
                               Selected="_selectedTypeNames"
                               SelectedChanged="@((HashSet<string> s) => { _selectedTypeNames = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Pallet Category"
                               Items="_palletCategories"
                               Selected="_selectedPalletCategories"
                               SelectedChanged="@((HashSet<string> s) => { _selectedPalletCategories = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="LpmPresence" Label="LPM Status" Value="_lpmStatus"
                       ValueChanged="v => { _lpmStatus = v; StateHasChanged(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="@(_lpmStatus == LpmPresence.Any ? "" : "lpm-filter-active")">
                <MudSelectItem T="LpmPresence" Value="LpmPresence.Any">Any</MudSelectItem>
                <MudSelectItem T="LpmPresence" Value="LpmPresence.HasLpm">Has LPM</MudSelectItem>
                <MudSelectItem T="LpmPresence" Value="LpmPresence.NoLpm">No LPM (blank)</MudSelectItem>
            </MudSelect>
        </MudItem>
        @* LPM month value (e.g. May-26). Distinct values from
           racks.dbo.whboxitems.LPM. Different from "LPM Status" above which
           only filters on presence (Any / Has / No). Empty = no filter. *@
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="LPM (month)"
                               Items="_lpms"
                               Selected="_selectedLpms"
                               SelectedChanged="@((HashSet<string> s) => { _selectedLpms = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="8" md="2">
            <MudTextField T="string" Label="Pallet / Box contains"
                          Value="_search"
                          ValueChanged="v => { _search = v; StateHasChanged(); }"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="@ActiveCls(_search)" />
        </MudItem>
        <MudItem xs="12" sm="4" md="2">
            <MudSelect T="WhGroupBy" Label="Group By" Value="_groupBy"
                       ValueChanged="v => { _groupBy = v; StateHasChanged(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Class="@(_groupBy == WhGroupBy.Box ? "" : "lpm-filter-active")">
                <MudSelectItem T="WhGroupBy" Value="WhGroupBy.Box">Box (detail)</MudSelectItem>
                <MudSelectItem T="WhGroupBy" Value="WhGroupBy.Division">Division</MudSelectItem>
                <MudSelectItem T="WhGroupBy" Value="WhGroupBy.Department">Department</MudSelectItem>
                <MudSelectItem T="WhGroupBy" Value="WhGroupBy.Brand">Brand</MudSelectItem>
            </MudSelect>
        </MudItem>

        @* Row 2 — Division / Department / Brand / ContNo filters (all multi-select),
           Non-Purchased toggle, Load + Export. *@
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Division"
                               Items="_divisions"
                               Selected="_selectedDivisions"
                               SelectedChanged="@((HashSet<string> s) => { _selectedDivisions = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Department"
                               Items="_departments"
                               Selected="_selectedDepartments"
                               SelectedChanged="@((HashSet<string> s) => { _selectedDepartments = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="Brand"
                               Items="_brands"
                               Selected="_selectedBrands"
                               SelectedChanged="@((HashSet<string> s) => { _selectedBrands = s; StateHasChanged(); })" />
        </MudItem>
        @* Container No (whboxitems.ContNo). *@
        <MudItem xs="12" sm="6" md="2">
            <MultiSelectFilter Label="ContNo"
                               Items="_contNos"
                               Selected="_selectedContNos"
                               SelectedChanged="@((HashSet<string> s) => { _selectedContNos = s; StateHasChanged(); })" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
            @* Default = OFF. When CHECKED, drops the ShopEligible <> 'E' filter
               and INCLUDES "non-purchased" boxes (the business term for
               ShopEligible='E') in the result. Same semantics as the
               "Include Non-Purchased Boxes" checkbox on SIM Generate.
               Highlighted whenever it's NOT the default of false. *@
            <MudCheckBox T="bool" Value="_includeNonPurchased"
                         ValueChanged="v => { _includeNonPurchased = v; StateHasChanged(); }"
                         Color="Color.Primary"
                         Class="@(_includeNonPurchased ? "lpm-filter-active" : "")"
                         Label="Include non-Purchased Boxes" />
        </MudItem>
        <MudItem xs="12" md="3" Class="d-flex align-center justify-end gap-2">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       Disabled="_loading" OnClick="LoadAsync">
                Load
            </MudButton>
            <MudButton Color="Color.Success" Variant="Variant.Outlined" DropShadow="false" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@(_loading || !HasResults)" OnClick="ExportExcelAsync">
                Excel
            </MudButton>
        </MudItem>
    </MudGrid>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
}

@* ─────────────────────────────────────────────────────────────────────────
   Conditionally render different tables per Group By mode. Only one of
   {_rows, _divRows, _deptRows, _brandRows} is populated by LoadAsync().
   ───────────────────────────────────────────────────────────────────── *@

@if (_groupBy == WhGroupBy.Box && _rows.Count > 0)
{
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-blue">
            <div class="lpm-metric-label">Boxes</div>
            <div class="lpm-metric-value">@_rows.Count.ToString("N0")</div>
            <div class="lpm-metric-sub">@(_rows.Count >= _topLimit ? "capped at " + _topLimit.ToString("N0") : "result rows")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-purple">
            <div class="lpm-metric-label">Pallets</div>
            <div class="lpm-metric-value">@_rows.Select(r => r.PalletNo).Distinct().Count().ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-green">
            <div class="lpm-metric-label">Warehouses</div>
            <div class="lpm-metric-value">@_rows.Select(r => r.Warehouse).Distinct().Count().ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-amber">
            <div class="lpm-metric-label">Total Qty</div>
            <div class="lpm-metric-value">@_rows.Sum(r => r.Qty).ToString("N0")</div>
        </div></MudItem>
    </MudGrid>

    <MudTable T="WhBoxRow" Items="_rows" Hover="true" Striped="true" Dense="true"
              FixedHeader="true" Height="62vh" AllowUnsorted="false"
              Class="lpm-wh-table lpm-wh-table-box">
        <HeaderContent>
            <MudTh>Country
                <span class="lpm-th-total is-count">@_rows.Select(r => r.Country).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.Warehouse" InitialDirection="SortDirection.Ascending">Warehouse</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.Warehouse).Distinct().Count() distinct</span>
            </MudTh>
            @* ContNo (container number) — sits before PalletNo so the row reads
               container → pallet → box, top-down. *@
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.ContNo ?? string.Empty">ContNo</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.ContNo).Where(c => !string.IsNullOrEmpty(c)).Distinct().Count().ToString("N0") distinct</span>
            </MudTh>
            @* LPM (month value) — moved here so ContNo + LPM are visually
               grouped at the front of the row. *@
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.LPM ?? string.Empty">LPM</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.LPM).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.PalletNo">Pallet No</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.PalletNo).Distinct().Count().ToString("N0") distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.BoxNo">Box No</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.BoxNo).Distinct().Count().ToString("N0") distinct</span>
            </MudTh>
            @* Qty sits right after Box No so each box's count is visible
               without scrolling past Pallet Type / Type Name / Division etc. *@
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.Qty">Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_rows.Sum(r => r.Qty).ToString("N0")</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.PalletType">Pallet Type</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.PalletType).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.TypeName ?? string.Empty">Type Name</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.TypeName).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.PalletCategory ?? string.Empty">Pallet Category</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.PalletCategory).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.Division ?? string.Empty">Division</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.Division).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.Department ?? string.Empty">Department</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.Department).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.Brand ?? string.Empty">Brand</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.Brand).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh><MudTableSortLabel T="WhBoxRow" SortBy="r => r.Rack ?? string.Empty">Rack</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_rows.Select(r => r.Rack).Distinct().Count() distinct</span>
            </MudTh>
            <MudTh>Purchased
                <span class="lpm-th-total is-count">@_rows.Count(r => r.Purchased == "N").ToString("N0") = N</span>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Country</MudTd>
            <MudTd>@context.Warehouse</MudTd>
            <MudTd>@context.ContNo</MudTd>
            <MudTd>@context.LPM</MudTd>
            <MudTd><code>@context.PalletNo</code></MudTd>
            <MudTd><code>@context.BoxNo</code></MudTd>
            <MudTd Style="text-align:right;">@context.Qty.ToString("N0")</MudTd>
            <MudTd>@context.PalletType</MudTd>
            <MudTd>@context.TypeName</MudTd>
            <MudTd>@context.PalletCategory</MudTd>
            <MudTd>@context.Division</MudTd>
            <MudTd>@context.Department</MudTd>
            <MudTd>@context.Brand</MudTd>
            <MudTd>@context.Rack</MudTd>
            <MudTd>@context.Purchased</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
        </PagerContent>
    </MudTable>
}
else if (_groupBy == WhGroupBy.Division && _divRows.Count > 0)
{
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-blue">
            <div class="lpm-metric-label">Divisions</div>
            <div class="lpm-metric-value">@_divRows.Count.ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-amber">
            <div class="lpm-metric-label">LPM Current Qty</div>
            <div class="lpm-metric-value">@_divRows.Sum(r => r.LPMCurrentQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-purple">
            <div class="lpm-metric-label">LPM Future Qty</div>
            <div class="lpm-metric-value">@_divRows.Sum(r => r.LPMFutureQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-green">
            <div class="lpm-metric-label">Non-LPM Qty</div>
            <div class="lpm-metric-value">@_divRows.Sum(r => r.NonLPMQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="12" sm="8" md="4"><div class="lpm-metric-card lpm-accent-rose">
            <div class="lpm-metric-label">Total Qty</div>
            <div class="lpm-metric-value">@_divRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty).ToString("N0")</div>
        </div></MudItem>
    </MudGrid>

    <MudTable T="WhDivisionRow" Items="_divRows" Hover="true" Striped="true" Dense="true"
              FixedHeader="true" Height="62vh" Class="lpm-wh-table">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="WhDivisionRow" SortBy="r => r.Division ?? string.Empty" InitialDirection="SortDirection.Ascending">Division</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_divRows.Count divisions</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDivisionRow" SortBy="r => r.LPMCurrentQty">LPM Qty Current</MudTableSortLabel>
                <span class="lpm-th-total">@_divRows.Sum(r => r.LPMCurrentQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDivisionRow" SortBy="r => r.LPMFutureQty">LPM Future Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_divRows.Sum(r => r.LPMFutureQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDivisionRow" SortBy="r => r.NonLPMQty">Non-LPM Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_divRows.Sum(r => r.NonLPMQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDivisionRow" SortBy="r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty">Total Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_divRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty).ToString("N0")</span></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@(context.Division ?? "(no division)")</MudTd>
            <MudTd Style="text-align:right;">@context.LPMCurrentQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.LPMFutureQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.NonLPMQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@((context.LPMCurrentQty + context.LPMFutureQty + context.NonLPMQty).ToString("N0"))</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
        </PagerContent>
    </MudTable>
}
else if (_groupBy == WhGroupBy.Department && _deptRows.Count > 0)
{
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-blue">
            <div class="lpm-metric-label">Department rows</div>
            <div class="lpm-metric-value">@_deptRows.Count.ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-amber">
            <div class="lpm-metric-label">LPM Current Qty</div>
            <div class="lpm-metric-value">@_deptRows.Sum(r => r.LPMCurrentQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-purple">
            <div class="lpm-metric-label">LPM Future Qty</div>
            <div class="lpm-metric-value">@_deptRows.Sum(r => r.LPMFutureQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-green">
            <div class="lpm-metric-label">Non-LPM Qty</div>
            <div class="lpm-metric-value">@_deptRows.Sum(r => r.NonLPMQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="12" sm="8" md="4"><div class="lpm-metric-card lpm-accent-rose">
            <div class="lpm-metric-label">Total Qty</div>
            <div class="lpm-metric-value">@_deptRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty).ToString("N0")</div>
        </div></MudItem>
    </MudGrid>

    <MudTable T="WhDepartmentRow" Items="_deptRows" Hover="true" Striped="true" Dense="true"
              FixedHeader="true" Height="62vh" Class="lpm-wh-table">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="WhDepartmentRow" SortBy="r => r.Division ?? string.Empty" InitialDirection="SortDirection.Ascending">Division</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_deptRows.Select(r => r.Division).Distinct().Count() distinct</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDepartmentRow" SortBy="r => r.Department ?? string.Empty">Department</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_deptRows.Count rows</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDepartmentRow" SortBy="r => r.LPMCurrentQty">LPM Qty Current</MudTableSortLabel>
                <span class="lpm-th-total">@_deptRows.Sum(r => r.LPMCurrentQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDepartmentRow" SortBy="r => r.LPMFutureQty">LPM Future Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_deptRows.Sum(r => r.LPMFutureQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDepartmentRow" SortBy="r => r.NonLPMQty">Non-LPM Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_deptRows.Sum(r => r.NonLPMQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhDepartmentRow" SortBy="r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty">Total Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_deptRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty).ToString("N0")</span></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@(context.Division ?? "(no division)")</MudTd>
            <MudTd>@(context.Department ?? "(no department)")</MudTd>
            <MudTd Style="text-align:right;">@context.LPMCurrentQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.LPMFutureQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.NonLPMQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@((context.LPMCurrentQty + context.LPMFutureQty + context.NonLPMQty).ToString("N0"))</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
        </PagerContent>
    </MudTable>
}
else if (_groupBy == WhGroupBy.Brand && _brandRows.Count > 0)
{
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-blue">
            <div class="lpm-metric-label">Brand rows</div>
            <div class="lpm-metric-value">@_brandRows.Count.ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-amber">
            <div class="lpm-metric-label">LPM Current Qty</div>
            <div class="lpm-metric-value">@_brandRows.Sum(r => r.LPMCurrentQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-purple">
            <div class="lpm-metric-label">LPM Future Qty</div>
            <div class="lpm-metric-value">@_brandRows.Sum(r => r.LPMFutureQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" sm="4" md="2"><div class="lpm-metric-card lpm-accent-green">
            <div class="lpm-metric-label">Non-LPM Qty</div>
            <div class="lpm-metric-value">@_brandRows.Sum(r => r.NonLPMQty).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="12" sm="8" md="4"><div class="lpm-metric-card lpm-accent-rose">
            <div class="lpm-metric-label">Total Qty</div>
            <div class="lpm-metric-value">@_brandRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty).ToString("N0")</div>
        </div></MudItem>
    </MudGrid>

    <MudTable T="WhBrandRow" Items="_brandRows" Hover="true" Striped="true" Dense="true"
              FixedHeader="true" Height="62vh" Class="lpm-wh-table">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.Division ?? string.Empty" InitialDirection="SortDirection.Ascending">Division</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_brandRows.Select(r => r.Division).Distinct().Count() distinct</span></MudTh>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.Department ?? string.Empty">Department</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_brandRows.Select(r => r.Department).Distinct().Count() distinct</span></MudTh>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.Brand ?? string.Empty">Brand</MudTableSortLabel>
                <span class="lpm-th-total is-count">@_brandRows.Count rows</span></MudTh>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.LPMCurrentQty">LPM Qty Current</MudTableSortLabel>
                <span class="lpm-th-total">@_brandRows.Sum(r => r.LPMCurrentQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.LPMFutureQty">LPM Future Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_brandRows.Sum(r => r.LPMFutureQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.NonLPMQty">Non-LPM Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_brandRows.Sum(r => r.NonLPMQty).ToString("N0")</span></MudTh>
            <MudTh><MudTableSortLabel T="WhBrandRow" SortBy="r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty">Total Qty</MudTableSortLabel>
                <span class="lpm-th-total">@_brandRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty).ToString("N0")</span></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@(context.Division ?? "(no division)")</MudTd>
            <MudTd>@(context.Department ?? "(no department)")</MudTd>
            <MudTd>@(context.Brand ?? "(no brand)")</MudTd>
            <MudTd Style="text-align:right;">@context.LPMCurrentQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.LPMFutureQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;">@context.NonLPMQty.ToString("N0")</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@((context.LPMCurrentQty + context.LPMFutureQty + context.NonLPMQty).ToString("N0"))</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
        </PagerContent>
    </MudTable>
}
else if (_loadedOnce && !_loading)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No rows match the current filters.</MudAlert>
}
else if (!_loadedOnce)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Apply one or more filters (leave blank for All) and click <strong>Load</strong>.
        Narrow the scope to a single Warehouse for fastest results &mdash; the underlying table has 700k+ rows.
    </MudAlert>
}

@code {
    private List<string> _countries        = new() { "UAE" };  // seeded with UAE so the dropdown is non-empty even before load
    private List<string> _warehouses       = new();
    private List<string> _typeNames        = new();
    private List<string> _palletCategories = new();
    private List<string> _lpms             = new();
    private List<string> _divisions        = new();
    private List<string> _departments      = new();
    private List<string> _brands           = new();
    private List<string> _contNos          = new();

    // Per-filter selection sets — these back the 8 MultiSelectFilter
    // dropdowns added in 1.11.0. Empty set = no filter (every value passes).
    // When the planner clicks Load, BuildFilter() packs these into a fresh
    // WhBoxFilter to hand off to WarehouseQueryService.
    private HashSet<string> _selectedWarehouses        = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedTypeNames         = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedPalletCategories  = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedLpms              = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedDivisions         = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedDepartments       = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedBrands            = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedContNos           = new(StringComparer.OrdinalIgnoreCase);

    // Result sets — only one is populated per Load depending on _groupBy.
    private List<WhBoxRow>        _rows       = new();
    private List<WhDivisionRow>   _divRows    = new();
    private List<WhDepartmentRow> _deptRows   = new();
    private List<WhBrandRow>      _brandRows  = new();

    // Scalar filter state — Country (single), Search (free-text),
    // LpmStatus (enum), IncludeNonPurchased (checkbox). These stay
    // single-value by design (see Q1/Q2 in the 1.11.0 spec).
    private string _country = "UAE";
    private string? _search = null;
    private LpmPresence _lpmStatus = LpmPresence.Any;
    private bool _includeNonPurchased = false;

    /// <summary>
    /// Pack the current state into a WhBoxFilter for the query service.
    /// Empty HashSets become null so the IN-clause helper drops the
    /// filter entirely (no AND col IN () fragment).
    /// </summary>
    private WhBoxFilter BuildFilter() => new(
        Warehouse:           _selectedWarehouses.Count == 0       ? null : _selectedWarehouses.ToList(),
        TypeName:            _selectedTypeNames.Count == 0        ? null : _selectedTypeNames.ToList(),
        PalletCategory:      _selectedPalletCategories.Count == 0 ? null : _selectedPalletCategories.ToList(),
        Lpm:                 _selectedLpms.Count == 0             ? null : _selectedLpms.ToList(),
        Search:              _search,
        LpmStatus:           _lpmStatus,
        Division:            _selectedDivisions.Count == 0        ? null : _selectedDivisions.ToList(),
        Department:          _selectedDepartments.Count == 0      ? null : _selectedDepartments.ToList(),
        Brand:               _selectedBrands.Count == 0           ? null : _selectedBrands.ToList(),
        IncludeNonPurchased: _includeNonPurchased,
        ContNo:              _selectedContNos.Count == 0          ? null : _selectedContNos.ToList(),
        Country:             _country);

    /// <summary>
    /// Country dropdown handler — kept as a named method (instead of inline in
    /// the Razor attribute) so the "UAE" string literal doesn't have to be
    /// escaped to survive Razor's attribute-value parser.
    ///
    /// <para>
    /// Country also drives the data source: UAE → racks.dbo.whboxitems;
    /// other countries → [&lt;DataName&gt;].dbo.WHBoxItemsExport. So when it
    /// changes we reload the country-specific dropdowns (Warehouse, LPM,
    /// ContNo, Brand) and clear any filter values from the previous country
    /// that may not exist in the new country's box data. The global
    /// dropdowns (Type Name, Pallet Category, Division, Department) come
    /// from master tables that don't change with country, so we leave them
    /// as-is.
    /// </para>
    /// </summary>
    private async Task OnCountryChanged(string? v)
    {
        _country = string.IsNullOrWhiteSpace(v) ? "UAE" : v;
        // Reset country-specific filter selections — the previously-selected
        // warehouse/LPM/ContNo/Brand may not exist in the new country's data.
        _selectedWarehouses.Clear();
        _selectedLpms.Clear();
        _selectedContNos.Clear();
        _selectedBrands.Clear();
        try
        {
            _warehouses = await Warehouse.GetWarehousesAsync(_country);
            _lpms       = await Warehouse.GetLpmsAsync(_country);
            _contNos    = await Warehouse.GetContNosAsync(_country);
            _brands     = await Warehouse.GetDistinctBrandsAsync(_country);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load filter lists for {_country}: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }
    private WhGroupBy   _groupBy = WhGroupBy.Box;
    private bool _loading;
    private bool _loadedOnce;
    private readonly int _topLimit = 200000;

    /// <summary>True when the current Group By has results worth exporting.</summary>
    private bool HasResults => _groupBy switch
    {
        WhGroupBy.Box        => _rows.Count > 0,
        WhGroupBy.Division   => _divRows.Count > 0,
        WhGroupBy.Department => _deptRows.Count > 0,
        WhGroupBy.Brand      => _brandRows.Count > 0,
        _                    => false,
    };

    /// <summary>
    /// Returns "lpm-filter-active" when the value is non-default, "" otherwise.
    /// Drives the yellow filter-highlight CSS in app.css so the planner can
    /// see at a glance which filters are in effect.
    /// </summary>
    private static string ActiveCls(string? v) => string.IsNullOrEmpty(v) ? "" : "lpm-filter-active";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _countries        = await Warehouse.GetCountriesAsync();
            _warehouses       = await Warehouse.GetWarehousesAsync();
            _typeNames        = await Warehouse.GetTypeNamesAsync();
            _palletCategories = await Warehouse.GetPalletCategoriesAsync();
            _lpms             = await Warehouse.GetLpmsAsync();
            _divisions        = await Warehouse.GetDistinctDivisionsAsync();
            _departments      = await Warehouse.GetDistinctDepartmentsAsync();
            _brands           = await Warehouse.GetDistinctBrandsAsync();
            _contNos          = await Warehouse.GetContNosAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load filter lists: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Build an Excel workbook from the currently-loaded result set and trigger
    /// a browser download via UploadHelpers.DownloadAsync. Sheet content depends
    /// on the active Group By so the user gets the same shape they're seeing.
    /// </summary>
    private async Task ExportExcelAsync()
    {
        if (!HasResults)
        {
            Snackbar.Add("Nothing to export — Load a result first.", Severity.Info);
            return;
        }
        try
        {
            using var wb = new XLWorkbook();
            var fileName = $"WarehouseBoxes_{_groupBy}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";

            switch (_groupBy)
            {
                case WhGroupBy.Box:
                {
                    var ws = wb.Worksheets.Add("Box Detail");
                    // Column order mirrors the on-screen Box Detail table:
                    //   ContNo + LPM moved to the front (after Warehouse) so
                    //   the row reads container → pallet → box, top-down.
                    string[] headers = { "Country", "Warehouse", "ContNo", "LPM",
                        "Pallet No", "Box No", "Qty",
                        "Pallet Type", "Type Name", "Pallet Category", "Division",
                        "Department", "Brand", "Rack", "Purchased" };
                    for (int i = 0; i < headers.Length; i++)
                        ws.Cell(1, i + 1).Value = headers[i];
                    ws.Range(1, 1, 1, headers.Length).Style.Font.Bold = true;
                    int row = 2;
                    foreach (var r in _rows)
                    {
                        ws.Cell(row, 1).Value  = r.Country;
                        ws.Cell(row, 2).Value  = r.Warehouse;
                        ws.Cell(row, 3).Value  = r.ContNo ?? "";
                        ws.Cell(row, 4).Value  = r.LPM ?? "";
                        ws.Cell(row, 5).Value  = r.PalletNo;
                        ws.Cell(row, 6).Value  = r.BoxNo;
                        ws.Cell(row, 7).Value  = r.Qty;
                        ws.Cell(row, 8).Value  = r.PalletType;
                        ws.Cell(row, 9).Value  = r.TypeName ?? "";
                        ws.Cell(row, 10).Value = r.PalletCategory ?? "";
                        ws.Cell(row, 11).Value = r.Division ?? "";
                        ws.Cell(row, 12).Value = r.Department ?? "";
                        ws.Cell(row, 13).Value = r.Brand ?? "";
                        ws.Cell(row, 14).Value = r.Rack ?? "";
                        ws.Cell(row, 15).Value = r.Purchased ?? "";
                        row++;
                    }
                    ws.Columns().AdjustToContents();
                    break;
                }
                case WhGroupBy.Division:
                {
                    var ws = wb.Worksheets.Add("By Division");
                    string[] headers = { "Division", "LPM Current Qty", "LPM Future Qty", "Non-LPM Qty", "Total Qty" };
                    for (int i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
                    ws.Range(1, 1, 1, headers.Length).Style.Font.Bold = true;
                    int row = 2;
                    foreach (var r in _divRows)
                    {
                        ws.Cell(row, 1).Value = r.Division ?? "(no division)";
                        ws.Cell(row, 2).Value = r.LPMCurrentQty;
                        ws.Cell(row, 3).Value = r.LPMFutureQty;
                        ws.Cell(row, 4).Value = r.NonLPMQty;
                        ws.Cell(row, 5).Value = r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty;
                        row++;
                    }
                    // Totals row at the bottom — bold.
                    ws.Cell(row, 1).Value = "TOTAL";
                    ws.Cell(row, 2).Value = _divRows.Sum(r => r.LPMCurrentQty);
                    ws.Cell(row, 3).Value = _divRows.Sum(r => r.LPMFutureQty);
                    ws.Cell(row, 4).Value = _divRows.Sum(r => r.NonLPMQty);
                    ws.Cell(row, 5).Value = _divRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty);
                    ws.Range(row, 1, row, 5).Style.Font.Bold = true;
                    ws.Columns().AdjustToContents();
                    break;
                }
                case WhGroupBy.Department:
                {
                    var ws = wb.Worksheets.Add("By Department");
                    string[] headers = { "Division", "Department", "LPM Current Qty", "LPM Future Qty", "Non-LPM Qty", "Total Qty" };
                    for (int i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
                    ws.Range(1, 1, 1, headers.Length).Style.Font.Bold = true;
                    int row = 2;
                    foreach (var r in _deptRows)
                    {
                        ws.Cell(row, 1).Value = r.Division ?? "(no division)";
                        ws.Cell(row, 2).Value = r.Department ?? "(no department)";
                        ws.Cell(row, 3).Value = r.LPMCurrentQty;
                        ws.Cell(row, 4).Value = r.LPMFutureQty;
                        ws.Cell(row, 5).Value = r.NonLPMQty;
                        ws.Cell(row, 6).Value = r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty;
                        row++;
                    }
                    ws.Cell(row, 1).Value = "TOTAL";
                    ws.Cell(row, 3).Value = _deptRows.Sum(r => r.LPMCurrentQty);
                    ws.Cell(row, 4).Value = _deptRows.Sum(r => r.LPMFutureQty);
                    ws.Cell(row, 5).Value = _deptRows.Sum(r => r.NonLPMQty);
                    ws.Cell(row, 6).Value = _deptRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty);
                    ws.Range(row, 1, row, 6).Style.Font.Bold = true;
                    ws.Columns().AdjustToContents();
                    break;
                }
                case WhGroupBy.Brand:
                {
                    var ws = wb.Worksheets.Add("By Brand");
                    string[] headers = { "Division", "Department", "Brand", "LPM Current Qty", "LPM Future Qty", "Non-LPM Qty", "Total Qty" };
                    for (int i = 0; i < headers.Length; i++) ws.Cell(1, i + 1).Value = headers[i];
                    ws.Range(1, 1, 1, headers.Length).Style.Font.Bold = true;
                    int row = 2;
                    foreach (var r in _brandRows)
                    {
                        ws.Cell(row, 1).Value = r.Division ?? "(no division)";
                        ws.Cell(row, 2).Value = r.Department ?? "(no department)";
                        ws.Cell(row, 3).Value = r.Brand ?? "(no brand)";
                        ws.Cell(row, 4).Value = r.LPMCurrentQty;
                        ws.Cell(row, 5).Value = r.LPMFutureQty;
                        ws.Cell(row, 6).Value = r.NonLPMQty;
                        ws.Cell(row, 7).Value = r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty;
                        row++;
                    }
                    ws.Cell(row, 1).Value = "TOTAL";
                    ws.Cell(row, 4).Value = _brandRows.Sum(r => r.LPMCurrentQty);
                    ws.Cell(row, 5).Value = _brandRows.Sum(r => r.LPMFutureQty);
                    ws.Cell(row, 6).Value = _brandRows.Sum(r => r.NonLPMQty);
                    ws.Cell(row, 7).Value = _brandRows.Sum(r => r.LPMCurrentQty + r.LPMFutureQty + r.NonLPMQty);
                    ws.Range(row, 1, row, 7).Style.Font.Bold = true;
                    ws.Columns().AdjustToContents();
                    break;
                }
            }

            await UploadHelpers.DownloadAsync(JS, wb, fileName);
            Snackbar.Add($"Exported {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private static Task<IEnumerable<string>> Search(List<string> source, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(source.Take(50));
        return Task.FromResult<IEnumerable<string>>(source
            .Where(s => s.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(50));
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        var started = DateTime.Now;
        var filter = BuildFilter();
        // Clear ALL result sets so a previous Group By's rows don't leak into
        // the new view if the user switches mode without re-Loading.
        _rows.Clear(); _divRows.Clear(); _deptRows.Clear(); _brandRows.Clear();
        try
        {
            int rowCount;
            switch (_groupBy)
            {
                case WhGroupBy.Box:
                    _rows = await Warehouse.GetBoxesAsync(filter, _topLimit);
                    rowCount = _rows.Count;
                    if (rowCount >= _topLimit)
                        Snackbar.Add($"Result capped at {_topLimit:N0} rows. Narrow the filter to see more.", Severity.Warning);
                    break;
                case WhGroupBy.Division:
                    _divRows = await Warehouse.GetDivisionSummaryAsync(filter);
                    rowCount = _divRows.Count;
                    break;
                case WhGroupBy.Department:
                    _deptRows = await Warehouse.GetDepartmentSummaryAsync(filter);
                    rowCount = _deptRows.Count;
                    break;
                case WhGroupBy.Brand:
                    _brandRows = await Warehouse.GetBrandSummaryAsync(filter);
                    rowCount = _brandRows.Count;
                    break;
                default:
                    rowCount = 0;
                    break;
            }
            _loadedOnce = true;

            await ActionLog.LogAsync(
                "WarehouseBoxes.Load",
                $"{started:yyyyMMddHHmmss}",
                new { groupBy = _groupBy.ToString(), filter = filter, rows = rowCount, elapsedMs = (int)(DateTime.Now - started).TotalMilliseconds });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load failed: {ex.Message}", Severity.Error);
            await ActionLog.LogAsync(
                "WarehouseBoxes.Load",
                $"{started:yyyyMMddHHmmss}-error",
                new { groupBy = _groupBy.ToString(), filter = filter, error = ex.Message });
        }
        finally
        {
            _loading = false; StateHasChanged();
        }
    }
}
