@page "/lpm/eom/generate"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.AdminOrEditor)]
@using LpmSim.Data.Eom
@using ClosedXML.Excel
@using System.IO
@inject IDbContextFactory<LpmDbContext> DbFactory
@inject EomCalculator Eom
@inject ICurrentUser CurrentUser
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>EOM Generate</PageTitle>

<div class="lpm-page-title">EOM Generate</div>
<div class="lpm-page-subtitle">
    Run the end-of-month calculation for a country. The engine applies the 6-step logic from the spec and
    writes results to <code>LPM_EOM_Output</code>. A preview is shown before anything is committed.
</div>

<MudExpansionPanels Elevation="0" Class="mb-3">
    <MudExpansionPanel Text="Column logic — how each column is computed" Icon="@Icons.Material.Filled.Info">
        <div style="font-size:0.86rem;line-height:1.55;color:#1f2937;">
            <table style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr style="background:#f1f5f9;">
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;width:18%;">Column</th>
                        <th style="text-align:left;padding:6px 10px;border:1px solid #e2e8f0;">Formula / Source</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Store</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Active stores from <code>DataSettings</code> for the selected Country (<code>ActiveStore = 'Y'</code>).</td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Division</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">Division name from <code>Division.DivCode → Division.Division</code>. The grid produces one row per <code>(Store, Division)</code> pair.</td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Wt Avg Sold</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>Per-period (monthly) weighted average</strong> of historical sold quantity
                            over the periods configured in <code>LPM_MonthlyWeight</code>:
                            <br/>
                            <code>Wt Avg Sold Qty = SUM( SoldQty(p) × WeightPct(p) ) ÷ N</code>
                            <br/>
                            where <code>N = COUNT of periods p in LPM_MonthlyWeight with WeightPct &gt; 0</code>.
                            <br/>
                            <span style="color:#64748b;font-size:.8rem;">
                                We divide by the period count <strong>N</strong>, NOT by
                                <code>SUM(WeightPct)</code>. The result is the average monthly weighted SoldQty,
                                already on a per-period scale — easier to compare across runs that use a
                                different number of weighting periods.
                            </span>
                            <br/>
                            <strong>Worked example.</strong> 3 periods, weights 0.2 / 0.3 / 0.5:
                            <table style="margin-top:.3rem;font-size:.82rem;border-collapse:collapse;">
                                <tr style="background:#f1f5f9;">
                                    <th style="padding:3px 8px;border:1px solid #e2e8f0;">Period</th>
                                    <th style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">SoldQty</th>
                                    <th style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">WeightPct</th>
                                    <th style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">SoldQty × Wt</th>
                                </tr>
                                <tr><td style="padding:3px 8px;border:1px solid #e2e8f0;">Nov-25</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">200</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">0.20</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">40</td></tr>
                                <tr><td style="padding:3px 8px;border:1px solid #e2e8f0;">Dec-25</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">300</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">0.30</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">90</td></tr>
                                <tr><td style="padding:3px 8px;border:1px solid #e2e8f0;">Jan-26</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">500</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">0.50</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">250</td></tr>
                                <tr style="font-weight:600;background:#fef9c3;">
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;">SUM</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">—</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">1.00</td>
                                    <td style="padding:3px 8px;border:1px solid #e2e8f0;text-align:right;">380</td></tr>
                            </table>
                            <code>Wt Avg Sold = 380 ÷ 3 = 126.67</code>
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Wt Avg Turn</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Same recipe applied to <code>TurnsQty</code>:
                            <br/>
                            <code>Wt Avg Turn = SUM( TurnsQty(p) × WeightPct(p) ) ÷ N</code>
                            <br/>
                            where <code>N</code> = count of periods with <code>WeightPct &gt; 0</code>.
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Pri Rank</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Per-Division priority — derived from two intermediate ranks.
                            Each rank is computed using <strong>competition ranking</strong>
                            (ties share a rank, next distinct value skips), and is <strong>only assigned when the source value is &gt; 0</strong>;
                            stores with a zero source value get rank = 0 (no rank).
                            <ul style="margin:.3rem 0 .3rem 1.1rem;">
                                <li><code>SoldQtyRank</code> — rank by <code>Wt Avg Sold</code> <strong>desc</strong> (highest seller = 1) — applied only where <code>Wt Avg Sold &gt; 0</code>.</li>
                                <li><code>TurnsRank</code> — rank by <code>Wt Avg Turn</code> <strong>asc</strong> (lowest turn = 1) — applied only where <code>Wt Avg Turn &gt; 0</code>.</li>
                            </ul>
                            Then:
                            <ul style="margin:.3rem 0 .3rem 1.1rem;">
                                <li>Both &gt; 0 &nbsp;→ &nbsp;<code>PriorityRank = (SoldQtyRank + TurnsRank) / 2</code></li>
                                <li>Only Sold &gt; 0 &nbsp;→ &nbsp;<code>PriorityRank = SoldQtyRank</code></li>
                                <li>Only Turn &gt; 0 &nbsp;→ &nbsp;<code>PriorityRank = TurnsRank</code></li>
                                <li>Both = 0 &nbsp;→ &nbsp;<code>PriorityRank = 0</code> &nbsp;(no historical signal — store is unranked)</li>
                            </ul>
                            Lower number = higher priority. SIM Generate fills the Division by <code>PriorityRank ASC</code>,
                            tiebreak <code>Wt Avg Sold DESC</code>.
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Grade</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Per-Division grade bucket. Within each Division, ranked stores are ordered by
                            <code>PriorityRank ASC, Wt Avg Sold DESC</code> and bucketed by <code>LPM_StoreGrade.SharePct</code>
                            (e.g. top 20% → Grade A, next 30% → Grade B, …). Each grade carries a <code>MarkupPct</code>
                            that <strong>reduces</strong> <code>Tgt Turn</code> via <code>× (1 − MarkupPct)</code> — premium
                            grades get a lower turn target.
                            <br/><strong>Stores with <code>PriorityRank = 0</code> are skipped</strong> — they have no
                            historical signal (both <code>Wt Avg Sold</code> and <code>Wt Avg Turn</code> are zero), so they
                            stay unranked: <code>Grade</code> = blank, no markup, <code>Tgt Sales = 0</code> and <code>Tgt EOM = 0</code>.
                            SIM Generate doesn't allocate to them anyway (zero EOM headroom).
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Tgt Turn</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <code>Tgt Turn = LPM_Planned.PlannedTurn × (1 − Grade.MarkupPct)</code>
                            <br/>
                            <span style="color:#64748b;font-size:.8rem;">
                                Starts from the per-Division <code>PlannedTurn</code> (keyed on Country + DivCode +
                                Year + Month) and reduces it by the store's grade-specific markup, so premium
                                grades get a lower (slower) turn target. Example: <code>PlannedTurn = 4.0</code>,
                                <code>MarkupPct = 0.10</code> → <code>Tgt Turn = 3.6</code>.
                                <br/>
                                When the store has no Grade (or the Grade isn't in <code>LPM_StoreGrade</code>),
                                <code>MarkupPct</code> defaults to 0, so <code>Tgt Turn = PlannedTurn</code>.
                                <code>Wt Avg Turn</code> is <strong>not</strong> the base — it's only used in
                                <code>TurnsRank</code> for the priority calculation.
                            </span>
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Tgt Sales</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Per-Division <code>LPM_Planned.PlannedSalesQty</code> (keyed on Country + DivCode +
                            Year + Month) apportioned across the stores in that Division by their share of
                            the Division's weighted-average sales:
                            <br/>
                            <code>Tgt Sales = (Wt Avg Sold / Σ Wt Avg Sold in Division) × PlannedSalesQty</code>
                            <br/>
                            <span style="color:#64748b;font-size:.8rem;">
                                Note: <code>Grade.SharePct</code> and <code>VolumeGroup.SharePct</code> do
                                <strong>not</strong> appear in this formula. SharePct is used only to
                                <em>bucket</em> stores into Grades (Step 2) and Volume Groups (Step 5);
                                Grade then influences <code>Tgt Turn</code> via <code>MarkupPct</code>,
                                and Volume Group drives the SKU Max range lookup. Neither shrinks
                                <code>Tgt Sales</code>. This way, <code>Σ Tgt Sales</code> across the
                                Division reconciles back to <code>PlannedSalesQty</code>.
                            </span>
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Tgt EOM</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            <strong>Per-store end-of-month target stock</strong>, apportioned across the stores
                            in the Division by their share of weighted-average sales:
                            <br/>
                            <code>Tgt EOM[store] = (Wt Avg Sold[store] ÷ Σ Wt Avg Sold in Division) × LPM_Planned.PlannedEOM</code>
                            <br/>
                            <span style="color:#64748b;font-size:.8rem;">
                                Same shape as Tgt Sales — just apportions <code>PlannedEOM</code> instead of
                                <code>PlannedSalesQty</code>. So a store's Tgt EOM <em>share</em> equals its
                                Tgt Sales <em>share</em> within the Division.
                                <br/>
                                <strong>Reconciliation:</strong> <code>Σ Tgt EOM(Division) = PlannedEOM(Division)</code>.
                                <br/>
                                <strong>Note on Grade markup:</strong> markup affects Tgt Turn (premium grades
                                turn slower) but is no longer fed into Tgt EOM. The EOM share is purely sales-driven.
                            </span>
                            <br/>
                            <strong>SIM use:</strong> this is the hard cap SIM Generate honours when filling boxes —
                            the per-store EOM headroom is <code>TargetEOM − DivSOH</code>; SIM stops adding to a
                            (Store, Div) the moment cumulative allocation reaches that.
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>Vol Grp</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Per-Division volume-group bucket. Stores in each Division are sorted by
                            <code>Tgt EOM DESC</code> and bucketed by <code>LPM_VolumeGroup.SharePct</code>
                            (top X% → Group A, next Y% → Group B, …).
                            <br/>
                            <strong>Used only for the <code>SKU Max</code> rule lookup</strong> — the
                            <code>(Country, DivCode, GroupCode, WHStock range)</code> key picks the per-item cap.
                            It does <strong>not</strong> appear in <code>Tgt Sales</code> or <code>Tgt EOM</code>;
                            both of those have already been computed by Step 4.
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>WH Summer / WH Winter</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            Eligible warehouse stock per Division, computed <strong>live from <code>racks.dbo.whboxitems</code></strong>
                            using the same eligibility filters SIM Generate uses:
                            <ul style="margin:.3rem 0 .3rem 1.1rem;">
                                <li><code>pt.PalletCategory = 'ELIGIBLE'</code></li>
                                <li><code>ShopEligible &lt;&gt; 'E'</code></li>
                                <li><strong>LPM</strong>: <code>LPMDt</code> set AND year/month on or before run period &nbsp;·&nbsp;
                                    <strong>Non-LPM</strong>: <code>LPMDt IS NULL</code> &nbsp;(both included)</li>
                            </ul>
                            Split by <code>pallettype.Season</code>: <code>'W'</code> → Winter column, otherwise Summer.
                            Item → Division comes from <code>Datareporting.upc_subclass × subclassmaster × Division</code>
                            (<code>MIN(DivCode)</code> per item — same rule SIM uses).
                            <br/>The legacy <code>LPM_WHStock</code> table is no longer consulted by EOM. The combined
                            value <code>WHStock = Summer + Winter</code> still drives the SKU Max range lookup below.
                        </td></tr>

                    <tr><td style="padding:6px 10px;border:1px solid #e2e8f0;"><strong>SKU Max</strong></td>
                        <td style="padding:6px 10px;border:1px solid #e2e8f0;">
                            From <code>LPM_SKUMaxRule</code> matched on <code>(Country, VolumeGroup, DivCode)</code>. Per-(Store, Item) cap inside SIM Generate (<code>SKUMax − SOH − cumulative allocated</code>).
                            <br/>
                            <strong>Override:</strong> any (Country, Store, Division) row in <code>LPM_StoreDivAccess</code>
                            with <code>IsActive = 0</code> forces <code>SKUMax = 0</code> for that combination, so SIM cannot
                            allocate the division's items to that store. Manage these on
                            <strong>Planning Config → Store / Division Access</strong>; re-run EOM Generate to apply changes.
                        </td></tr>
                </tbody>
            </table>

            <div style="margin-top:0.75rem;padding:0.6rem 0.8rem;background:#fef9c3;border-radius:6px;border:1px solid #facc15;">
                <strong>Order of evaluation</strong> — each column is computed in this dependency order so a row's later
                columns can reuse earlier ones:&nbsp;
                <code>Store → Division → Wt Avg Sold/Turn → Pri Rank → Grade → Tgt Turn → Vol Grp → Tgt Sales → Tgt EOM → SKU Max</code>.
                <br/>SIM Generate then consumes <code>Tgt EOM</code> (hard cap), <code>Pri Rank</code> (fill order),
                and <code>SKU Max</code> (per-store-item cap) from this output.
            </div>
        </div>
    </MudExpansionPanel>
</MudExpansionPanels>

<div class="lpm-section">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="3">
            <MudSelect T="string" Label="Country" Value="_country"
                       ValueChanged="async v => { _country = v ?? string.Empty; await CheckAsync(); }"
                       Variant="Variant.Outlined" Clearable="true">
                @foreach (var c in _countries)
                {
                    <MudSelectItem Value="@c">@c</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudNumericField T="int" Label="Year" Value="_year"
                             ValueChanged="async (int v) => { _year = v; await CheckAsync(); }"
                             Min="2020" Max="2100" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="int" Label="Month" Value="_month"
                       ValueChanged="async (int v) => { _month = v; await CheckAsync(); }"
                       Variant="Variant.Outlined">
                @for (int m = 1; m <= 12; m++)
                {
                    var mv = m;
                    <MudSelectItem Value="mv">@(new DateTime(2000, mv, 1).ToString("MMM")) (@mv)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="5" Class="d-flex justify-end gap-2 flex-wrap">
            <MudButton Variant="Variant.Outlined" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@(string.IsNullOrEmpty(_country))" OnClick="CheckAsync">
                Re-check
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.History"
                       Disabled="@(string.IsNullOrEmpty(_country) || _running)"
                       OnClick="ViewSavedAsync">
                View Saved
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       Disabled="@(_readiness?.IsReady != true || _running)"
                       OnClick="GenerateAsync">
                Generate
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       Disabled="@(_readiness?.IsReady != true || _running)"
                       OnClick="ApproveAsync">
                Approve
            </MudButton>
        </MudItem>
    </MudGrid>
</div>

@if (_running)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
}

@if (_readiness is not null)
{
    var blockedCount = _readiness.All.Count(x => !x.Ok);
    var headerLabel  = blockedCount == 0
        ? "Input readiness — all checks passed"
        : $"Input readiness — {blockedCount} blocker(s) — click to expand";

    <MudExpansionPanels Elevation="0" Class="mb-3">
        <MudExpansionPanel Text="@headerLabel"
                           IsInitiallyExpanded="@(blockedCount > 0)"
                           Icon="@(blockedCount == 0 ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.WarningAmber)">
            <MudGrid Spacing="2">
                @foreach (var item in _readiness.All)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <div class="lpm-metric-card @(item.Ok ? "lpm-accent-green" : "lpm-accent-rose")">
                            <div class="d-flex align-center justify-space-between">
                                <div class="lpm-metric-label">@item.Label</div>
                                @if (item.Ok)
                                {
                                    <span class="lpm-status lpm-status-ok">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /> Ready
                                    </span>
                                }
                                else
                                {
                                    <span class="lpm-status lpm-status-err">
                                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" /> Blocked
                                    </span>
                                }
                            </div>
                            <div class="lpm-metric-sub" style="margin-top:0.5rem;">@item.Detail</div>
                        </div>
                    </MudItem>
                }
            </MudGrid>

            @if (!_readiness.IsReady)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-3">
                    Resolve the <strong>Blocked</strong> items above before Generate / Approve.
                </MudAlert>
            }
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@if (_preview.Count > 0)
{
    <div class="lpm-section-title mb-2 d-flex align-center gap-2">
        <span>@_previewLabel &mdash; @_preview.Count rows</span>
        @if (_savedAt is not null)
        {
            <span class="lpm-status lpm-status-ok">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                Generated @_savedAt?.ToString("yyyy-MM-dd HH:mm")
            </span>
        }
        else
        {
            <span class="lpm-status lpm-status-warn">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                Live preview &mdash; not saved
            </span>
        }
    </div>
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-blue">
            <div class="lpm-metric-label">Stores</div>
            <div class="lpm-metric-value">@_preview.Select(r => r.StoreID).Distinct().Count()</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-purple">
            <div class="lpm-metric-label">Divisions</div>
            <div class="lpm-metric-value">@_preview.Select(r => r.DivCode).Distinct().Count()</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-amber">
            <div class="lpm-metric-label">Total Target Sales</div>
            <div class="lpm-metric-value">@_preview.Sum(r => r.TargetSales).ToString("N0")</div>
        </div></MudItem>
        <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-cyan">
            <div class="lpm-metric-label">Total Target EOM</div>
            <div class="lpm-metric-value">@_preview.Sum(r => r.TargetEOM).ToString("N0")</div>
        </div></MudItem>
    </MudGrid>

    <MudTabs Elevation="0" Rounded="true" KeepPanelsAlive="true" Class="mb-3">

    @* ─── Tab 1: Store × Division (the existing detailed grid) ─────────────── *@
    <MudTabPanel Text="Store × Division" Icon="@Icons.Material.Filled.GridOn">
    <div class="lpm-section">
        <MudGrid Spacing="2" Class="mb-2 align-center">
            <MudItem xs="12" md="3">
                @* Searchable Division filter — type to narrow long lists. *@
                <MudAutocomplete T="string" Label="Filter Division"
                                 Value="_filterDivisionText"
                                 ValueChanged="OnDivisionFilterChanged"
                                 SearchFunc="SearchDivisions"
                                 Variant="Variant.Outlined"
                                 CoerceText="true" ResetValueOnEmptyText="true" Clearable="true"
                                 Placeholder="All divisions" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudAutocomplete T="string" Label="Filter Store"
                                 Value="_filterStore"
                                 ValueChanged="OnStoreFilterChanged"
                                 SearchFunc="SearchStores"
                                 Variant="Variant.Outlined"
                                 CoerceText="true" ResetValueOnEmptyText="true" Clearable="true"
                                 Placeholder="All stores" />
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" Label="Filter Grade" Value="_filterGrade"
                           ValueChanged="(string v) => { _filterGrade = v ?? string.Empty; StateHasChanged(); }"
                           Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem T="string" Value="@(string.Empty)">All grades</MudSelectItem>
                    @foreach (var g in _preview.Select(r => r.Grade ?? string.Empty)
                                                .Where(g => !string.IsNullOrEmpty(g))
                                                .Distinct().OrderBy(g => g))
                    {
                        <MudSelectItem T="string" Value="@g">@g</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" Label="Filter Vol Grp" Value="_filterVolGrp"
                           ValueChanged="(string v) => { _filterVolGrp = v ?? string.Empty; StateHasChanged(); }"
                           Variant="Variant.Outlined" Clearable="true">
                    <MudSelectItem T="string" Value="@(string.Empty)">All groups</MudSelectItem>
                    @foreach (var g in _preview.Select(r => r.VolumeGroup ?? string.Empty)
                                                .Where(g => !string.IsNullOrEmpty(g))
                                                .Distinct().OrderBy(g => g))
                    {
                        <MudSelectItem T="string" Value="@g">@g</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex justify-end">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" DropShadow="false"
                           StartIcon="@Icons.Material.Filled.Download"
                           Disabled="@(_preview.Count == 0)"
                           OnClick="ExportExcelAsync">
                    Excel
                </MudButton>
            </MudItem>
        </MudGrid>

        @{
            // Totals across whatever the filter currently shows. Average columns
            // (Wt Avg Turn, Pri Rank, Tgt Turn) skip the totals row — summing
            // averages doesn't mean anything.
            var fp           = FilteredPreview.ToList();
            // Sum the decimal values FIRST then round once at the end.
            // Casting per-row to long loses fractional parts (up to 0.5 each)
            // — with N rows that diverges from Excel's true decimal sum by
            // up to N/2 units. Rounding the total once gives a single-unit
            // ceiling difference vs. Excel.
            var totalSold    = (long)Math.Round(fp.Sum(r => r.WtAvgSoldQty), MidpointRounding.AwayFromZero);
            var totalTgtSales= (long)Math.Round(fp.Sum(r => r.TargetSales),  MidpointRounding.AwayFromZero);
            var totalTgtEom  = (long)Math.Round(fp.Sum(r => r.TargetEOM),    MidpointRounding.AwayFromZero);
            var totalSoh     = fp.Sum(r => (long)r.SOH);                      // SOH is int — no precision loss
            var totalMerchM  = fp.Sum(r => (long)r.MerchNeedMonth);           // MerchNeed* are int
            var totalMerchW  = fp.Sum(r => (long)r.MerchNeedWeek);
            var totalMerchD  = fp.Sum(r => (long)r.MerchNeedDay);
            var rowCount     = fp.Count;

            // WH Summer / Winter are per-DIVISION values repeated on every
            // store row inside that division, so a flat Sum() multiplies the
            // real warehouse stock by the store count. Group by DivCode and
            // take the value once per division to get the actual stock totals
            // visible in the current filter.
            var wsBySeason   = fp.GroupBy(r => r.DivCode)
                                 .Select(g => new { Summer = g.First().WHStockSummer,
                                                    Winter = g.First().WHStockWinter })
                                 .ToList();
            var totalWhSummer = wsBySeason.Sum(x => (long)x.Summer);
            var totalWhWinter = wsBySeason.Sum(x => (long)x.Winter);
        }

        <MudTable T="EomRow" Items="fp" Hover="true" Striped="true" Dense="true"
                  FixedHeader="true" Height="65vh" AllowUnsorted="false"
                  Class="lpm-eom-preview">
            @* Hover tooltips only on the columns the planning team specified.
               Store / Division / Sold Qty Rank / Turns Rank have no tooltip
               by design — they're self-explanatory. *@
            <HeaderContent>
                <MudTh Style="width:11%;"><div class="th-total">@rowCount.ToString("N0") rows</div>
                    <MudTableSortLabel T="EomRow" SortBy="r => r.StoreID" InitialDirection="SortDirection.Ascending">Store</MudTableSortLabel></MudTh>

                <MudTh Style="width:9%;"><div class="th-total">&nbsp;</div>
                    <MudTableSortLabel T="EomRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>

                <MudTh Style="width:6%;"><div class="th-total">@totalSold.ToString("N0")</div><span title="WtAvgSold = Avg(Sum(Monthly Actual SoldQty after applying Weights))">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.WtAvgSoldQty">Wt<br />Avg<br />Sold</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:6%;"><div class="th-total">&nbsp;</div><span title="WtAvgTurn = Avg(Sum(Monthly Actual Turns after applying Weights))">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.WtAvgTurn">Wt<br />Avg<br />Turn</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:5%;"><div class="th-total">&nbsp;</div>
                    <MudTableSortLabel T="EomRow" SortBy="r => r.SoldQtyRank">Sold<br />Qty<br />Rank</MudTableSortLabel></MudTh>

                <MudTh Style="width:5%;"><div class="th-total">&nbsp;</div>
                    <MudTableSortLabel T="EomRow" SortBy="r => r.TurnsRank">Turns<br />Rank</MudTableSortLabel></MudTh>

                <MudTh Style="width:6%;"><div class="th-total">&nbsp;</div><span title="PriRank = avg(SoldQtyrank and TurnsRank)">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.PriorityRank">Pri<br />Rank</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:7%;"><div class="th-total">&nbsp;</div><span title="Grade = Stores are ordered by PriorityRank and bucketed by Share% for each Grade">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.Grade ?? string.Empty">Grade</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:6%;"><div class="th-total">&nbsp;</div><span title="TgtTurn = PlannedTurn × (1 − Markup%) based on Grade">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.TargetTurn">Tgt<br />Turn</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:8%;"><div class="th-total">@totalTgtSales.ToString("N0")</div><span title="TargetSales = Apportion Planned Sales Qty to all stores based on % of WtAvgSoldQty over Total WtAvgSoldQty for that Division">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.TargetSales">Tgt<br />Sales</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:8%;"><div class="th-total">@totalTgtEom.ToString("N0")</div><span title="TargetEOM = Apportion Planned EOM Qty to all stores based on % of WtAvgSoldQty over Total WtAvgSoldQty for that Division">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.TargetEOM">Tgt<br />EOM</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:6%;"><div class="th-total">@totalSoh.ToString("N0")</div><span title="SOH = Sum of LPM_LocStock.SOH across all items for this (Store, Division). Source: racks.dbo.LPM_LocStock joined to active stores in DataSettings.">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:7%;"><div class="th-total">@totalMerchM.ToString("N0")</div><span title="Merch Need (Month) = TargetEOM − SOH + TargetSales. Open-to-receive: what WH must ship this month so the store ends at TargetEOM after selling TargetSales.">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.MerchNeedMonth">Merch Need<br />(Month)</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:7%;"><div class="th-total">@totalMerchW.ToString("N0")</div><span title="Merch Need (Week) = mirror of Wk1 — kept as a back-compat column for ADM / Reports / ProductionScheduler that haven't been week-aware'd yet.">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.MerchNeedWeek">Merch Need<br />(Week)</MudTableSortLabel></span></MudTh>

                @* Per-week Wk1/Wk2/Wk3/Wk4 columns were removed in 1.10.1 —
                   they were squashing the header layout. The per-week values
                   are still computed and stored on LPM_EOM_Output (Wk1..4)
                   and SIM Generate's Week dropdown still picks the right
                   one for the allocator's cap; we just don't render them on
                   this Store × Division grid. *@

                <MudTh Style="width:7%;"><div class="th-total">@totalMerchD.ToString("N0")</div><span title="Merch Need (Day) = Merch Need (Week) / 6. Reference daily slice assuming a 6-day production week.">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.MerchNeedDay">Merch Need<br />(Day)</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:7%;"><div class="th-total">&nbsp;</div><span title="VolGrp = Stores are sorted by TgtEOM and bucketed by SharePct of Volume Groups">Vol<br />Grp</span></MudTh>

                <MudTh Style="width:7%;"><div class="th-total" title="Sum of distinct Division values (not per-row, since WH Stock repeats across stores in the same Division).">@totalWhSummer.ToString("N0")</div><span title="WHSummer = Total Eligible Stock Summer per Division&#10;= SUM(Qty) for Summer-tagged eligible boxes mapped to this Division">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.WHStockSummer">WH<br />Summer</MudTableSortLabel></span></MudTh>

                <MudTh Style="width:7%;"><div class="th-total" title="Sum of distinct Division values (not per-row, since WH Stock repeats across stores in the same Division).">@totalWhWinter.ToString("N0")</div><span title="WHWinter = Total Eligible Stock Winter per Division&#10;= SUM(Qty) for Winter-tagged eligible boxes mapped to this Division">
                    <MudTableSortLabel T="EomRow" SortBy="r => r.WHStockWinter">WH<br />Winter</MudTableSortLabel></span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div style="font-weight:500;"><code>@context.StoreID</code></div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.StoreName</MudText>
                </MudTd>
                <MudTd>@context.DivisionName</MudTd>
                <MudTd>@context.WtAvgSoldQty.ToString("N0")</MudTd>
                <MudTd>@context.WtAvgTurn.ToString("N1")</MudTd>
                <MudTd>@context.SoldQtyRank</MudTd>
                <MudTd>@context.TurnsRank</MudTd>
                <MudTd>@context.PriorityRank.ToString("0.#")</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Grade</MudChip></MudTd>
                <MudTd>@context.TargetTurn.ToString("N1")</MudTd>
                <MudTd>@context.TargetSales.ToString("N0")</MudTd>
                <MudTd>@context.TargetEOM.ToString("N0")</MudTd>
                <MudTd>@context.SOH.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedMonth.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedWeek.ToString("N0")</MudTd>
                @* Wk1..Wk4 cells removed in 1.10.1 — see header comment. *@
                <MudTd>@context.MerchNeedDay.ToString("N0")</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Info">@context.VolumeGroup</MudChip></MudTd>
                <MudTd>@context.WHStockSummer.ToString("N0")</MudTd>
                <MudTd>@context.WHStockWinter.ToString("N0")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
            </PagerContent>
        </MudTable>
    </div>
    </MudTabPanel>

    @* ─── Tab 2: Store Summary — rolled up across all divisions ──────────── *@
    <MudTabPanel Text="Store Summary" Icon="@Icons.Material.Filled.Storefront">
    <div class="lpm-section">
        @{
            // Roll up all rows for the current Country to one row per Store.
            // Country scoping is implicit (the page-level _country selector
            // already filters _preview).
            var storeRoll = _preview
                .GroupBy(r => new { r.StoreID, r.StoreName })
                .Select(g => new StoreSummaryEom
                {
                    StoreID        = g.Key.StoreID,
                    StoreName      = g.Key.StoreName ?? "",
                    SOH            = g.Sum(r => (long)r.SOH),
                    // TargetEOM / TargetSales are decimal — sum first, round
                    // once at the end to match Excel's true-decimal totals.
                    // Casting per-row to long would truncate fractional parts
                    // and accumulate rounding error proportional to row count.
                    TargetEOM      = (long)Math.Round(g.Sum(r => r.TargetEOM),   MidpointRounding.AwayFromZero),
                    TargetSales    = (long)Math.Round(g.Sum(r => r.TargetSales), MidpointRounding.AwayFromZero),
                    MerchNeedMonth = g.Sum(r => (long)r.MerchNeedMonth),
                    MerchNeedWeek  = g.Sum(r => (long)r.MerchNeedWeek),
                    MerchNeedDay   = g.Sum(r => (long)r.MerchNeedDay),
                })
                .Where(s => string.IsNullOrEmpty(_filterStoreSummary)
                         || s.StoreID.Contains(_filterStoreSummary, StringComparison.OrdinalIgnoreCase)
                         || s.StoreName.Contains(_filterStoreSummary, StringComparison.OrdinalIgnoreCase))
                .OrderBy(s => s.StoreID)
                .ToList();

            var ssCount        = storeRoll.Count;
            var ssTotalSoh     = storeRoll.Sum(s => s.SOH);
            var ssTotalTgtEom  = storeRoll.Sum(s => s.TargetEOM);
            var ssTotalTgtSale = storeRoll.Sum(s => s.TargetSales);
            var ssTotalMerchM  = storeRoll.Sum(s => s.MerchNeedMonth);
            var ssTotalMerchW  = storeRoll.Sum(s => s.MerchNeedWeek);
            var ssTotalMerchD  = storeRoll.Sum(s => s.MerchNeedDay);
        }

        <MudGrid Spacing="2" Class="mb-2 align-center">
            <MudItem xs="12" md="4">
                <MudAutocomplete T="string" Label="Filter Store"
                                 Value="_filterStoreSummary"
                                 ValueChanged="(string v) => { _filterStoreSummary = v ?? string.Empty; StateHasChanged(); }"
                                 SearchFunc="SearchStores"
                                 Variant="Variant.Outlined"
                                 CoerceText="true" ResetValueOnEmptyText="true" Clearable="true"
                                 Placeholder="All stores" />
            </MudItem>
            <MudItem xs="12" md="8" Class="d-flex justify-end align-center">
                <MudText Typo="Typo.caption" Style="color:#64748b;">
                    Aggregated across all divisions for @_country @_year-@_month.ToString("D2"). Excel export above writes both tabs.
                </MudText>
            </MudItem>
        </MudGrid>

        <MudTable T="StoreSummaryEom" Items="storeRoll" Hover="true" Striped="true" Dense="true"
                  FixedHeader="true" Height="65vh" AllowUnsorted="false"
                  Class="lpm-eom-preview">
            <HeaderContent>
                <MudTh Style="width:14%;">
                    <div class="th-total">@ssCount.ToString("N0") rows</div>
                    <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.StoreID" InitialDirection="SortDirection.Ascending">Store ID</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:26%;">
                    <div class="th-total">&nbsp;</div>
                    <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.StoreName">Store Name</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@ssTotalSoh.ToString("N0")</div>
                    <span title="Sum of LPM_LocStock.SOH across all (Store × Division) rows for this store.">
                        <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.SOH">SOH</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@ssTotalTgtEom.ToString("N0")</div>
                    <span title="Sum of TargetEOM across divisions for this store.">
                        <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.TargetEOM">Target EOM</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@ssTotalTgtSale.ToString("N0")</div>
                    <span title="Sum of TargetSales across divisions for this store.">
                        <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.TargetSales">Target Sales</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@ssTotalMerchM.ToString("N0")</div>
                    <span title="Σ Merch Need (Month) for this store. = TargetEOM − SOH + TargetSales (per Div, summed).">
                        <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.MerchNeedMonth">Merch Need<br />(Month)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@ssTotalMerchW.ToString("N0")</div>
                    <span title="Σ Merch Need (Week) for this store. = Merch Need (Month) / 4.">
                        <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.MerchNeedWeek">Merch Need<br />(Week)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@ssTotalMerchD.ToString("N0")</div>
                    <span title="Σ Merch Need (Day) for this store. = Merch Need (Week) / 6 (fixed 6-day production week).">
                        <MudTableSortLabel T="StoreSummaryEom" SortBy="r => r.MerchNeedDay">Merch Need<br />(Day)</MudTableSortLabel>
                    </span>
                </MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><code>@context.StoreID</code></MudTd>
                <MudTd>@context.StoreName</MudTd>
                <MudTd>@context.SOH.ToString("N0")</MudTd>
                <MudTd>@context.TargetEOM.ToString("N0")</MudTd>
                <MudTd>@context.TargetSales.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedMonth.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedWeek.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedDay.ToString("N0")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
            </PagerContent>
        </MudTable>
    </div>
    </MudTabPanel>

    @* ─── Tab 3: Division Summary — rolled up across all stores ─────────── *@
    <MudTabPanel Text="Division Summary" Icon="@Icons.Material.Filled.Category">
    <div class="lpm-section">
        @{
            // Roll up all rows for the current Country to one row per Division.
            // Country scoping is implicit via _preview.
            var divRoll = _preview
                .GroupBy(r => new { r.DivCode, r.DivisionName })
                .Select(g =>
                {
                    var stock = StockForDiv(g.Key.DivCode);
                    return new DivisionSummaryEom
                    {
                        DivCode        = g.Key.DivCode,
                        DivisionName   = g.Key.DivisionName ?? "",
                        SOH            = g.Sum(r => (long)r.SOH),
                        // Sum decimal values first, round once. Per-row long
                        // cast was truncating fractional parts before summing.
                        TargetEOM      = (long)Math.Round(g.Sum(r => r.TargetEOM),   MidpointRounding.AwayFromZero),
                        TargetSales    = (long)Math.Round(g.Sum(r => r.TargetSales), MidpointRounding.AwayFromZero),
                        MerchNeedMonth = g.Sum(r => (long)r.MerchNeedMonth),
                        MerchNeedWeek  = g.Sum(r => (long)r.MerchNeedWeek),
                        MerchNeedDay   = g.Sum(r => (long)r.MerchNeedDay),
                        // LPMBoxQty is per-Division (repeated across stores) —
                        // take the value from any row in the group, not Sum().
                        LPMBoxQty      = g.First().LPMBoxQty,
                        // Stock breakdown — values driven by _divSummarySeason.
                        HOStock             = stock.HO,
                        WHStockPurchased    = stock.WHPurch,
                        WHStockNonPurchased = stock.WHNonPurch,
                        EligibleStock       = stock.Elig,
                    };
                })
                .Where(d => string.IsNullOrEmpty(_filterDivisionSummary)
                         || d.DivisionName.Contains(_filterDivisionSummary, StringComparison.OrdinalIgnoreCase)
                         || d.DivCode.ToString().Contains(_filterDivisionSummary, StringComparison.OrdinalIgnoreCase))
                .OrderBy(d => d.DivisionName)
                .ToList();

            var dsCount        = divRoll.Count;
            var dsTotalSoh     = divRoll.Sum(d => d.SOH);
            var dsTotalTgtEom  = divRoll.Sum(d => d.TargetEOM);
            var dsTotalTgtSale = divRoll.Sum(d => d.TargetSales);
            var dsTotalMerchM  = divRoll.Sum(d => d.MerchNeedMonth);
            var dsTotalMerchW  = divRoll.Sum(d => d.MerchNeedWeek);
            var dsTotalMerchD  = divRoll.Sum(d => d.MerchNeedDay);
            var dsTotalLpmBox  = divRoll.Sum(d => (long)d.LPMBoxQty);
            var dsTotalHO      = divRoll.Sum(d => d.HOStock);
            var dsTotalWHP     = divRoll.Sum(d => d.WHStockPurchased);
            var dsTotalWHNP    = divRoll.Sum(d => d.WHStockNonPurchased);
            var dsTotalElig    = divRoll.Sum(d => d.EligibleStock);
        }

        <MudGrid Spacing="2" Class="mb-2 align-center">
            <MudItem xs="12" md="4">
                <MudAutocomplete T="string" Label="Filter Division"
                                 Value="_filterDivisionSummary"
                                 ValueChanged="(string v) => { _filterDivisionSummary = v ?? string.Empty; StateHasChanged(); }"
                                 SearchFunc="SearchDivisions"
                                 Variant="Variant.Outlined"
                                 CoerceText="true" ResetValueOnEmptyText="true" Clearable="true"
                                 Placeholder="All divisions" />
            </MudItem>
            @* Season filter — applies ONLY to the rightmost 4 columns
               (HO Stock, WH Purchased, WH Non-Purchased, Eligible).
               SOH / Target EOM / Target Sales / Merch Need columns stay
               aggregated across both seasons regardless of this filter. *@
            <MudItem xs="12" md="3">
                <MudSelect T="string" Label="Season (stock cols)"
                           Value="_divSummarySeason"
                           ValueChanged="OnDivSummarySeasonChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                    <MudSelectItem T="string" Value="@SeasonAll">All seasons</MudSelectItem>
                    <MudSelectItem T="string" Value="@SeasonSummer">Summer</MudSelectItem>
                    <MudSelectItem T="string" Value="@SeasonWinter">Winter</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="5" Class="d-flex justify-end align-center">
                <MudText Typo="Typo.caption" Style="color:#64748b;">
                    Aggregated across all stores for @_country @_year-@_month.ToString("D2"). Excel export above writes all three tabs.
                </MudText>
            </MudItem>
        </MudGrid>

        <MudTable T="DivisionSummaryEom" Items="divRoll" Hover="true" Striped="true" Dense="true"
                  FixedHeader="true" Height="65vh" AllowUnsorted="false"
                  Class="lpm-eom-preview">
            <HeaderContent>
                <MudTh Style="width:10%;">
                    <div class="th-total">@dsCount.ToString("N0") rows</div>
                    <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.DivCode" InitialDirection="SortDirection.Ascending">Div Code</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:30%;">
                    <div class="th-total">&nbsp;</div>
                    <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.DivisionName">Division</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@dsTotalSoh.ToString("N0")</div>
                    <span title="Sum of LPM_LocStock.SOH across all (Store × Division) rows for this division.">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.SOH">SOH</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@dsTotalTgtEom.ToString("N0")</div>
                    <span title="Sum of TargetEOM across stores for this division.">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.TargetEOM">Target EOM</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@dsTotalTgtSale.ToString("N0")</div>
                    <span title="Sum of TargetSales across stores for this division.">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.TargetSales">Target Sales</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@dsTotalMerchM.ToString("N0")</div>
                    <span title="Σ Merch Need (Month) for this division. = TargetEOM − SOH + TargetSales (per Store, summed).">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.MerchNeedMonth">Merch Need<br />(Month)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@dsTotalMerchW.ToString("N0")</div>
                    <span title="Σ Merch Need (Week) for this division. = Merch Need (Month) / 4.">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.MerchNeedWeek">Merch Need<br />(Week)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:12%;">
                    <div class="th-total">@dsTotalMerchD.ToString("N0")</div>
                    <span title="Σ Merch Need (Day) for this division. = Merch Need (Week) / 6 (fixed 6-day production week).">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.MerchNeedDay">Merch Need<br />(Day)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:8%;">
                    <div class="th-total">@dsTotalLpmBox.ToString("N0")</div>
                    <span title="Σ qty of LPM-tagged eligible boxes (PalletCategory='ELIGIBLE' AND LPMDt IS NOT NULL). No ShopEligible filter.">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.LPMBoxQty">LPM Box<br />Qty</MudTableSortLabel>
                    </span>
                </MudTh>
                @* 4 new stock columns — driven by the Season filter above.
                   Values come from EomCalculator.GetDivisionStockBreakdownAsync
                   (LPM_LocStock + whboxitems queries), refreshed every time
                   the preview reloads. *@
                <MudTh Style="width:8%;">
                    <div class="th-total">@dsTotalHO.ToString("N0")</div>
                    <span title="Σ LPM_LocStock.SOH for items in this division where dataname='HODATA'. Season comes from upcbarcodes.Itemtype ('W' = Winter, else Summer). Drives by the Season filter above.">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.HOStock">HO<br />Stock</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:8%;">
                    <div class="th-total">@dsTotalWHP.ToString("N0")</div>
                    <span title="Σ whboxitems.Qty for boxes where ShopEligible='E' (already claimed by a shop).">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.WHStockPurchased">WH Stock<br />(Purchased)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:8%;">
                    <div class="th-total">@dsTotalWHNP.ToString("N0")</div>
                    <span title="Σ whboxitems.Qty for boxes where ShopEligible IS NULL OR <>'E' (still available for SIM).">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.WHStockNonPurchased">WH Stock<br />(Non-Purchased)</MudTableSortLabel>
                    </span>
                </MudTh>
                <MudTh Style="width:8%;">
                    <div class="th-total">@dsTotalElig.ToString("N0")</div>
                    <span title="Σ whboxitems.Qty for boxes where PalletCategory='ELIGIBLE' AND ShopEligible='E' (purchased subset of ELIGIBLE category).">
                        <MudTableSortLabel T="DivisionSummaryEom" SortBy="r => r.EligibleStock">Eligible<br />Stock</MudTableSortLabel>
                    </span>
                </MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><code>@context.DivCode</code></MudTd>
                <MudTd>@context.DivisionName</MudTd>
                <MudTd>@context.SOH.ToString("N0")</MudTd>
                <MudTd>@context.TargetEOM.ToString("N0")</MudTd>
                <MudTd>@context.TargetSales.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedMonth.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedWeek.ToString("N0")</MudTd>
                <MudTd>@context.MerchNeedDay.ToString("N0")</MudTd>
                <MudTd>@context.LPMBoxQty.ToString("N0")</MudTd>
                <MudTd>@context.HOStock.ToString("N0")</MudTd>
                <MudTd>@context.WHStockPurchased.ToString("N0")</MudTd>
                <MudTd>@context.WHStockNonPurchased.ToString("N0")</MudTd>
                <MudTd>@context.EligibleStock.ToString("N0")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
            </PagerContent>
        </MudTable>
    </div>
    </MudTabPanel>

    </MudTabs>
}

@code {
    private List<string> _countries = new();
    private string _country = "UAE";
    private int _year = DateTime.Today.Year;
    private int _month = DateTime.Today.Month;

    private EomReadiness? _readiness;
    private List<EomRow> _preview = new();
    private bool _running;

    private int    _filterDiv;
    private string _filterDivisionText = "";   // raw autocomplete text for display
    private string _filterStore        = "";
    private string _filterGrade        = "";
    private string _filterVolGrp       = "";
    private string _filterStoreSummary    = "";   // Store filter on the Store-Summary tab
    private string _filterDivisionSummary = "";   // Division filter on the Division-Summary tab
    /// <summary>Season filter for the Division-Summary tab's 4 stock columns
    /// (HO Stock, WH Purchased, WH Non-Purchased, Eligible). "All" sums
    /// Summer + Winter; "S"/"W" shows just that season. Doesn't affect the
    /// pre-existing SOH / Target EOM / Target Sales / Merch Need columns.</summary>
    private string _divSummarySeason = SeasonAll;
    private const string SeasonAll    = "All";
    private const string SeasonSummer = "S";
    private const string SeasonWinter = "W";
    /// <summary>Per-(Div × Season) stock breakdown keyed by (DivCode, Season).
    /// Loaded once after Preview/Generate completes via
    /// EomCalculator.GetDivisionStockBreakdownAsync — refreshed every time
    /// the preview re-runs so the values match the underlying data.</summary>
    private Dictionary<(int DivCode, string Season), DivisionStockBreakdown> _divStock = new();
    private string _previewLabel       = "Preview";
    private DateTime? _savedAt;

    /// <summary>
    /// Per-Store rollup of EOM output across divisions — drives the
    /// "Store Summary" tab + the second Excel sheet.
    /// </summary>
    private class StoreSummaryEom
    {
        public string StoreID        { get; set; } = "";
        public string StoreName      { get; set; } = "";
        public long   SOH            { get; set; }
        public long   TargetEOM      { get; set; }
        public long   TargetSales    { get; set; }
        public long   MerchNeedMonth { get; set; }
        public long   MerchNeedWeek  { get; set; }
        public long   MerchNeedDay   { get; set; }
    }

    /// <summary>
    /// Per-Division rollup of EOM output across stores — drives the
    /// "Division Summary" tab + the third Excel sheet.
    /// </summary>
    private class DivisionSummaryEom
    {
        public int    DivCode        { get; set; }
        public string DivisionName   { get; set; } = "";
        public long   SOH            { get; set; }
        public long   TargetEOM      { get; set; }
        public long   TargetSales    { get; set; }
        public long   MerchNeedMonth { get; set; }
        public long   MerchNeedWeek  { get; set; }
        public long   MerchNeedDay   { get; set; }
        /// <summary>Per-Division qty of LPM-tagged eligible boxes (no ShopEligible filter).</summary>
        public int    LPMBoxQty      { get; set; }

        // Stock breakdown (loaded on-demand via GetDivisionStockBreakdownAsync).
        // Driven by _divSummarySeason — "All" sums Summer + Winter; "S"/"W"
        // shows just that season. Defaults to 0 when no stock data exists
        // for the division (rare but possible if upc_subclass mapping is
        // missing or the country has no data).
        /// <summary>Σ SOH for items in this Div × Season from <c>LPM_LocStock</c> where <c>dataname='HODATA'</c>.</summary>
        public long   HOStock             { get; set; }
        /// <summary>Σ <c>whboxitems.Qty</c> with <c>ShopEligible='E'</c>.</summary>
        public long   WHStockPurchased    { get; set; }
        /// <summary>Σ <c>whboxitems.Qty</c> with <c>ShopEligible IS NULL OR &lt;&gt; 'E'</c>.</summary>
        public long   WHStockNonPurchased { get; set; }
        /// <summary>Σ <c>whboxitems.Qty</c> with <c>PalletCategory='ELIGIBLE' AND ShopEligible='E'</c>.</summary>
        public long   EligibleStock       { get; set; }
    }

    /// <summary>
    /// Helper to look up the 4 stock metrics for a (DivCode, Season-filter)
    /// combination from the on-demand <c>_divStock</c> dictionary. When the
    /// filter is "All", sums Summer + Winter; otherwise returns just that
    /// season's row (or zeros if no data).
    /// </summary>
    private (long HO, long WHPurch, long WHNonPurch, long Elig) StockForDiv(int divCode)
    {
        if (_divSummarySeason == SeasonSummer || _divSummarySeason == SeasonWinter)
        {
            return _divStock.TryGetValue((divCode, _divSummarySeason), out var r)
                ? (r.HOStock, r.WHStockPurchased, r.WHStockNonPurchased, r.EligibleStock)
                : (0L, 0L, 0L, 0L);
        }
        // SeasonAll — sum both seasons.
        long ho = 0, wp = 0, wn = 0, el = 0;
        foreach (var s in new[] { SeasonSummer, SeasonWinter })
        {
            if (_divStock.TryGetValue((divCode, s), out var r))
            {
                ho += r.HOStock;
                wp += r.WHStockPurchased;
                wn += r.WHStockNonPurchased;
                el += r.EligibleStock;
            }
        }
        return (ho, wp, wn, el);
    }

    private IEnumerable<EomRow> FilteredPreview
    {
        get
        {
            IEnumerable<EomRow> q = _preview;
            if (_filterDiv > 0)
                q = q.Where(r => r.DivCode == _filterDiv);
            if (!string.IsNullOrWhiteSpace(_filterStore))
            {
                var f = _filterStore.Trim();
                q = q.Where(r =>
                    r.StoreID.Contains(f, StringComparison.OrdinalIgnoreCase) ||
                    r.StoreName.Contains(f, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrWhiteSpace(_filterGrade))
                q = q.Where(r => string.Equals(r.Grade, _filterGrade, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(_filterVolGrp))
                q = q.Where(r => string.Equals(r.VolumeGroup, _filterVolGrp, StringComparison.OrdinalIgnoreCase));
            return q;
        }
    }

    /// <summary>
    /// Search-as-you-type for the Division autocomplete. Suggestions are formatted
    /// "Womenswear  (419)" — the trailing parenthesised DivCode is stripped on selection
    /// and stored in <c>_filterDiv</c> so the predicate is a fast int comparison.
    /// </summary>
    private Task<IEnumerable<string>> SearchDivisions(string? value, CancellationToken ct)
    {
        var all = _preview
            .Select(r => $"{r.DivisionName}  ({r.DivCode})")
            .Distinct()
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(all.Take(50));
        return Task.FromResult<IEnumerable<string>>(all
            .Where(s => s.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(50));
    }

    private void OnDivisionFilterChanged(string? v)
    {
        _filterDivisionText = v ?? string.Empty;
        if (string.IsNullOrWhiteSpace(v))
        {
            _filterDiv = 0;
        }
        else
        {
            // Pull the trailing "(419)" out and parse to int.
            var s = v.Trim();
            var open  = s.LastIndexOf('(');
            var close = s.LastIndexOf(')');
            if (open >= 0 && close > open && close == s.Length - 1
                && int.TryParse(s.Substring(open + 1, close - open - 1).Trim(), out var div))
            {
                _filterDiv = div;
            }
            else
            {
                // Free-typed text — try to match by name (first hit wins).
                var match = _preview.FirstOrDefault(r =>
                    r.DivisionName.Contains(s, StringComparison.OrdinalIgnoreCase));
                _filterDiv = match?.DivCode ?? 0;
            }
        }
        StateHasChanged();
    }

    /// <summary>
    /// Normalise the autocomplete value: when the user picks a suggestion like
    /// "BFL DXB Shopping center  (BFL-DXB)", extract the StoreID from inside
    /// the trailing parentheses and store ONLY that. When the user types free
    /// text (no parens), store as-is.
    /// This way <see cref="FilteredPreview"/> filters with a simple Contains.
    /// </summary>
    private void OnStoreFilterChanged(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) { _filterStore = ""; }
        else
        {
            var s = v.Trim();
            // Pull out the "(BFL-DXB)" suffix if present.
            var open  = s.LastIndexOf('(');
            var close = s.LastIndexOf(')');
            if (open >= 0 && close > open && close == s.Length - 1)
                _filterStore = s.Substring(open + 1, close - open - 1).Trim();
            else
                _filterStore = s;
        }
        StateHasChanged();
    }

    /// <summary>
    /// Returns suggestions formatted as "BFL DXB Shopping center  (BFL-DXB)" so
    /// the human-friendly store NAME is what the planner reads first; the
    /// StoreID is shown in parentheses for disambiguation when multiple stores
    /// share a similar name. Both fields are searchable.
    /// </summary>
    private Task<IEnumerable<string>> SearchStores(string? value, CancellationToken ct)
    {
        var all = _preview
            .Select(r => $"{r.StoreName}  ({r.StoreID})")
            .Distinct()
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(all.Take(50));
        return Task.FromResult<IEnumerable<string>>(all
            .Where(s => s.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(50));
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _countries = await db.DataSettings
            .Where(s => s.ActiveStore == "Y" && s.Country != null && s.Country != "")
            .Select(s => s.Country!).Distinct().OrderBy(c => c).ToListAsync();

        if (!_countries.Contains(_country, StringComparer.OrdinalIgnoreCase))
            _country = _countries.FirstOrDefault() ?? "";

        // Default to the latest saved month: prefer generated LPM_EOM_Output;
        // fall back to the latest monthly-weight run configured for this country.
        var latestOut = await db.LpmEomOutputs.AsNoTracking()
            .Where(e => e.Country == _country)
            .OrderByDescending(e => e.Year1).ThenByDescending(e => e.Month1)
            .Select(e => new { e.Year1, e.Month1 })
            .FirstOrDefaultAsync();
        if (latestOut is not null)
        {
            _year = latestOut.Year1; _month = latestOut.Month1;
        }
        else
        {
            var latestW = await db.LpmMonthlyWeights.AsNoTracking()
                .Where(w => w.Country == _country)
                .OrderByDescending(w => w.RunYear).ThenByDescending(w => w.RunMonth)
                .Select(w => new { w.RunYear, w.RunMonth })
                .FirstOrDefaultAsync();
            if (latestW is not null) { _year = latestW.RunYear; _month = latestW.RunMonth; }
        }

        if (!string.IsNullOrEmpty(_country)) await CheckAsync();
    }

    private async Task CheckAsync()
    {
        _preview.Clear();
        _savedAt = null;
        _readiness = null;
        if (string.IsNullOrEmpty(_country)) { StateHasChanged(); return; }

        _running = true; StateHasChanged();
        try
        {
            _readiness = await Eom.CheckAsync(_country, _year, _month);
            // Auto-load any saved EOM output for this scope so user sees it immediately.
            var (rows, last) = await Eom.GetSavedAsync(_country, _year, _month);
            if (rows.Count > 0)
            {
                _preview = rows;
                _savedAt = last;
                _previewLabel = "Saved Output";
                await LoadDivisionStockBreakdownAsync();
            }
        }
        finally { _running = false; StateHasChanged(); }
    }

    /// <summary>
    /// Refresh the on-demand stock breakdown that backs the new
    /// Division Summary columns (HO Stock / WH Purchased / WH Non-Purchased
    /// / Eligible Stock). Cheap on the SQL side (a single query with two
    /// CTE rollups), so we fire it whenever <c>_preview</c> is reloaded.
    /// Non-fatal: any failure just leaves the columns at 0 — the rest of
    /// the page keeps working.
    /// </summary>
    /// <summary>
    /// Named handler for the Season filter dropdown on the Division Summary
    /// tab — kept as a method (instead of inline) to keep the Razor markup
    /// clean and avoid double-quote escape issues inside Razor attribute
    /// values.
    /// </summary>
    private void OnDivSummarySeasonChanged(string? v)
    {
        _divSummarySeason = string.IsNullOrEmpty(v) ? "All" : v;
        StateHasChanged();
    }

    private async Task LoadDivisionStockBreakdownAsync()
    {
        try
        {
            var rows = await Eom.GetDivisionStockBreakdownAsync(_country);
            _divStock = rows.ToDictionary(r => (r.DivCode, r.Season));
        }
        catch (Exception ex)
        {
            _divStock = new();
            Snackbar.Add($"Division stock breakdown failed: {ex.Message}", Severity.Warning);
        }
    }

    /// <summary>
    /// "Generate" button — runs the engine in memory and shows the preview
    /// grid WITHOUT writing to LPM_EOM_Output. Approve persists those rows.
    /// (Internally still calls Eom.PreviewAsync — that name in the service
    /// layer reflects what it does: produce values without saving.)
    /// </summary>
    private async Task GenerateAsync()
    {
        _running = true; _preview.Clear(); StateHasChanged();
        try
        {
            _preview = await Eom.PreviewAsync(_country, _year, _month);
            _previewLabel = "Generated (not saved)";
            _savedAt = null;
            await LoadDivisionStockBreakdownAsync();
            Snackbar.Add($"Generated: {_preview.Count} rows. Click Approve to save.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Generate failed: {ex.Message}", Severity.Error);
        }
        finally { _running = false; StateHasChanged(); }
    }

    private async Task ViewSavedAsync()
    {
        _running = true; _preview.Clear(); StateHasChanged();
        try
        {
            var (rows, last) = await Eom.GetSavedAsync(_country, _year, _month);
            _preview = rows;
            _savedAt = last;
            _previewLabel = "Saved Output";
            await LoadDivisionStockBreakdownAsync();
            if (rows.Count == 0)
                Snackbar.Add($"No saved EOM output for {_country} {_year}/{_month:D2}. Click Generate first.", Severity.Info);
            else
                Snackbar.Add($"Loaded {rows.Count:N0} saved rows.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load saved failed: {ex.Message}", Severity.Error);
        }
        finally { _running = false; StateHasChanged(); }
    }

    /// <summary>
    /// "Approve" button — runs the engine AND writes to LPM_EOM_Output,
    /// replacing any existing rows for the same (Country, Year, Month).
    /// SIM Generate consumes the saved output, so this is the action that
    /// actually publishes EOM for downstream use.
    /// </summary>
    private async Task ApproveAsync()
    {
        var ok = await DialogService.ShowMessageBox("Approve EOM",
            $"This will REPLACE any existing LPM_EOM_Output rows for {_country} {_year}/{_month:D2}. Continue?",
            yesText: "Approve", cancelText: "Cancel");
        if (ok != true) return;

        _running = true; StateHasChanged();
        try
        {
            var count = await Eom.GenerateAsync(_country, _year, _month, CurrentUser.Name);
            Snackbar.Add($"Approved {count} rows for {_country} {_year}/{_month:D2}.", Severity.Success);
            var (rows, last) = await Eom.GetSavedAsync(_country, _year, _month);
            _preview = rows;
            _savedAt = last;
            _previewLabel = "Saved Output";
            await LoadDivisionStockBreakdownAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Approve failed: {ex.Message}", Severity.Error);
        }
        finally { _running = false; StateHasChanged(); }
    }

    /// <summary>
    /// Excel export of the FILTERED preview rows. Mirrors the columns
    /// shown in the grid; numeric columns formatted as "#,##0".
    /// </summary>
    private async Task ExportExcelAsync()
    {
        var rows = FilteredPreview.ToList();
        if (rows.Count == 0)
        {
            Snackbar.Add("Nothing to export.", Severity.Warning);
            return;
        }

        try
        {
            using var wb = new XLWorkbook();

            // ── Sheet 1: Store × Division (the existing detailed grid) ────
            var ws = wb.Worksheets.Add("Store-Div EOM");

            string[] headers = {
                "StoreID", "StoreName", "Division",
                "Wt Avg Sold", "Wt Avg Turn",
                "Sold Qty Rank", "Turns Rank", "Pri Rank",
                "Grade", "Tgt Turn",
                "Tgt Sales", "Tgt EOM",
                "SOH", "Merch Need (Month)", "Merch Need (Week)", "Merch Need (Day)",
                "Vol Grp", "WH Summer", "WH Winter"
            };
            for (int c = 0; c < headers.Length; c++)
                ws.Cell(1, c + 1).Value = headers[c];
            ws.Range(1, 1, 1, headers.Length).Style.Font.Bold = true;
            ws.Range(1, 1, 1, headers.Length).Style.Fill.BackgroundColor = XLColor.LightGray;

            int row = 2;
            foreach (var r in rows)
            {
                ws.Cell(row, 1).Value  = r.StoreID;
                ws.Cell(row, 2).Value  = r.StoreName;
                ws.Cell(row, 3).Value  = r.DivisionName;
                ws.Cell(row, 4).Value  = (double)r.WtAvgSoldQty;
                ws.Cell(row, 5).Value  = (double)r.WtAvgTurn;
                ws.Cell(row, 6).Value  = r.SoldQtyRank;
                ws.Cell(row, 7).Value  = r.TurnsRank;
                ws.Cell(row, 8).Value  = (double)r.PriorityRank;
                ws.Cell(row, 9).Value  = r.Grade ?? "";
                ws.Cell(row, 10).Value = (double)r.TargetTurn;
                ws.Cell(row, 11).Value = (double)r.TargetSales;
                ws.Cell(row, 12).Value = (double)r.TargetEOM;
                ws.Cell(row, 13).Value = r.SOH;
                ws.Cell(row, 14).Value = r.MerchNeedMonth;
                ws.Cell(row, 15).Value = r.MerchNeedWeek;
                ws.Cell(row, 16).Value = r.MerchNeedDay;
                ws.Cell(row, 17).Value = r.VolumeGroup ?? "";
                ws.Cell(row, 18).Value = r.WHStockSummer;
                ws.Cell(row, 19).Value = r.WHStockWinter;
                row++;
            }

            int last = row - 1;
            foreach (var col in new[] { 4, 5, 8, 10, 11, 12, 13, 14, 15, 16, 18, 19 })
                ws.Range(2, col, last, col).Style.NumberFormat.Format = "#,##0.##";
            ws.Columns().AdjustToContents();

            // ── Sheet 2: Store Summary (rolled up across divisions) ───────
            var storeRoll = _preview
                .GroupBy(r2 => new { r2.StoreID, r2.StoreName })
                .Select(g => new
                {
                    StoreID        = g.Key.StoreID,
                    StoreName      = g.Key.StoreName ?? "",
                    SOH            = g.Sum(r2 => (long)r2.SOH),
                    // Sum decimals first, round once — see Store-Div tab note.
                    TargetEOM      = (long)Math.Round(g.Sum(r2 => r2.TargetEOM),   MidpointRounding.AwayFromZero),
                    TargetSales    = (long)Math.Round(g.Sum(r2 => r2.TargetSales), MidpointRounding.AwayFromZero),
                    MerchNeedMonth = g.Sum(r2 => (long)r2.MerchNeedMonth),
                    MerchNeedWeek  = g.Sum(r2 => (long)r2.MerchNeedWeek),
                    MerchNeedDay   = g.Sum(r2 => (long)r2.MerchNeedDay),
                })
                .OrderBy(s => s.StoreID)
                .ToList();

            var ws2 = wb.Worksheets.Add("Store Summary");
            string[] headers2 = {
                "StoreID", "StoreName", "SOH",
                "Target EOM", "Target Sales",
                "Merch Need (Month)", "Merch Need (Week)", "Merch Need (Day)"
            };
            for (int c = 0; c < headers2.Length; c++)
                ws2.Cell(1, c + 1).Value = headers2[c];
            ws2.Range(1, 1, 1, headers2.Length).Style.Font.Bold = true;
            ws2.Range(1, 1, 1, headers2.Length).Style.Fill.BackgroundColor = XLColor.LightGray;

            int row2 = 2;
            foreach (var s in storeRoll)
            {
                ws2.Cell(row2, 1).Value = s.StoreID;
                ws2.Cell(row2, 2).Value = s.StoreName;
                ws2.Cell(row2, 3).Value = s.SOH;
                ws2.Cell(row2, 4).Value = s.TargetEOM;
                ws2.Cell(row2, 5).Value = s.TargetSales;
                ws2.Cell(row2, 6).Value = s.MerchNeedMonth;
                ws2.Cell(row2, 7).Value = s.MerchNeedWeek;
                ws2.Cell(row2, 8).Value = s.MerchNeedDay;
                row2++;
            }

            int last2 = row2 - 1;
            if (last2 >= 2)
            {
                foreach (var col in new[] { 3, 4, 5, 6, 7, 8 })
                    ws2.Range(2, col, last2, col).Style.NumberFormat.Format = "#,##0";
            }
            ws2.Columns().AdjustToContents();

            // ── Sheet 3: Division Summary (rolled up across stores) ───────
            var divRoll = _preview
                .GroupBy(r3 => new { r3.DivCode, r3.DivisionName })
                .Select(g => new
                {
                    DivCode        = g.Key.DivCode,
                    DivisionName   = g.Key.DivisionName ?? "",
                    SOH            = g.Sum(r3 => (long)r3.SOH),
                    // Sum decimals first, round once — same fix as the on-screen
                    // projection so the Excel sheet matches the UI footer.
                    TargetEOM      = (long)Math.Round(g.Sum(r3 => r3.TargetEOM),   MidpointRounding.AwayFromZero),
                    TargetSales    = (long)Math.Round(g.Sum(r3 => r3.TargetSales), MidpointRounding.AwayFromZero),
                    MerchNeedMonth = g.Sum(r3 => (long)r3.MerchNeedMonth),
                    MerchNeedWeek  = g.Sum(r3 => (long)r3.MerchNeedWeek),
                    MerchNeedDay   = g.Sum(r3 => (long)r3.MerchNeedDay),
                    // LPMBoxQty is per-Division — repeats across store rows.
                    LPMBoxQty      = g.First().LPMBoxQty,
                })
                .OrderBy(d => d.DivisionName)
                .ToList();

            var ws3 = wb.Worksheets.Add("Division Summary");
            string[] headers3 = {
                "DivCode", "Division", "SOH",
                "Target EOM", "Target Sales",
                "Merch Need (Month)", "Merch Need (Week)", "Merch Need (Day)",
                "LPM Box Qty"
            };
            for (int c = 0; c < headers3.Length; c++)
                ws3.Cell(1, c + 1).Value = headers3[c];
            ws3.Range(1, 1, 1, headers3.Length).Style.Font.Bold = true;
            ws3.Range(1, 1, 1, headers3.Length).Style.Fill.BackgroundColor = XLColor.LightGray;

            int row3 = 2;
            foreach (var d in divRoll)
            {
                ws3.Cell(row3, 1).Value = d.DivCode;
                ws3.Cell(row3, 2).Value = d.DivisionName;
                ws3.Cell(row3, 3).Value = d.SOH;
                ws3.Cell(row3, 4).Value = d.TargetEOM;
                ws3.Cell(row3, 5).Value = d.TargetSales;
                ws3.Cell(row3, 6).Value = d.MerchNeedMonth;
                ws3.Cell(row3, 7).Value = d.MerchNeedWeek;
                ws3.Cell(row3, 8).Value = d.MerchNeedDay;
                ws3.Cell(row3, 9).Value = d.LPMBoxQty;
                row3++;
            }

            int last3 = row3 - 1;
            if (last3 >= 2)
            {
                foreach (var col in new[] { 3, 4, 5, 6, 7, 8, 9 })
                    ws3.Range(2, col, last3, col).Style.NumberFormat.Format = "#,##0";
            }
            ws3.Columns().AdjustToContents();

            // ── Save + download ───────────────────────────────────────────
            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var url = $"data:application/octet-stream;base64,{b64}";
            var fileName = $"EOM_{_country}_{_year}-{_month:D2}.xlsx";
            await JS.InvokeVoidAsync("lpmDownload", url, fileName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Excel export failed: {ex.Message}", Severity.Error);
        }
    }
}
