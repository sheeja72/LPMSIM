@page "/lpm/lpm-sim/reports"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.AnyRole)]
@* 1.14.25 — opened to AnyRole so the Reports (Viewer) role can access.
   1.14.60 — Totals footers on every tab; "Filter by Itemcode list" Excel
   upload that narrows SIM Boxes (boxes containing at least one matched
   item) and Item Details (matching item rows). EOM Summary is unaffected
   by the item filter (no Itemcode column). *@
@using LpmSim.Data.LpmSim
@using LpmSim.Web.Components.Pages.Uploads
@using ClosedXML.Excel
@using System.IO
@inject IDbContextFactory<LpmDbContext> DbFactory
@inject LpmSimReportService Reports
@inject ICurrentUser CurrentUser
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>LPM SIM Reports</PageTitle>

<div class="lpm-page-title">LPM SIM Reports</div>
<div class="lpm-page-subtitle">
    Three views of an LPM SIM batch: EOM-level summary, Box-level allocations, and Item-level details.
</div>

<div class="lpm-section lpm-filter-bar" style="max-width:1200px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="3" md="2">
            <MudSelect T="string" Label="Country" Value="_country"
                       ValueChanged="async v => { _country = v ?? string.Empty; await ReloadBatchesAsync(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                @foreach (var c in _countries)
                {
                    <MudSelectItem Value="@c">@c</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3" md="3">
            <MudDatePicker Label="SIM Run Date (optional)" Date="_runDate"
                           DateChanged="OnRunDateChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Clearable />
        </MudItem>
        <MudItem xs="12" sm="3" md="3">
            <MudSelect T="long" Label="Batch No" Value="_batchNo"
                       ValueChanged="async (long v) => { _batchNo = v; await LoadActiveTabAsync(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var b in _batches)
                {
                    <MudSelectItem T="long" Value="b.LPMBatchNo">
                        @($"#{b.LPMBatchNo} · {b.RunDate:yyyy-MM-dd} · {b.Status} · {b.LinesGenerated:N0} lines")
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudTextField T="string" Label="Filter Store" Value="_filterStore"
                          ValueChanged="v => _filterStore = v ?? string.Empty"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate Clearable />
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudTextField T="string" Label="Filter Division" Value="_filterDiv"
                          ValueChanged="v => _filterDiv = v ?? string.Empty"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate Clearable />
        </MudItem>
    </MudGrid>
</div>

@* 1.14.60 — Item-list Excel upload + status chip. The uploaded itemcodes
   filter the SIM Boxes tab (boxes containing at least one of the items)
   and Item Details tab (matching item rows). EOM Summary is unaffected. *@
<div class="lpm-section" style="max-width:1200px;display:flex;align-items:center;flex-wrap:wrap;gap:0.75rem;">
    <MudFileUpload T="IBrowserFile" FilesChanged="OnItemFilterUploaded" Accept=".xlsx">
        <ActivatorContent>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.Upload" Size="Size.Small">
                Filter by Itemcode list (Excel)
            </MudButton>
        </ActivatorContent>
    </MudFileUpload>
    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default" DropShadow="false"
               StartIcon="@Icons.Material.Filled.Download"
               OnClick="DownloadItemFilterTemplate">
        Template
    </MudButton>
    @if (_itemFilter.Count > 0)
    {
        var matchedItems = _itemRows.Count(r => _itemFilter.Contains(r.Itemcode));
        var matchedBoxes = _boxesContainingFilteredItems.Count;
        <div style="font-size:0.85rem;color:#334155;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" Color="Color.Primary" />
            <span><strong>@_itemFilter.Count itemcode(s)</strong>
                @if (!string.IsNullOrEmpty(_itemFilterFileName))
                {
                    <text>from <code>@_itemFilterFileName</code></text>
                }
                @if (_itemRows.Count > 0)
                {
                    <text> · <strong>@matchedItems</strong> matching row(s) across <strong>@matchedBoxes</strong> box(es) in batch #@_batchNo</text>
                }
            </span>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearItemFilter">
                Clear
            </MudButton>
        </div>
    }
    else
    {
        <span style="font-size:0.82rem;color:#64748b;">
            Upload an <code>.xlsx</code> with header <code>Itemcode</code> in <code>A1</code> and itemcodes from <code>A2</code> down to filter SIM Boxes &amp; Item Details.
        </span>
    }
</div>
@if (_itemFilterError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-2" Style="max-width:1200px;">@_itemFilterError</MudAlert>
}

@if (_busy)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
}

@if (_batchNo == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Style="max-width:1200px;">
        Pick a country (and optionally a date) to see available batches, then choose one.
    </MudAlert>
}
else
{
    <MudTabs Elevation="0" Rounded="true" Border="true"
             ApplyEffectsToContainer="true" PanelClass="pa-4" Class="mud-paper"
             ActivePanelIndexChanged="OnTabChanged" Style="max-width:1200px;">

        <MudTabPanel Text="EOM Summary" Icon="@Icons.Material.Filled.Insights">
            @if (_eomRows.Count > 0)
            {
                var fe = FilteredEom.ToList();
                // 1.14.62 — Totals computed once per render so header + footer
                // + Excel button all share the same numbers.
                var eomTotEom    = fe.Sum(r => r.EOM ?? 0m);
                var eomTotSoh    = fe.Sum(r => (long)r.SOH);
                var eomTotMrn    = fe.Sum(r => (long)(r.MerchNeedWeek ?? 0));
                var eomTotSim    = fe.Sum(r => (long)r.LpmSimQty);
                var eomTotOvr    = fe.Sum(r => (long)r.OverrideQty);
                <div class="d-flex justify-end mb-2">
                    <MudButton Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small"
                               DropShadow="false" StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_downloadingExcel || fe.Count == 0)"
                               OnClick="DownloadEomExcelAsync">
                        Excel (@fe.Count.ToString("N0"))
                    </MudButton>
                </div>
                <MudTable T="EomSummaryRow" Items="fe" Hover Striped Dense FixedHeader Height="60vh" AllowUnsorted="false">
                    <HeaderContent>
                        @* 1.14.62 — Totals in header (above the column name) for
                           every numeric column, so the planner sees them without
                           scrolling to the footer. Footer still shown for tall tables. *@
                        <MudTh>Batch</MudTh>
                        <MudTh><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.StoreID">Store ID</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.StoreName">Store Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@eomTotEom.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.EOM ?? 0m">EOM</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@eomTotSoh.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@eomTotMrn.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.MerchNeedWeek ?? 0">Merch Need (Week)</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@eomTotSim.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.LpmSimQty">LPM SIM Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@eomTotOvr.ToString("N0")</div><MudTableSortLabel T="EomSummaryRow" SortBy="r => r.OverrideQty">Override Qty</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>#@context.LPMBatchNo</MudTd>
                        <MudTd><code>@context.StoreID</code></MudTd>
                        <MudTd>@context.StoreName</MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd>@(context.EOM?.ToString("N0"))</MudTd>
                        <MudTd>@context.SOH.ToString("N0")</MudTd>
                        <MudTd>@(context.MerchNeedWeek?.ToString("N0") ?? "—")</MudTd>
                        <MudTd>@context.LpmSimQty.ToString("N0")</MudTd>
                        <MudTd style="@(context.OverrideQty > 0 ? "color:#d97706;font-weight:600;" : "")">@(context.OverrideQty > 0 ? context.OverrideQty.ToString("N0") : "—")</MudTd>
                    </RowTemplate>
                    <FooterContent>
                        @* 1.14.60 — Totals row across filtered rows.
                           1.14.62 — Same totals now also surface in the header (above each
                           column name); the footer stays for tall tables. *@
                        <MudTd Style="font-weight:600;" colspan="4">TOTAL (@fe.Count.ToString("N0") rows)</MudTd>
                        <MudTd Style="font-weight:600;">@eomTotEom.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@eomTotSoh.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@eomTotMrn.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@eomTotSim.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@eomTotOvr.ToString("N0")</MudTd>
                    </FooterContent>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_busy)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No EOM summary rows for this batch.</MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="SIM Boxes" Icon="@Icons.Material.Filled.Inventory2">
            <MudSwitch T="bool" Value="_rollupBoxOnly"
                       ValueChanged="async (bool v) => { _rollupBoxOnly = v; await LoadBoxesAsync(); }"
                       Color="Color.Primary" Label="Roll up to Box (without Store / Div)" Class="mb-2" />

            @if (_boxRows.Count > 0)
            {
                var fb = FilteredBoxes.ToList();
                // 1.14.60 — When not rolled-up, the same physical box appears
                // once per (Store × Div) allocation, so SUMming BoxQty would
                // multi-count. Group by BoxNo and take the first BoxQty per
                // group for the true total Box Qty. Rolled-up view already
                // collapses to one row per box, so the calc converges.
                var distinctBoxes  = fb.GroupBy(r => r.BoxNo).ToList();
                var totalBoxQty    = distinctBoxes.Sum(g => (long)(g.First().BoxQty ?? 0));
                var totalAlloc     = fb.Sum(r => (long)r.LpmSimQty);
                var avgUsability   = fb.Count > 0
                    ? fb.Average(r => r.SkuUsabilityPct ?? 0m)
                    : 0m;
                <div class="d-flex justify-end mb-2">
                    <MudButton Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small"
                               DropShadow="false" StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_downloadingExcel || fb.Count == 0)"
                               OnClick="DownloadBoxesExcelAsync">
                        Excel (@fb.Count.ToString("N0"))
                    </MudButton>
                </div>
                <MudTable T="BoxDetailRow" Items="fb" Hover Striped Dense FixedHeader Height="60vh" AllowUnsorted="false">
                    <HeaderContent>
                        @* 1.14.62 — Totals in header for the three numeric columns
                           (Box Qty deduped, Allocated Qty summed, Usability averaged). *@
                        <MudTh>Batch</MudTh>
                        @if (!_rollupBoxOnly)
                        {
                            <MudTh><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.StoreID ?? string.Empty">Store</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.DivisionName ?? string.Empty">Division</MudTableSortLabel></MudTh>
                        }
                        <MudTh><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.BoxNo">Box</MudTableSortLabel></MudTh>
                        @* 1.14.81 — Kind (LPM/Non-LPM badge) + LPM Date right after Box
                           so the planner sees the LPM tag at a glance, paired with the
                           date stamp from whboxitems.LPMDt. *@
                        <MudTh><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.BoxKind ?? string.Empty">Kind</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.LpmDate ?? DateTime.MinValue">LPM Date</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalBoxQty.ToString("N0")</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.BoxQty ?? 0">Box Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@totalAlloc.ToString("N0")</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.LpmSimQty">Allocated Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@avgUsability.ToString("0.0")% avg</div><MudTableSortLabel T="BoxDetailRow" SortBy="r => r.SkuUsabilityPct ?? 0m">SKU Usability %</MudTableSortLabel></MudTh>
                        <MudTh>Pallet Type</MudTh>
                        <MudTh>Type Name</MudTh>
                        <MudTh>Pallet Category</MudTh>
                        @* 1.14.70 — Pallet-purchase / GIN columns from whboxitems. *@
                        <MudTh>Purchase Dt</MudTh>
                        <MudTh>GIN No</MudTh>
                        <MudTh>GIN Date</MudTh>
                        <MudTh>From/To</MudTh>
                        @* 1.14.80 — Container number + most-recent Approved batch
                           containing this box (same country). Helps planners spot
                           reused / re-shipped boxes. *@
                        <MudTh>Cont No</MudTh>
                        <MudTh>Recent Batch</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>#@context.LPMBatchNo</MudTd>
                        @if (!_rollupBoxOnly)
                        {
                            <MudTd>
                                @if (!string.IsNullOrEmpty(context.StoreID))
                                {
                                    <code>@context.StoreID</code>
                                    <br />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.StoreName</MudText>
                                }
                            </MudTd>
                            <MudTd>@context.DivisionName</MudTd>
                        }
                        <MudTd><code>@context.BoxNo</code></MudTd>
                        @* 1.14.81 — Kind badge (mirrors Generate preview styling) + LPM Date. *@
                        <MudTd>
                            @if (context.BoxKind == "LPM")
                            {
                                <span class="lpm-status lpm-status-ok">LPM</span>
                            }
                            else if (context.BoxKind == "Non-LPM")
                            {
                                <span class="lpm-status lpm-status-warn">Non-LPM</span>
                            }
                        </MudTd>
                        <MudTd>@(context.LpmDate?.ToString("yyyy-MM-dd") ?? string.Empty)</MudTd>
                        <MudTd>@(context.BoxQty?.ToString("N0"))</MudTd>
                        <MudTd>@context.LpmSimQty.ToString("N0")</MudTd>
                        <MudTd>@(context.SkuUsabilityPct?.ToString("0.0") ?? "—")%</MudTd>
                        <MudTd>@context.PalletType</MudTd>
                        <MudTd>@context.TypeName</MudTd>
                        <MudTd>@context.PalletCategory</MudTd>
                        @* 1.14.70 — Pallet-purchase / GIN cells. Empty string
                           when the underlying column is NULL so the cell
                           renders as blank rather than showing "01/01/0001". *@
                        <MudTd>@(context.PurDate?.ToString("yyyy-MM-dd") ?? string.Empty)</MudTd>
                        <MudTd>@(context.GINNo ?? string.Empty)</MudTd>
                        <MudTd>@(context.GinDate?.ToString("yyyy-MM-dd") ?? string.Empty)</MudTd>
                        <MudTd>@(context.FromTo ?? string.Empty)</MudTd>
                        @* 1.14.80 — Cont No (free text) + Recent Batch (#N or em-dash). *@
                        <MudTd>@(context.ContNo ?? string.Empty)</MudTd>
                        <MudTd>@(context.RecentBatchNo.HasValue ? $"#{context.RecentBatchNo}" : "—")</MudTd>
                    </RowTemplate>
                    <FooterContent>
                        @* 1.14.60 — Totals row. Box Qty is summed across DISTINCT
                           BoxNos (so the same physical box that repeats across
                           store/div rows in the non-roll-up view isn't counted
                           multiple times). Allocated Qty sums per row (each row
                           is a real (Box × Store × Div) allocation). Usability
                           is averaged across rows. *@
                        @if (!_rollupBoxOnly)
                        {
                            <MudTd Style="font-weight:600;" colspan="3">TOTAL (@fb.Count.ToString("N0") rows · @distinctBoxes.Count.ToString("N0") distinct boxes)</MudTd>
                        }
                        else
                        {
                            <MudTd Style="font-weight:600;" colspan="1">TOTAL (@fb.Count.ToString("N0") boxes)</MudTd>
                        }
                        @* 1.14.81 — Footer cells for Kind + LPM Date (no totals — badge / date). *@
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                        <MudTd Style="font-weight:600;">@totalBoxQty.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@totalAlloc.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@avgUsability.ToString("0.0")% avg</MudTd>
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                        @* 1.14.70 — Footer cells for the 4 new pallet-purchase
                           columns. Dashes (no totals — these are date / text). *@
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                        @* 1.14.80 — Footer cells for Cont No + Recent Batch. *@
                        <MudTd>—</MudTd>
                        <MudTd>—</MudTd>
                    </FooterContent>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_busy)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No box rows for this batch.</MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="Item Details" Icon="@Icons.Material.Filled.ListAlt">
            @if (_itemRows.Count > 0)
            {
                var fi = FilteredItems.ToList();
                var distinctItems = fi.Select(r => r.Itemcode).Distinct(StringComparer.OrdinalIgnoreCase).Count();
                // 1.14.62 — Totals computed once.
                var itTotQty    = fi.Sum(r => (long)(r.BoxItemQty ?? 0));
                var itTotSku    = fi.Sum(r => (long)(r.SKUMax ?? 0));
                var itTotSoh    = fi.Sum(r => (long)r.SOH);
                var itTotLpm    = fi.Sum(r => (long)r.LpmQty);
                <div class="d-flex justify-end mb-2">
                    <MudButton Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small"
                               DropShadow="false" StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_downloadingExcel || fi.Count == 0)"
                               OnClick="DownloadItemsExcelAsync">
                        Excel (@fi.Count.ToString("N0"))
                    </MudButton>
                </div>
                <MudTable T="ItemDetailRow" Items="fi" Hover Striped Dense FixedHeader Height="60vh" AllowUnsorted="false">
                    <HeaderContent>
                        @* 1.14.62 — Totals in header for the four numeric columns. *@
                        <MudTh>Batch</MudTh>
                        <MudTh><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.StoreID">Store</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.DivisionName">Division</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.BoxNo">Box</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.Itemcode">Item</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@itTotQty.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.BoxItemQty ?? 0">Qty</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@itTotSku.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.SKUMax ?? 0">SKU Max</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@itTotSoh.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.SOH">SOH</MudTableSortLabel></MudTh>
                        <MudTh><div class="th-total">@itTotLpm.ToString("N0")</div><MudTableSortLabel T="ItemDetailRow" SortBy="r => r.LpmQty">LPM Qty</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>#@context.LPMBatchNo</MudTd>
                        <MudTd>
                            <code>@context.StoreID</code>
                            <br />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.StoreName</MudText>
                        </MudTd>
                        <MudTd>@context.DivisionName</MudTd>
                        <MudTd><code>@context.BoxNo</code></MudTd>
                        <MudTd><code>@context.Itemcode</code></MudTd>
                        <MudTd>@(context.BoxItemQty?.ToString("N0"))</MudTd>
                        <MudTd>@(context.SKUMax?.ToString("N0"))</MudTd>
                        <MudTd>@context.SOH.ToString("N0")</MudTd>
                        <MudTd>@context.LpmQty.ToString("N0")</MudTd>
                    </RowTemplate>
                    <FooterContent>
                        @* 1.14.60 — Totals row. All four numeric columns are
                           per-row qty so straight SUM is correct. Row count +
                           distinct item count are shown together so the user
                           can read both "how many allocations" and "how many
                           SKUs" at a glance. *@
                        <MudTd Style="font-weight:600;" colspan="5">TOTAL (@fi.Count.ToString("N0") rows · @distinctItems.ToString("N0") distinct items)</MudTd>
                        <MudTd Style="font-weight:600;">@itTotQty.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@itTotSku.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@itTotSoh.ToString("N0")</MudTd>
                        <MudTd Style="font-weight:600;">@itTotLpm.ToString("N0")</MudTd>
                    </FooterContent>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 50, 100, 200, 500 }" />
                    </PagerContent>
                </MudTable>
            }
            else if (!_busy)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No item rows for this batch.</MudAlert>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    private List<string> _countries = new();
    private string _country = "UAE";
    private DateTime? _runDate;
    private long _batchNo;
    private List<BatchHeader> _batches = new();

    /// <summary>
    /// 1.14.70 — Filename tag derived from the current batch's <c>Sources</c>
    /// column so every Excel download names the LPM / Non-LPM run.
    /// 1.14.81 — Moved to a leading prefix (was a trailing suffix) and the
    /// Non-LPM form is now all-caps so it's visually distinct from LPM at a
    /// glance in the Downloads folder:
    /// <list type="bullet">
    ///   <item><c>"LPM"</c> → <c>"LPM_"</c></item>
    ///   <item><c>"Non-LPM"</c> or <c>"Non-LPM*"</c> → <c>"NONLPM_"</c></item>
    ///   <item><c>"LPM,Non-LPM"</c> → <c>"LPM_NONLPM_"</c></item>
    ///   <item>missing / unknown batch → <c>""</c> (filename omits the tag)</item>
    /// </list>
    /// The trailing <c>"*"</c> marker (IncludePurchasedBoxes) is stripped from
    /// the filename — it's metadata that lives in the DB, not something the
    /// planner browses by. Callers prepend this to the filename.
    /// </summary>
    private string CurrentBatchTag()
    {
        var b = _batches.FirstOrDefault(x => x.LPMBatchNo == _batchNo);
        var raw = b?.Sources;
        if (string.IsNullOrWhiteSpace(raw)) return "";
        // "Non-LPM*" → "Non-LPM"; ".Replace(",",..)" then ".Replace("-","")"
        // collapses "LPM,Non-LPM" to "LPM_NonLPM" and "Non-LPM" to "NonLPM".
        // ToUpperInvariant flips that to "LPM_NONLPM" / "NONLPM" so the Non-LPM
        // file can't be misread as LPM at a glance.
        var s = raw.TrimEnd('*').Trim()
                   .Replace(" ", "")
                   .Replace(",", "_")
                   .Replace("-", "")
                   .ToUpperInvariant();
        return string.IsNullOrEmpty(s) ? "" : s + "_";
    }
    private string _filterStore = "";
    private string _filterDiv = "";
    private int _activeTab;
    private bool _busy;
    private bool _rollupBoxOnly;
    // 1.14.62 — Excel download busy flag so the three per-tab buttons can't
    // be hammered before the previous workbook finishes streaming.
    private bool _downloadingExcel;

    private List<EomSummaryRow> _eomRows = new();
    private List<BoxDetailRow> _boxRows = new();
    private List<ItemDetailRow> _itemRows = new();

    // 1.14.60 — Item-list filter state. Uploaded itemcodes filter SIM Boxes
    // (boxes containing any matched item) + Item Details (matching item rows).
    // EOM Summary is store/div-level so the filter doesn't apply there.
    private HashSet<string> _itemFilter = new(StringComparer.OrdinalIgnoreCase);
    private string? _itemFilterFileName;
    private string? _itemFilterError;
    // Pre-computed BoxNo set derived from _itemRows × _itemFilter. Rebuilt by
    // RebuildBoxFilter() every time either side changes (upload, clear, batch
    // change, or item-rows refresh).
    private HashSet<string> _boxesContainingFilteredItems = new(StringComparer.OrdinalIgnoreCase);

    private IEnumerable<EomSummaryRow> FilteredEom =>
        _eomRows.Where(r => MatchStore(r.StoreID, r.StoreName) && MatchDiv(r.DivisionName));
    private IEnumerable<BoxDetailRow> FilteredBoxes =>
        _boxRows
            .Where(r => MatchStore(r.StoreID ?? "", r.StoreName ?? "") && MatchDiv(r.DivisionName ?? ""))
            // 1.14.60 — When the item filter is set, only show boxes containing
            // at least one matched item. Without the filter, no-op.
            .Where(r => _itemFilter.Count == 0 || _boxesContainingFilteredItems.Contains(r.BoxNo));
    private IEnumerable<ItemDetailRow> FilteredItems =>
        _itemRows
            .Where(r => MatchStore(r.StoreID, r.StoreName) && MatchDiv(r.DivisionName))
            // 1.14.60 — Direct itemcode filter on item rows.
            .Where(r => _itemFilter.Count == 0 || _itemFilter.Contains(r.Itemcode));

    private bool MatchStore(string storeId, string storeName)
    {
        if (string.IsNullOrWhiteSpace(_filterStore)) return true;
        var f = _filterStore.Trim();
        return storeId.Contains(f, StringComparison.OrdinalIgnoreCase)
            || storeName.Contains(f, StringComparison.OrdinalIgnoreCase);
    }
    private bool MatchDiv(string divName)
    {
        if (string.IsNullOrWhiteSpace(_filterDiv)) return true;
        return divName.Contains(_filterDiv.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _countries = await db.DataSettings
            .Where(s => s.ActiveStore == "Y" && s.Country != null && s.Country != "")
            .Select(s => s.Country!).Distinct().OrderBy(c => c).ToListAsync();
        if (!_countries.Contains(_country, StringComparer.OrdinalIgnoreCase))
            _country = _countries.FirstOrDefault() ?? "";
        await ReloadBatchesAsync();
    }

    private async Task OnRunDateChanged(DateTime? d)
    {
        _runDate = d;
        await ReloadBatchesAsync();
    }

    private async Task ReloadBatchesAsync()
    {
        _eomRows.Clear(); _boxRows.Clear(); _itemRows.Clear();
        if (string.IsNullOrEmpty(_country)) { _batches = new(); _batchNo = 0; StateHasChanged(); return; }
        try
        {
            // 1.14.67 — Pass the current user so "Running" batches that
            // another user started but hasn't finished are hidden from this
            // viewer (and won't pre-select as the latest batch).
            _batches = await Reports.ListBatchesAsync(_country, _runDate, CurrentUser.Name);
            _batchNo = _batches.FirstOrDefault()?.LPMBatchNo ?? 0;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to list batches: {ex.Message}", Severity.Error);
            _batches = new(); _batchNo = 0;
        }
        await LoadActiveTabAsync();
    }

    private async Task OnTabChanged(int idx)
    {
        _activeTab = idx;
        await LoadActiveTabAsync();
    }

    private async Task LoadActiveTabAsync()
    {
        if (_batchNo == 0) { StateHasChanged(); return; }
        switch (_activeTab)
        {
            case 0: await LoadEomAsync();   break;
            case 1: await LoadBoxesAsync(); break;
            case 2: await LoadItemsAsync(); break;
        }
    }

    private async Task LoadEomAsync()
    {
        _busy = true; StateHasChanged();
        try { _eomRows = await Reports.GetEomSummaryAsync(_batchNo); }
        catch (Exception ex) { Snackbar.Add($"EOM Summary failed: {ex.Message}", Severity.Error); _eomRows = new(); }
        finally { _busy = false; StateHasChanged(); }
    }

    private async Task LoadBoxesAsync()
    {
        _busy = true; StateHasChanged();
        try { _boxRows = await Reports.GetBoxDetailsAsync(_batchNo, _rollupBoxOnly); }
        catch (Exception ex) { Snackbar.Add($"Box report failed: {ex.Message}", Severity.Error); _boxRows = new(); }
        finally { _busy = false; StateHasChanged(); }
    }

    private async Task LoadItemsAsync()
    {
        _busy = true; StateHasChanged();
        try
        {
            _itemRows = await Reports.GetItemDetailsAsync(_batchNo);
            // 1.14.60 — Refresh the BoxNo set derived from items so the
            // SIM Boxes tab's item filter stays in sync after a batch swap
            // or a manual reload of the items tab.
            RebuildBoxFilter();
        }
        catch (Exception ex) { Snackbar.Add($"Item report failed: {ex.Message}", Severity.Error); _itemRows = new(); }
        finally { _busy = false; StateHasChanged(); }
    }

    // ─── 1.14.60 — Item-list Excel upload ──────────────────────────────

    /// <summary>
    /// Reads the uploaded workbook, validates the "Itemcode" header in A1,
    /// extracts itemcodes from A2 downward into _itemFilter, then ensures
    /// item rows are loaded for the current batch so the SIM Boxes filter
    /// (which needs BoxNo → Itemcode mapping) can resolve.
    /// </summary>
    private async Task OnItemFilterUploaded(IBrowserFile file)
    {
        _itemFilterError = null;
        _itemFilterFileName = file.Name;
        try
        {
            using var ms = await UploadHelpers.ReadUploadAsync(file);
            using var wb = new XLWorkbook(ms);
            var sheet = wb.Worksheets.First();
            // Header validation — match the user's chosen Excel format
            // (Itemcode in A1, data from A2 down).
            var header = UploadHelpers.TryString(sheet.Row(1).Cell(1));
            if (!string.Equals(header, "Itemcode", StringComparison.OrdinalIgnoreCase))
            {
                _itemFilterError = $"Header mismatch in A1: expected 'Itemcode', got '{header}'. " +
                                   "Download the template above for the correct shape.";
                _itemFilter.Clear();
                _itemFilterFileName = null;
                _boxesContainingFilteredItems.Clear();
                return;
            }
            _itemFilter.Clear();
            int lastRow;
            try { lastRow = sheet.LastRowUsed()?.RowNumber() ?? 1; } catch { lastRow = 10000; }
            for (int r = 2; r <= lastRow; r++)
            {
                var txt = UploadHelpers.TryString(sheet.Row(r).Cell(1));
                if (!string.IsNullOrWhiteSpace(txt))
                    _itemFilter.Add(txt.Trim());
            }
            if (_itemFilter.Count == 0)
            {
                _itemFilterError = "No itemcodes found in column A (rows 2+). File parsed OK but the column was empty.";
                _itemFilterFileName = null;
                return;
            }
            // The SIM Boxes filter needs item rows to resolve BoxNo membership.
            // Lazy-load if the user hasn't visited Item Details yet.
            if (_itemRows.Count == 0 && _batchNo > 0)
            {
                await LoadItemsAsync();
            }
            else
            {
                RebuildBoxFilter();
            }
            Snackbar.Add($"Loaded {_itemFilter.Count} itemcode(s) from {file.Name}.", Severity.Success);
        }
        catch (Exception ex)
        {
            _itemFilterError = $"Failed to read file: {ex.Message}";
            _itemFilter.Clear();
            _itemFilterFileName = null;
            _boxesContainingFilteredItems.Clear();
        }
    }

    private void ClearItemFilter()
    {
        _itemFilter.Clear();
        _itemFilterFileName = null;
        _itemFilterError = null;
        _boxesContainingFilteredItems.Clear();
        StateHasChanged();
    }

    /// <summary>
    /// Derives the BoxNo set containing at least one filtered itemcode from
    /// the currently loaded _itemRows. Called whenever either side changes:
    /// after an upload, after item-rows are (re)loaded, after batch swap.
    /// </summary>
    private void RebuildBoxFilter()
    {
        if (_itemFilter.Count == 0)
        {
            _boxesContainingFilteredItems.Clear();
            return;
        }
        _boxesContainingFilteredItems = new HashSet<string>(
            _itemRows.Where(r => _itemFilter.Contains(r.Itemcode))
                     .Select(r => r.BoxNo),
            StringComparer.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Emits a tiny template workbook the user can fill in. Header in A1
    /// only — no example rows, no extra columns. Matches the upload's
    /// validation exactly.
    /// </summary>
    private async Task DownloadItemFilterTemplate()
    {
        using var wb = new XLWorkbook();
        var sheet = wb.Worksheets.Add("Items");
        UploadHelpers.WriteHeader(sheet, new[] { "Itemcode" });
        // Two example itemcodes so the planner can see the expected shape.
        sheet.Cell(2, 1).Value = "3700943269072";
        sheet.Cell(3, 1).Value = "8904232736763";
        await UploadHelpers.DownloadAsync(JS, wb, "SimReports_ItemFilter_Template.xlsx");
    }

    // ─── 1.14.62 — Per-tab Excel downloads ─────────────────────────────
    //
    // Each handler mirrors the on-screen filtered view (Store/Division filter
    // + item-list filter both flow through via FilteredEom / FilteredBoxes /
    // FilteredItems). A TOTAL row appears at the bottom of each sheet with
    // the same totals shown in the header / footer.
    //
    // ClosedXML in-memory workbook → base64 → browser download via the
    // existing UploadHelpers.DownloadAsync. No DB hit; uses rows already
    // loaded for the tab.

    private async Task DownloadEomExcelAsync()
    {
        if (_downloadingExcel) return;
        _downloadingExcel = true; StateHasChanged();
        try
        {
            var rows = FilteredEom.ToList();
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("EOM Summary");
            string[] headers = { "Batch", "StoreID", "StoreName", "Division",
                                 "EOM", "SOH", "MerchNeed(Wk)", "LPM SIM Qty", "Override Qty" };
            for (int c = 0; c < headers.Length; c++)
            {
                ws.Cell(1, c + 1).Value = headers[c];
                ws.Cell(1, c + 1).Style.Font.Bold = true;
                ws.Cell(1, c + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int r = 2;
            foreach (var x in rows)
            {
                ws.Cell(r, 1).Value = x.LPMBatchNo;
                ws.Cell(r, 2).Value = x.StoreID;
                ws.Cell(r, 3).Value = x.StoreName;
                ws.Cell(r, 4).Value = x.DivisionName;
                if (x.EOM.HasValue)            ws.Cell(r, 5).Value = (double)x.EOM.Value;
                ws.Cell(r, 6).Value = x.SOH;
                if (x.MerchNeedWeek.HasValue)  ws.Cell(r, 7).Value = x.MerchNeedWeek.Value;
                ws.Cell(r, 8).Value = x.LpmSimQty;
                ws.Cell(r, 9).Value = x.OverrideQty;
                r++;
            }
            var totalRow = rows.Count + 2;
            ws.Cell(totalRow, 1).Value = $"TOTAL ({rows.Count:N0} rows)";
            ws.Cell(totalRow, 1).Style.Font.Bold = true;
            ws.Cell(totalRow, 5).Value = (double)rows.Sum(x => x.EOM ?? 0m);
            ws.Cell(totalRow, 6).Value = rows.Sum(x => (long)x.SOH);
            ws.Cell(totalRow, 7).Value = rows.Sum(x => (long)(x.MerchNeedWeek ?? 0));
            ws.Cell(totalRow, 8).Value = rows.Sum(x => (long)x.LpmSimQty);
            ws.Cell(totalRow, 9).Value = rows.Sum(x => (long)x.OverrideQty);
            for (int c = 5; c <= 9; c++) ws.Cell(totalRow, c).Style.Font.Bold = true;
            ws.Range(2, 5, totalRow, 9).Style.NumberFormat.Format = "#,##0";
            ws.Columns().AdjustToContents();

            // 1.14.70 — Filename includes the LPM / Non-LPM tag from the batch's Sources.
            // 1.14.81 — Tag moved to the LEADING prefix (was a trailing suffix) so the
            // Downloads-folder view groups LPM and NONLPM exports separately.
            var fileName = $"{CurrentBatchTag()}SimReports_EomSummary_Batch{_batchNo}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await UploadHelpers.DownloadAsync(JS, wb, fileName);
            Snackbar.Add($"Exported {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally { _downloadingExcel = false; StateHasChanged(); }
    }

    private async Task DownloadBoxesExcelAsync()
    {
        if (_downloadingExcel) return;
        _downloadingExcel = true; StateHasChanged();
        try
        {
            var rows = FilteredBoxes.ToList();
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("SIM Boxes");
            // Header set depends on roll-up mode (Store/Div columns appear
            // only when NOT rolled up — matches what's shown on screen).
            var headers = new List<string> { "Batch" };
            if (!_rollupBoxOnly) { headers.Add("StoreID"); headers.Add("StoreName"); headers.Add("Division"); }
            headers.AddRange(new[] { "BoxNo",
                                     // 1.14.81 — Kind (LPM / Non-LPM) + LPM Date, inserted after BoxNo
                                     // to mirror the on-screen layout.
                                     "Kind", "LPM Date",
                                     "Box Qty", "Allocated Qty", "SKU Usability %",
                                     "Pallet Type", "Type Name", "Pallet Category",
                                     // 1.14.70 — Pallet-purchase / GIN columns.
                                     "Purchase Dt", "GIN No", "GIN Date", "From/To",
                                     // 1.14.80 — Cont No + Recent Approved Batch (same country, other than this batch).
                                     "Cont No", "Recent Batch" });
            for (int c = 0; c < headers.Count; c++)
            {
                ws.Cell(1, c + 1).Value = headers[c];
                ws.Cell(1, c + 1).Style.Font.Bold = true;
                ws.Cell(1, c + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int r = 2;
            foreach (var x in rows)
            {
                int c = 1;
                ws.Cell(r, c++).Value = x.LPMBatchNo;
                if (!_rollupBoxOnly)
                {
                    ws.Cell(r, c++).Value = x.StoreID ?? "";
                    ws.Cell(r, c++).Value = x.StoreName ?? "";
                    ws.Cell(r, c++).Value = x.DivisionName ?? "";
                }
                ws.Cell(r, c++).Value = x.BoxNo;
                // 1.14.81 — Kind + LPM Date inserted right after BoxNo to match
                // the on-screen layout. Date written as DateTime so Excel sorts
                // it properly; blank when the box is Non-LPM.
                ws.Cell(r, c++).Value = x.BoxKind ?? "";
                if (x.LpmDate.HasValue) ws.Cell(r, c).Value = x.LpmDate.Value; c++;
                if (x.BoxQty.HasValue)             ws.Cell(r, c).Value = x.BoxQty.Value;        c++;
                ws.Cell(r, c++).Value = x.LpmSimQty;
                if (x.SkuUsabilityPct.HasValue)    ws.Cell(r, c).Value = (double)x.SkuUsabilityPct.Value;  c++;
                ws.Cell(r, c++).Value = x.PalletType ?? "";
                ws.Cell(r, c++).Value = x.TypeName ?? "";
                ws.Cell(r, c++).Value = x.PalletCategory ?? "";
                // 1.14.70 — Pallet-purchase / GIN columns. Excel handles
                // DateTime natively so dates land as proper sortable cells;
                // GIN No + From/To are free-text strings.
                if (x.PurDate.HasValue) ws.Cell(r, c).Value = x.PurDate.Value; c++;
                ws.Cell(r, c++).Value = x.GINNo ?? "";
                if (x.GinDate.HasValue) ws.Cell(r, c).Value = x.GinDate.Value; c++;
                ws.Cell(r, c++).Value = x.FromTo ?? "";
                // 1.14.80 — Cont No (free text) + Recent Batch (numeric — keeps
                // Excel sort/filter useful; blank when no earlier batch matches).
                ws.Cell(r, c++).Value = x.ContNo ?? "";
                if (x.RecentBatchNo.HasValue) ws.Cell(r, c).Value = x.RecentBatchNo.Value; c++;
                r++;
            }
            // TOTAL row — Box Qty deduped by BoxNo, Allocated summed, Usability averaged.
            var distinctBoxes = rows.GroupBy(x => x.BoxNo).ToList();
            var totBoxQty  = distinctBoxes.Sum(g => (long)(g.First().BoxQty ?? 0));
            var totAlloc   = rows.Sum(x => (long)x.LpmSimQty);
            var avgUse     = rows.Count > 0 ? rows.Average(x => x.SkuUsabilityPct ?? 0m) : 0m;
            // 1.14.81 — boxQtyCol shifted +2: Kind + LPM Date were inserted
            // after BoxNo, so Box Qty now lives at column 5 (rollup) / 8 (non-rollup)
            // rather than 3 / 6. Allocated + Usability shift along with it.
            int boxQtyCol  = _rollupBoxOnly ? 5 : 8;
            int allocCol   = boxQtyCol + 1;
            int usableCol  = boxQtyCol + 2;
            var totalRow = rows.Count + 2;
            ws.Cell(totalRow, 1).Value = $"TOTAL ({rows.Count:N0} rows · {distinctBoxes.Count:N0} distinct boxes)";
            ws.Cell(totalRow, 1).Style.Font.Bold = true;
            ws.Cell(totalRow, boxQtyCol).Value = totBoxQty;
            ws.Cell(totalRow, allocCol).Value  = totAlloc;
            ws.Cell(totalRow, usableCol).Value = (double)avgUse;
            ws.Cell(totalRow, boxQtyCol).Style.Font.Bold = true;
            ws.Cell(totalRow, allocCol).Style.Font.Bold  = true;
            ws.Cell(totalRow, usableCol).Style.Font.Bold = true;
            ws.Range(2, boxQtyCol, totalRow, allocCol).Style.NumberFormat.Format = "#,##0";
            ws.Range(2, usableCol, totalRow, usableCol).Style.NumberFormat.Format = "0.0";
            ws.Columns().AdjustToContents();

            // 1.14.70 — Filename includes the LPM / Non-LPM tag from the batch's Sources.
            // 1.14.81 — Tag moved to leading prefix (was a trailing suffix).
            var fileName = $"{CurrentBatchTag()}SimReports_SimBoxes_Batch{_batchNo}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await UploadHelpers.DownloadAsync(JS, wb, fileName);
            Snackbar.Add($"Exported {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally { _downloadingExcel = false; StateHasChanged(); }
    }

    private async Task DownloadItemsExcelAsync()
    {
        if (_downloadingExcel) return;
        _downloadingExcel = true; StateHasChanged();
        try
        {
            var rows = FilteredItems.ToList();
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Item Details");
            string[] headers = { "Batch", "StoreID", "StoreName", "Division", "BoxNo",
                                 "Itemcode", "Qty", "SKU Max", "SOH", "LPM Qty" };
            for (int c = 0; c < headers.Length; c++)
            {
                ws.Cell(1, c + 1).Value = headers[c];
                ws.Cell(1, c + 1).Style.Font.Bold = true;
                ws.Cell(1, c + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
            }
            int r = 2;
            foreach (var x in rows)
            {
                ws.Cell(r, 1).Value = x.LPMBatchNo;
                ws.Cell(r, 2).Value = x.StoreID;
                ws.Cell(r, 3).Value = x.StoreName;
                ws.Cell(r, 4).Value = x.DivisionName;
                ws.Cell(r, 5).Value = x.BoxNo;
                ws.Cell(r, 6).Value = x.Itemcode;
                if (x.BoxItemQty.HasValue) ws.Cell(r, 7).Value = x.BoxItemQty.Value;
                if (x.SKUMax.HasValue)     ws.Cell(r, 8).Value = x.SKUMax.Value;
                ws.Cell(r, 9).Value  = x.SOH;
                ws.Cell(r, 10).Value = x.LpmQty;
                r++;
            }
            var distinctItems = rows.Select(x => x.Itemcode).Distinct(StringComparer.OrdinalIgnoreCase).Count();
            var totalRow = rows.Count + 2;
            ws.Cell(totalRow, 1).Value = $"TOTAL ({rows.Count:N0} rows · {distinctItems:N0} distinct items)";
            ws.Cell(totalRow, 1).Style.Font.Bold = true;
            ws.Cell(totalRow, 7).Value  = rows.Sum(x => (long)(x.BoxItemQty ?? 0));
            ws.Cell(totalRow, 8).Value  = rows.Sum(x => (long)(x.SKUMax ?? 0));
            ws.Cell(totalRow, 9).Value  = rows.Sum(x => (long)x.SOH);
            ws.Cell(totalRow, 10).Value = rows.Sum(x => (long)x.LpmQty);
            for (int c = 7; c <= 10; c++) ws.Cell(totalRow, c).Style.Font.Bold = true;
            ws.Range(2, 7, totalRow, 10).Style.NumberFormat.Format = "#,##0";
            ws.Columns().AdjustToContents();

            // 1.14.70 — Filename includes the LPM / Non-LPM tag from the batch's Sources.
            // 1.14.81 — Tag moved to leading prefix (was a trailing suffix).
            var fileName = $"{CurrentBatchTag()}SimReports_ItemDetails_Batch{_batchNo}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await UploadHelpers.DownloadAsync(JS, wb, fileName);
            Snackbar.Add($"Exported {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally { _downloadingExcel = false; StateHasChanged(); }
    }
