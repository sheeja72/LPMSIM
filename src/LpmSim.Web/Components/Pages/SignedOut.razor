@page "/signed-out"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Signed out — Planning Hub</PageTitle>

<div style="background:#ffffff;border-radius:12px;padding:2rem 2.5rem;max-width:520px;
            box-shadow:0 18px 40px rgba(0,0,0,.35);text-align:center;">
    <div style="font-size:2.5rem;color:#ca8a04;margin-bottom:.5rem;">⏱️</div>
    <h2 style="margin:0 0 .25rem;color:#0f172a;font-weight:600;">You have been signed out</h2>
    <p style="margin:.25rem 0 1rem;color:#475569;font-size:.95rem;">
        Your session was ended due to inactivity (or you clicked Sign Out).
    </p>
    <p style="margin:.25rem 0 1.5rem;color:#475569;font-size:.9rem;">
        To continue using Planning Hub, <strong>close this browser tab</strong>
        and reopen the application from your shortcut. Your Windows
        credentials will be revalidated on the next launch.
    </p>
    <a href="/" style="display:inline-block;background:#2563eb;color:#fff;text-decoration:none;
                       padding:.55rem 1.25rem;border-radius:6px;font-weight:600;font-size:.92rem;">
        Reopen Planning Hub
    </a>
</div>
