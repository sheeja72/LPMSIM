@using ClosedXML.Excel
@using System.IO
@using LpmSim.Web.Components.Pages.Uploads
@inject IDbContextFactory<LpmDbContext> DbFactory
@inject ICurrentUser CurrentUser
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudGrid Spacing="3">
    <MudItem xs="12" md="4">
        <div class="lpm-section">
            <div class="lpm-section-title">Template</div>
            <div class="lpm-section-sub">
                Per-period weights used by EOM Generate. 13 rows per (Country, RunYear, RunMonth)
                summing to 100%.
            </div>
            <MudChipSet T="string" ReadOnly="true" Class="mb-3">
                @foreach (var h in Header) { <MudChip T="string" Size="Size.Small">@h</MudChip> }
            </MudChipSet>
            <MudButton OnClick="DownloadTemplate" StartIcon="@Icons.Material.Filled.Download"
                       Variant="Variant.Outlined" Color="Color.Primary" DropShadow="false">Download template</MudButton>
        </div>
        <div class="lpm-section">
            <div class="lpm-section-title">Rules</div>
            <ul class="pl-4 mb-0" style="font-size:0.82rem; color:#64748b;">
                <li><strong>Country</strong> must exist in DataSettings (case-insensitive).</li>
                <li><strong>PeriodSeq</strong> 1–13. <strong>WeightPct</strong> accepts "25" or "25%" or "0.25".</li>
                <li><strong>1.14.41:</strong> Two rows sharing the same <code>(PeriodYear, PeriodMonth)</code> within one <code>(Country, RunYear, RunMonth)</code> are flagged as errors — fix in Excel before committing.</li>
                <li><strong>1.14.41:</strong> Commit is now <strong>replace-all per run period</strong>. Every existing row for each <code>(Country, RunYear, RunMonth)</code> in the file is wiped before the new rows are inserted — no orphaned PeriodSeq survives from a prior upload.</li>
            </ul>
        </div>
    </MudItem>
    <MudItem xs="12" md="8">
        <div class="lpm-section">
            <div class="lpm-section-title">Upload file</div>
            <MudFileUpload T="IBrowserFile" FilesChanged="OnFileSelected" Accept=".xlsx">
                <ActivatorContent>
                    <div class="lpm-dropzone">
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.body1" Class="mt-2">Drop an <strong>.xlsx</strong> file here, or click.</MudText>
                        @if (_fileName is not null)
                        {
                            <MudText Typo="Typo.body2" Class="mt-2" Style="font-weight:600;">@_fileName</MudText>
                        }
                    </div>
                </ActivatorContent>
            </MudFileUpload>
        </div>

        @if (_parsing) { <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-2" /> }
        @if (_fatalError is not null) { <MudAlert Severity="Severity.Error" Class="mb-3">@_fatalError</MudAlert> }

        @if (_rows.Count > 0)
        {
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-blue"><div class="lpm-metric-label">Total Rows</div><div class="lpm-metric-value">@_rows.Count</div></div></MudItem>
                <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-green"><div class="lpm-metric-label">Valid</div><div class="lpm-metric-value">@_validCount</div></div></MudItem>
                <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-rose"><div class="lpm-metric-label">Errors</div><div class="lpm-metric-value">@_errorCount</div></div></MudItem>
                <MudItem xs="6" md="3"><div class="lpm-metric-card lpm-accent-amber"><div class="lpm-metric-label">Will Upsert</div><div class="lpm-metric-value">@_validCount</div></div></MudItem>
            </MudGrid>

            @* 1.14.41 — Error breakdown section, same UX as SkuMaxRulesUpload
               (1.14.38) and VolumeGroupsUpload (1.14.39). Groups error rows
               by message + shows counts so the planner sees the dominant
               issue pattern (e.g. "Duplicate (PeriodYear, PeriodMonth): 4 rows"). *@
            @if (_errorCount > 0)
            {
                var errorGroups = _rows
                    .Where(r => r.Error is not null)
                    .GroupBy(r => r.Error!)
                    .Select(g => new { Message = g.Key, Count = g.Count(), SampleRows = g.Take(5).Select(r => r.RowNum).ToList() })
                    .OrderByDescending(x => x.Count)
                    .ToList();
                <div class="lpm-section mb-3" style="border-left:4px solid #dc2626;">
                    <div class="lpm-section-title" style="color:#dc2626;">
                        Error breakdown — @_errorCount row(s) across @errorGroups.Count distinct issue(s)
                    </div>
                    <MudTable Items="errorGroups" Hover Dense Striped Height="240px" FixedHeader>
                        <HeaderContent>
                            <MudTh Style="width:90px;">Count</MudTh>
                            <MudTh>Issue</MudTh>
                            <MudTh Style="width:220px;">Sample row #s</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="text-align:right;font-weight:600;color:#dc2626;">@context.Count.ToString("N0")</MudTd>
                            <MudTd><span style="font-family:monospace;font-size:0.85rem;">@context.Message</span></MudTd>
                            <MudTd Style="color:#64748b;font-size:0.82rem;">@string.Join(", ", context.SampleRows)</MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            }

            var displayRows = _errorCount > 0
                ? _rows.OrderBy(r => r.Error is null ? 1 : 0).Take(200)
                : _rows.Take(200);
            <MudTable Items="displayRows" Hover Dense Striped FixedHeader Height="50vh">
                <HeaderContent>
                    <MudTh>Row</MudTh><MudTh>Country</MudTh><MudTh>RunY</MudTh><MudTh>RunM</MudTh>
                    <MudTh>Seq</MudTh><MudTh>PeriodY</MudTh><MudTh>PeriodM</MudTh><MudTh>Weight%</MudTh><MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.RowNum</MudTd>
                    <MudTd>@context.Country</MudTd>
                    <MudTd>@context.RunYear</MudTd>
                    <MudTd>@context.RunMonth</MudTd>
                    <MudTd>@context.PeriodSeq</MudTd>
                    <MudTd>@context.PeriodYear</MudTd>
                    <MudTd>@context.PeriodMonth</MudTd>
                    <MudTd>@(context.WeightPct.HasValue ? (context.WeightPct.Value * 100m).ToString("0.##") + "%" : "")</MudTd>
                    <MudTd>
                        @if (context.Error is null) { <span class="lpm-status lpm-status-ok">OK</span> }
                        else                         { <span class="lpm-status lpm-status-err">@context.Error</span> }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <div class="d-flex justify-end mt-3">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false"
                           StartIcon="@Icons.Material.Filled.Save"
                           Disabled="_committing || _validCount == 0" OnClick="CommitAsync">
                    Commit @_validCount row(s)
                </MudButton>
            </div>
        }
    </MudItem>
</MudGrid>

@code {
    private static readonly string[] Header =
        { "Country", "RunYear", "RunMonth", "PeriodSeq", "PeriodYear", "PeriodMonth", "WeightPct" };

    private string? _fileName;
    private bool _parsing, _committing;
    private string? _fatalError;
    private List<Row> _rows = new();
    private int _validCount, _errorCount;

    private async Task OnFileSelected(IBrowserFile file)
    {
        _fileName = file.Name; _rows.Clear(); _fatalError = null;
        _validCount = _errorCount = 0;
        _parsing = true; StateHasChanged();
        try
        {
            using var ms = await UploadHelpers.ReadUploadAsync(file);
            await ParseAsync(ms);
        }
        catch (Exception ex) { _fatalError = $"Failed to read file: {ex.Message}"; }
        finally { _parsing = false; StateHasChanged(); }
    }

    private async Task ParseAsync(Stream xlsx)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var countrySet = new HashSet<string>(
            await db.DataSettings.AsNoTracking().Where(s => s.Country != null && s.Country != "")
                .Select(s => s.Country!).Distinct().ToListAsync(),
            StringComparer.OrdinalIgnoreCase);

        try
        {
            using var wb = new XLWorkbook(xlsx);
            var sheet = wb.Worksheets.First();
            for (int i = 0; i < Header.Length; i++)
            {
                var got = UploadHelpers.TryString(sheet.Row(1).Cell(i + 1));
                if (!string.Equals(got, Header[i], StringComparison.OrdinalIgnoreCase))
                {
                    _fatalError = $"Header mismatch col {i + 1}: expected '{Header[i]}', got '{got}'.";
                    return;
                }
            }

            int lastRow;
            try { lastRow = sheet.LastRowUsed()?.RowNumber() ?? 1; } catch { lastRow = 10000; }

            for (int r = 2; r <= lastRow; r++)
            {
                var xlRow = sheet.Row(r);
                if (!UploadHelpers.RowIsUsed(xlRow)) continue;
                var (ctry, e1) = UploadHelpers.CellText(xlRow, 1, "Country");
                var (ry,   e2) = UploadHelpers.CellInt(xlRow, 2, "RunYear");
                var (rm,   e3) = UploadHelpers.CellInt(xlRow, 3, "RunMonth");
                var (sq,   e4) = UploadHelpers.CellInt(xlRow, 4, "PeriodSeq");
                var (py,   e5) = UploadHelpers.CellInt(xlRow, 5, "PeriodYear");
                var (pm,   e6) = UploadHelpers.CellInt(xlRow, 6, "PeriodMonth");
                var (wp,   e7) = UploadHelpers.CellPct(xlRow, 7, "WeightPct");

                var row = new Row
                {
                    RowNum = r, Country = ctry, RunYear = ry, RunMonth = rm,
                    PeriodSeq = sq, PeriodYear = py, PeriodMonth = pm, WeightPct = wp,
                };
                var problems = new List<string>(new[] { e1, e2, e3, e4, e5, e6, e7 }.Where(e => !string.IsNullOrEmpty(e)));
                if (string.IsNullOrWhiteSpace(ctry))                                   problems.Add("Country blank");
                else if (!countrySet.Contains(ctry))                                   problems.Add($"Country '{ctry}' not in DataSettings");
                if (ry is null || ry < 2000 || ry > 2100)                              problems.Add("RunYear out of range");
                if (rm is null || rm < 1 || rm > 12)                                   problems.Add("RunMonth must be 1..12");
                if (sq is null || sq < 1 || sq > 13)                                   problems.Add("PeriodSeq must be 1..13");
                if (py is null || py < 2000 || py > 2100)                              problems.Add("PeriodYear out of range");
                if (pm is null || pm < 1 || pm > 12)                                   problems.Add("PeriodMonth must be 1..12");
                if (wp is null)                                                        problems.Add("WeightPct blank");
                if (problems.Count > 0) row.Error = string.Join("; ", problems);
                _rows.Add(row);
            }
        }
        catch (Exception ex) { _fatalError = $"Failed to open workbook: {ex.Message}"; return; }

        // 1.14.41 — In-file duplicate detection on
        // (Country, RunYear, RunMonth, PeriodYear, PeriodMonth). PK on
        // LPM_MonthlyWeight is (Country, RunYear, RunMonth, PeriodSeq) —
        // PeriodSeq makes it possible to enter the same period TWICE under
        // different seq numbers (e.g. 2026-3 at seq 1 AND at seq 11). SQL
        // accepts both, total becomes 200%, EOM Generate fails readiness.
        // Surfacing this at parse time forces the planner to fix the file
        // before commit.
        //
        // Only checks among rows that are otherwise valid — already-errored
        // rows don't need extra noise.
        var firstSeenAt = new Dictionary<(string Country, int RunYear, int RunMonth, int PeriodYear, int PeriodMonth), int>();
        foreach (var r in _rows.Where(x => x.Error is null && x.Country is not null
                                        && x.RunYear is not null && x.RunMonth is not null
                                        && x.PeriodYear is not null && x.PeriodMonth is not null))
        {
            // Country normalised to uppercase so case differences within
            // the same upload still trigger the dup check.
            var key = (r.Country!.ToUpperInvariant(), r.RunYear!.Value, r.RunMonth!.Value,
                       r.PeriodYear!.Value, r.PeriodMonth!.Value);
            if (firstSeenAt.TryGetValue(key, out var firstRow))
            {
                // Both the earlier row AND this one get the error so the
                // planner can find both in the row preview.
                var msg = $"Duplicate period ({r.PeriodYear}-{r.PeriodMonth:D2}) for ({r.Country}, RunY={r.RunYear}, RunM={r.RunMonth}) — also at row {firstRow}";
                r.Error = msg;
                var prior = _rows.FirstOrDefault(x => x.RowNum == firstRow);
                if (prior is not null && prior.Error is null)
                    prior.Error = $"Duplicate period ({r.PeriodYear}-{r.PeriodMonth:D2}) for ({r.Country}, RunY={r.RunYear}, RunM={r.RunMonth}) — also at row {r.RowNum}";
            }
            else
            {
                firstSeenAt[key] = r.RowNum;
            }
        }

        _validCount = _rows.Count(r => r.Error is null);
        _errorCount = _rows.Count - _validCount;
    }

    private async Task CommitAsync()
    {
        _committing = true; StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var now = DateTime.Now;
            var valid = _rows.Where(r => r.Error is null).ToList();
            if (valid.Count == 0) return;

            // 1.14.41 — Commit is now replace-all per run period. The natural
            // unit of Monthly Weights is "13 rows summing to 100% for one
            // (Country, RunYear, RunMonth)". Partial uploads — keeping some
            // old PeriodSeq rows alongside new ones — never make sense and
            // were the root of the duplicate-period bug surfaced in 1.14.41.
            //
            // For each (Country, RunYear, RunMonth) in the upload: DELETE
            // every existing row, then INSERT the new ones. Atomic in a single
            // SaveChanges so we never leave the table in a half-old/half-new
            // state.
            var periods = valid
                .Select(r => (Country: r.Country!, RunYear: r.RunYear!.Value, RunMonth: r.RunMonth!.Value))
                .Distinct()
                .ToList();

            // Load all existing rows for these (Country, RunYear, RunMonth)
            // periods in a single round-trip. EF can't directly translate
            // a multi-tuple-IN, so we build a flat OR over the periods.
            var countries  = periods.Select(p => p.Country).Distinct().ToList();
            var runYears   = periods.Select(p => p.RunYear).Distinct().ToList();
            var runMonths  = periods.Select(p => p.RunMonth).Distinct().ToList();
            var candidates = await db.LpmMonthlyWeights
                .Where(w => countries.Contains(w.Country)
                         && runYears.Contains(w.RunYear)
                         && runMonths.Contains(w.RunMonth))
                .ToListAsync();
            // Filter to exact (Country, RunYear, RunMonth) tuples after the
            // round-trip — the broad IN above can over-fetch when one of the
            // periods doesn't share Country/Year/Month with another in the
            // batch, but the in-memory filter is cheap.
            var periodSet = new HashSet<(string, int, int)>(
                periods.Select(p => (p.Country, p.RunYear, p.RunMonth)),
                new TupleCountryRunComparerCI());
            var toRemove = candidates
                .Where(w => periodSet.Contains((w.Country, w.RunYear, w.RunMonth)))
                .ToList();
            db.LpmMonthlyWeights.RemoveRange(toRemove);

            foreach (var r in valid)
            {
                db.LpmMonthlyWeights.Add(new LpmMonthlyWeight
                {
                    Country     = r.Country!,
                    RunYear     = r.RunYear!.Value,
                    RunMonth    = r.RunMonth!.Value,
                    PeriodSeq   = r.PeriodSeq!.Value,
                    PeriodYear  = r.PeriodYear!.Value,
                    PeriodMonth = r.PeriodMonth!.Value,
                    WeightPct   = r.WeightPct!.Value,
                    CreateTS    = now,
                });
            }

            await db.SaveChangesAsync();
            Snackbar.Add(
                $"Replaced {periods.Count} run period(s) — removed {toRemove.Count} old row(s), inserted {valid.Count} new row(s).",
                Severity.Success);
            _rows.Clear(); _fileName = null; _validCount = _errorCount = 0;
        }
        catch (Exception ex) { Snackbar.Add($"Commit failed: {ex.Message}", Severity.Error); }
        finally { _committing = false; StateHasChanged(); }
    }

    /// <summary>
    /// 1.14.41 — Case-insensitive equality on (Country, RunYear, RunMonth)
    /// so a re-upload of 'Uae' after 'UAE' rows exist still wipes them.
    /// </summary>
    private sealed class TupleCountryRunComparerCI : IEqualityComparer<(string Country, int RunYear, int RunMonth)>
    {
        public bool Equals((string Country, int RunYear, int RunMonth) x, (string Country, int RunYear, int RunMonth) y)
            => StringComparer.OrdinalIgnoreCase.Equals(x.Country, y.Country)
            && x.RunYear == y.RunYear
            && x.RunMonth == y.RunMonth;
        public int GetHashCode((string Country, int RunYear, int RunMonth) obj)
            => HashCode.Combine(
                StringComparer.OrdinalIgnoreCase.GetHashCode(obj.Country ?? ""),
                obj.RunYear,
                obj.RunMonth);
    }

    private async Task DownloadTemplate()
    {
        using var wb = new XLWorkbook();
        var sheet = wb.Worksheets.Add("Monthly_Weights");
        UploadHelpers.WriteHeader(sheet, Header);
        await UploadHelpers.DownloadAsync(JS, wb, "MonthlyWeights_Template.xlsx");
    }

    private sealed class Row
    {
        public int RowNum { get; init; }
        public string? Country { get; init; }
        public int? RunYear { get; init; }
        public int? RunMonth { get; init; }
        public int? PeriodSeq { get; init; }
        public int? PeriodYear { get; init; }
        public int? PeriodMonth { get; init; }
        public decimal? WeightPct { get; init; }
        public string? Error { get; set; }
    }
}
