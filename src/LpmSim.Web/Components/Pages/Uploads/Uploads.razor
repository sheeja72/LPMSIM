@page "/lpm/uploads"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.AdminOrEditor)]

<PageTitle>Data Uploads</PageTitle>

<div class="lpm-page-title">Data Uploads</div>
<div class="lpm-page-subtitle">
    Import the Excel workbooks used by EOM Generate. Each file is validated before commit;
    you can review the preview and errors before any data hits the database.
</div>

<MudTabs Elevation="0" Rounded="true" Border="true"
         ApplyEffectsToContainer="true" PanelClass="pa-4" Class="mud-paper">
    <MudTabPanel Text="Sales &amp; Turns" Icon="@Icons.Material.Filled.TrendingUp">
        <SalesTurnsUpload />
    </MudTabPanel>
    <MudTabPanel Text="WH Stock" Icon="@Icons.Material.Filled.Inventory2">
        <WHStockUpload />
    </MudTabPanel>
    <MudTabPanel Text="Monthly Weights" Icon="@Icons.Material.Filled.EventNote">
        <MonthlyWeightsUpload />
    </MudTabPanel>
    <MudTabPanel Text="Planned Inputs" Icon="@Icons.Material.Filled.RequestQuote">
        <PlannedInputsUpload />
    </MudTabPanel>
    <MudTabPanel Text="Store Grades" Icon="@Icons.Material.Filled.WorkspacePremium">
        <StoreGradesUpload />
    </MudTabPanel>
    <MudTabPanel Text="Volume Groups" Icon="@Icons.Material.Filled.DonutSmall">
        <VolumeGroupsUpload />
    </MudTabPanel>
    <MudTabPanel Text="SKU Max Rules" Icon="@Icons.Material.Filled.Rule">
        <SkuMaxRulesUpload />
    </MudTabPanel>
    <MudTabPanel Text="Stores Capacity" Icon="@Icons.Material.Filled.Storefront">
        <StoresCapacityUpload />
    </MudTabPanel>
</MudTabs>
