@using LpmSim.Data.Auditing
@inject IDbContextFactory<LpmDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IActionLogger ActionLog

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            @* 1.14.39 — Division is now part of the PK. Required on Add.
               On Edit it's disabled (changing DivCode would orphan the row
               under the old key). To move a group to a different Division,
               delete + re-add. *@
            <MudSelect T="int" Value="Model.DivCode"
                       ValueChanged="(int v) => Model.DivCode = v"
                       Label="Division" Required="true"
                       Disabled="@(!IsNew)" Variant="Variant.Outlined">
                @foreach (var d in Divisions)
                {
                    <MudSelectItem T="int" Value="d.DivCode">@d.Name (@d.DivCode)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField T="string" Value="Model.GroupCode"
                          ValueChanged="v => Model.GroupCode = v ?? string.Empty"
                          Label="Code" Placeholder="e.g. A"
                          Disabled="@(!IsNew)" Required="true" Variant="Variant.Outlined" />
            <MudTextField T="string" Value="Model.GroupName"
                          ValueChanged="v => Model.GroupName = v ?? string.Empty"
                          Label="Name" Variant="Variant.Outlined" />
            <MudNumericField T="int" Value="Model.SortOrder"
                             ValueChanged="(int v) => Model.SortOrder = v"
                             Label="Sort Order" Variant="Variant.Outlined" Min="1" />
            <MudNumericField T="decimal" Value="SharePctDisplay"
                             ValueChanged="(decimal v) => Model.SharePct = v / 100m"
                             Label="Share %" Variant="Variant.Outlined"
                             Min="0m" Max="100m" Step="0.01m" />
            <MudSwitch T="bool" Value="Model.IsActive"
                       ValueChanged="(bool v) => Model.IsActive = v"
                       Label="Active" Color="Color.Success" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false"
                   OnClick="SaveAsync" Disabled="_saving">
            @(IsNew ? "Add" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public LpmVolumeGroup Model { get; set; } = new();
    [Parameter] public bool IsNew { get; set; }
    /// <summary>1.14.39 — Division list passed in by the parent so the
    /// dropdown doesn't re-query the DB on every dialog open.</summary>
    [Parameter] public List<Division> Divisions { get; set; } = new();

    private bool _saving;

    private decimal SharePctDisplay => Math.Round(Model.SharePct * 100m, 4);

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Model.GroupCode))
        {
            Snackbar.Add("Code is required.", Severity.Error);
            return;
        }
        // 1.14.39 — Division required (DivCode is part of the new PK).
        if (Model.DivCode <= 0)
        {
            Snackbar.Add("Division is required.", Severity.Error);
            return;
        }
        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (IsNew)
            {
                // Existence check now includes DivCode.
                if (await db.LpmVolumeGroups.AnyAsync(x =>
                        x.Country == Model.Country && x.DivCode == Model.DivCode && x.GroupCode == Model.GroupCode))
                {
                    Snackbar.Add($"A group with that code already exists for {Model.Country} / Div {Model.DivCode}.", Severity.Warning);
                    return;
                }
                db.LpmVolumeGroups.Add(new LpmVolumeGroup
                {
                    Country   = Model.Country,
                    DivCode   = Model.DivCode,
                    GroupCode = Model.GroupCode.Trim(),
                    GroupName = Model.GroupName,
                    SortOrder = Model.SortOrder,
                    SharePct = Model.SharePct,
                    IsActive = Model.IsActive,
                    CreateTS = DateTime.Now,
                });
            }
            else
            {
                var row = await db.LpmVolumeGroups.FirstAsync(x =>
                    x.Country == Model.Country && x.DivCode == Model.DivCode && x.GroupCode == Model.GroupCode);
                row.GroupName = Model.GroupName;
                row.SortOrder = Model.SortOrder;
                row.SharePct = Model.SharePct;
                row.IsActive = Model.IsActive;
            }
            await db.SaveChangesAsync();
            Snackbar.Add("Saved.", Severity.Success);
            await ActionLog.LogAsync(IsNew ? "VolumeGroups.Add" : "VolumeGroups.Edit",
                $"{Model.Country}/Div{Model.DivCode}/{Model.GroupCode}",
                new { country = Model.Country, divCode = Model.DivCode, groupCode = Model.GroupCode,
                      groupName = Model.GroupName, sortOrder = Model.SortOrder, sharePct = Model.SharePct,
                      isActive = Model.IsActive },
                action: 'X');
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
