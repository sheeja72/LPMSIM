@inject IDbContextFactory<LpmDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" Value="Model.GradeCode"
                          ValueChanged="v => Model.GradeCode = v ?? string.Empty"
                          Label="Code" Placeholder="e.g. Diamond"
                          Disabled="@(!IsNew)" Required="true" Variant="Variant.Outlined" />
            <MudTextField T="string" Value="Model.GradeName"
                          ValueChanged="v => Model.GradeName = v ?? string.Empty"
                          Label="Name" Variant="Variant.Outlined" />
            <MudNumericField T="int" Value="Model.SortOrder"
                             ValueChanged="(int v) => Model.SortOrder = v"
                             Label="Sort Order" Variant="Variant.Outlined" Min="1" />
            <MudNumericField T="decimal" Value="SharePctDisplay"
                             ValueChanged="(decimal v) => Model.SharePct = v / 100m"
                             Label="Share %" Variant="Variant.Outlined"
                             Min="-100m" Max="100m" Step="0.01m"
                             HelperText="Negative and zero allowed" />
            <MudNumericField T="decimal" Value="MarkupPctDisplay"
                             ValueChanged="(decimal v) => Model.MarkupPct = v / 100m"
                             Label="Markup %" Variant="Variant.Outlined"
                             Min="-100m" Max="100m" Step="0.01m"
                             HelperText="Negative = over-performs plan; 0 = matches plan" />
            <MudSwitch T="bool" Value="Model.IsActive"
                       ValueChanged="(bool v) => Model.IsActive = v"
                       Label="Active" Color="Color.Success" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false"
                   OnClick="SaveAsync" Disabled="_saving">
            @(IsNew ? "Add" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public LpmStoreGrade Model { get; set; } = new();
    [Parameter] public bool IsNew { get; set; }

    private bool _saving;

    private decimal SharePctDisplay => Math.Round(Model.SharePct * 100m, 4);
    private decimal MarkupPctDisplay => Math.Round(Model.MarkupPct * 100m, 4);

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Model.GradeCode))
        {
            Snackbar.Add("Code is required.", Severity.Error);
            return;
        }
        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (IsNew)
            {
                if (await db.LpmStoreGrades.AnyAsync(x => x.Country == Model.Country && x.GradeCode == Model.GradeCode))
                {
                    Snackbar.Add("A grade with that code already exists for this country.", Severity.Warning);
                    return;
                }
                db.LpmStoreGrades.Add(new LpmStoreGrade
                {
                    Country   = Model.Country,
                    GradeCode = Model.GradeCode.Trim(),
                    GradeName = Model.GradeName,
                    SortOrder = Model.SortOrder,
                    SharePct = Model.SharePct,
                    MarkupPct = Model.MarkupPct,
                    IsActive = Model.IsActive,
                    CreateTS = DateTime.Now,
                });
            }
            else
            {
                var row = await db.LpmStoreGrades.FirstAsync(x => x.Country == Model.Country && x.GradeCode == Model.GradeCode);
                row.GradeName = Model.GradeName;
                row.SortOrder = Model.SortOrder;
                row.SharePct = Model.SharePct;
                row.MarkupPct = Model.MarkupPct;
                row.IsActive = Model.IsActive;
            }
            await db.SaveChangesAsync();
            Snackbar.Add("Saved.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
