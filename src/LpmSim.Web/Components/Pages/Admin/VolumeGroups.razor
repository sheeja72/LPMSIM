@page "/admin/volume-groups"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.AdminOrPlanner)]
@using LpmSim.Data.Auditing
@inject IDbContextFactory<LpmDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IActionLogger ActionLog

<PageTitle>Volume Groups</PageTitle>

<div class="lpm-page-title">Volume Groups</div>
<div class="lpm-page-subtitle">
    Configure volume group share % used to bucket stores after Target EOM is calculated.
    <strong>1.14.39 — Groups are now per-Division.</strong> Each division's active rows should sum to 100%.
</div>

<div class="lpm-section lpm-filter-bar mb-3">
    <MudGrid Spacing="2" Class="align-center">
        <MudItem xs="12" md="3">
            <MudSelect T="string" Label="Country" Value="_country"
                       ValueChanged="async v => { _country = v ?? string.Empty; await ReloadAsync(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var c in _countries)
                {
                    <MudSelectItem Value="@c">@c</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="int" Label="Division (filter)" Value="_divFilter"
                       ValueChanged="(int v) => { _divFilter = v; StateHasChanged(); }"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                <MudSelectItem T="int" Value="0">All divisions</MudSelectItem>
                @foreach (var d in _divisions)
                {
                    <MudSelectItem T="int" Value="d.DivCode">@d.Name (@d.DivCode)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="5" Class="d-flex justify-end">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" DropShadow="false"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddAsync"
                       Disabled="@string.IsNullOrEmpty(_country)">
                Add Group
            </MudButton>
        </MudItem>
    </MudGrid>
</div>

<MudTable T="LpmVolumeGroup" Items="@FilteredGroups" Hover="true" Dense="true"
          Loading="_loading" AllowUnsorted="false" Class="lpm-narrow-table" Style="max-width:1000px;">
    <HeaderContent>
        <MudTh><MudTableSortLabel T="LpmVolumeGroup" SortBy="g => g.DivCode" InitialDirection="SortDirection.Ascending">Division</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LpmVolumeGroup" SortBy="g => g.SortOrder">Order</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="LpmVolumeGroup" SortBy="g => g.GroupCode">Code</MudTableSortLabel></MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Share %</MudTh>
        <MudTh>Active</MudTh>
        <MudTh Style="width:140px;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@DivisionName(context.DivCode) <span style="color:#94a3b8;">(@context.DivCode)</span></MudTd>
        <MudTd>@context.SortOrder</MudTd>
        <MudTd><code>@context.GroupCode</code></MudTd>
        <MudTd>@context.GroupName</MudTd>
        <MudTd>@((context.SharePct * 100m).ToString("0.##"))%</MudTd>
        <MudTd>
            <MudSwitch T="bool" Value="context.IsActive" Color="Color.Success"
                       ValueChanged="(bool v) => ToggleActiveAsync(context, v)" />
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="() => OpenEditAsync(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="() => DeleteAsync(context)" />
        </MudTd>
    </RowTemplate>
</MudTable>

@* 1.14.39 — Per-Division share totals. Each division should sum to 100%
   among its active rows. Lists every division that has at least one
   active row + flags any that don't sum to 100%. *@
@if (_groups.Count > 0)
{
    var perDiv = _groups.Where(g => g.IsActive)
        .GroupBy(g => g.DivCode)
        .Select(grp => new { DivCode = grp.Key, Sum = grp.Sum(x => x.SharePct), Count = grp.Count() })
        .OrderBy(x => x.DivCode)
        .ToList();
    <MudText Typo="Typo.caption" Class="mt-2 d-block" Style="color:#64748b;">
        Active share totals (@_country) — each division should be 100%:
    </MudText>
    <div class="mt-1" style="font-size:0.82rem; line-height:1.6; max-width:1000px;">
        @foreach (var p in perDiv)
        {
            var ok = Math.Abs(p.Sum - 1m) < 0.0001m;
            <span style="display:inline-block; margin-right:12px; padding:2px 6px; border-radius:3px;
                         background:@(ok ? "#dcfce7" : "#fef3c7"); color:@(ok ? "#166534" : "#92400e");">
                @DivisionName(p.DivCode): @((p.Sum * 100m).ToString("0.##"))% (@p.Count rows)
            </span>
        }
    </div>
}

@code {
    private List<string> _countries = new();
    private string _country = "UAE";
    private List<LpmVolumeGroup> _groups = new();
    // 1.14.39 — Divisions used to populate the per-Division filter dropdown
    // and to render Division Name (vs the raw DivCode int) in the table.
    private List<Division> _divisions = new();
    private int _divFilter; // 0 = "All divisions"
    private bool _loading;

    private string DivisionName(int code) =>
        _divisions.FirstOrDefault(d => d.DivCode == code)?.Name ?? code.ToString();

    // Filtered rows powering the table — applies the Division filter if set.
    private IEnumerable<LpmVolumeGroup> FilteredGroups =>
        _divFilter == 0 ? _groups : _groups.Where(g => g.DivCode == _divFilter);

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _countries = await db.DataSettings.AsNoTracking()
            .Where(s => s.ActiveStore == "Y" && s.Country != null && s.Country != "")
            .Select(s => s.Country!).Distinct().OrderBy(c => c).ToListAsync();
        // Divisions: order by DivCode so the filter dropdown matches the rest of the app.
        _divisions = await db.Divisions.AsNoTracking().OrderBy(d => d.DivCode).ToListAsync();
        if (!_countries.Contains(_country, StringComparer.OrdinalIgnoreCase))
            _country = _countries.FirstOrDefault() ?? "";
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        if (string.IsNullOrEmpty(_country)) { _groups = new(); return; }
        _loading = true; StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _groups = await db.LpmVolumeGroups.AsNoTracking()
                .Where(g => g.Country == _country)
                // 1.14.39 — Sort by DivCode then SortOrder so the table reads
                // grouped by Division (each division's 5 rows together).
                .OrderBy(g => g.DivCode).ThenBy(g => g.SortOrder).ToListAsync();
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task OpenAddAsync()
    {
        // 1.14.39 — Pre-seed Division from the current filter if one is set,
        // otherwise leave at 0 (the dialog forces selection).
        var parameters = new DialogParameters<VolumeGroupEditDialog>
        {
            { x => x.Model, new LpmVolumeGroup { Country = _country, DivCode = _divFilter, SortOrder = (_groups.Count + 1) } },
            { x => x.IsNew, true },
            { x => x.Divisions, _divisions }
        };
        var dlg = await DialogService.ShowAsync<VolumeGroupEditDialog>($"Add volume group ({_country})", parameters);
        var result = await dlg.Result;
        if (result is not null && !result.Canceled) await ReloadAsync();
    }

    private async Task OpenEditAsync(LpmVolumeGroup g)
    {
        var copy = new LpmVolumeGroup
        {
            Country = g.Country, DivCode = g.DivCode, GroupCode = g.GroupCode, GroupName = g.GroupName,
            SortOrder = g.SortOrder, SharePct = g.SharePct, IsActive = g.IsActive
        };
        var parameters = new DialogParameters<VolumeGroupEditDialog>
        {
            { x => x.Model, copy }, { x => x.IsNew, false }, { x => x.Divisions, _divisions }
        };
        var dlg = await DialogService.ShowAsync<VolumeGroupEditDialog>($"Edit {g.Country}/{DivisionName(g.DivCode)}/{g.GroupCode}", parameters);
        var result = await dlg.Result;
        if (result is not null && !result.Canceled) await ReloadAsync();
    }

    private async Task ToggleActiveAsync(LpmVolumeGroup g, bool active)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            // 1.14.39 — PK widened, so the EF lookup needs all 3 columns.
            var row = await db.LpmVolumeGroups.FirstAsync(x =>
                x.Country == g.Country && x.DivCode == g.DivCode && x.GroupCode == g.GroupCode);
            row.IsActive = active;
            await db.SaveChangesAsync();
            g.IsActive = active;
            Snackbar.Add($"{g.Country}/{DivisionName(g.DivCode)}/{g.GroupCode} → {(active ? "active" : "inactive")}.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task DeleteAsync(LpmVolumeGroup g)
    {
        var ok = await DialogService.ShowMessageBox("Delete volume group",
            $"Delete {g.Country}/{DivisionName(g.DivCode)}/{g.GroupCode}? SKU Max rules referencing this (Country, Division, GroupCode) will become orphaned.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var row = await db.LpmVolumeGroups.FirstAsync(x =>
                x.Country == g.Country && x.DivCode == g.DivCode && x.GroupCode == g.GroupCode);
            db.LpmVolumeGroups.Remove(row);
            await db.SaveChangesAsync();
            Snackbar.Add($"Deleted {g.Country}/{DivisionName(g.DivCode)}/{g.GroupCode}.", Severity.Success);
            await ActionLog.LogAsync("VolumeGroups.Delete",
                $"{g.Country}/Div{g.DivCode}/{g.GroupCode}",
                new { country = g.Country, divCode = g.DivCode, groupCode = g.GroupCode, groupName = g.GroupName },
                action: 'X');
            await ReloadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }
}
