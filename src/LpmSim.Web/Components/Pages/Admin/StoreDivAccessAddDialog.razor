@using System.Linq

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Pick one or more <strong>stores</strong> and one or more <strong>divisions</strong> to
            deactivate for <strong>@Country</strong>. Each selected pair will get a row with
            <code>IsActive = 0</code>. Existing rows for the same pair will be flipped to inactive
            without duplication.
        </MudText>

        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Stores</MudText>
                <MudTextField T="string" Placeholder="Filter store id or name…"
                              ValueChanged="(string v) => { _storeFilter = v ?? string.Empty; }"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                @{ var visStores = FilteredStores.ToList(); }
                @* 1.14.45 — Select-all toggles every store currently visible
                   under the filter (not the full master list). Lets the
                   planner type a prefix like "BFL-" then tick the box to
                   select every BFL store without 50 individual clicks. *@
                <div style="margin-top:.4rem;">
                    <MudCheckBox T="bool"
                                 Value="@(visStores.Count > 0 && visStores.All(s => _pickedStores.Contains(s.StoreID)))"
                                 ValueChanged="(bool v) => ToggleAllVisibleStores(v)"
                                 Color="Color.Primary" Dense="true" Size="Size.Small"
                                 Disabled="@(visStores.Count == 0)">
                        <strong>Select all</strong>
                        <span style="color:#94a3b8;">(@visStores.Count visible)</span>
                    </MudCheckBox>
                </div>
                <div style="max-height:280px;overflow:auto;border:1px solid #e2e8f0;border-radius:6px;padding:.4rem .6rem;margin-top:.4rem;">
                    @foreach (var s in visStores)
                    {
                        <div>
                            <MudCheckBox T="bool" Value="@_pickedStores.Contains(s.StoreID)"
                                         ValueChanged="(bool v) => ToggleStore(s.StoreID, v)"
                                         Color="Color.Primary" Dense="true" Size="Size.Small">
                                <code>@s.StoreID</code> · <span style="color:#475569;">@s.Name</span>
                            </MudCheckBox>
                        </div>
                    }
                </div>
                <MudText Typo="Typo.caption" Class="mt-1" Style="color:#64748b;">
                    @_pickedStores.Count selected
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Divisions</MudText>
                <MudTextField T="string" Placeholder="Filter division name or code…"
                              ValueChanged="(string v) => { _divFilter = v ?? string.Empty; }"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                @{ var visDivs = FilteredDivisions.ToList(); }
                <div style="margin-top:.4rem;">
                    <MudCheckBox T="bool"
                                 Value="@(visDivs.Count > 0 && visDivs.All(d => _pickedDivs.Contains(d.DivCode)))"
                                 ValueChanged="(bool v) => ToggleAllVisibleDivs(v)"
                                 Color="Color.Primary" Dense="true" Size="Size.Small"
                                 Disabled="@(visDivs.Count == 0)">
                        <strong>Select all</strong>
                        <span style="color:#94a3b8;">(@visDivs.Count visible)</span>
                    </MudCheckBox>
                </div>
                <div style="max-height:280px;overflow:auto;border:1px solid #e2e8f0;border-radius:6px;padding:.4rem .6rem;margin-top:.4rem;">
                    @foreach (var d in visDivs)
                    {
                        <div>
                            <MudCheckBox T="bool" Value="@_pickedDivs.Contains(d.DivCode)"
                                         ValueChanged="(bool v) => ToggleDiv(d.DivCode, v)"
                                         Color="Color.Primary" Dense="true" Size="Size.Small">
                                @d.Name <span style="color:#94a3b8;">(@d.DivCode)</span>
                            </MudCheckBox>
                        </div>
                    }
                </div>
                <MudText Typo="Typo.caption" Class="mt-1" Style="color:#64748b;">
                    @_pickedDivs.Count selected
                </MudText>
            </MudItem>
        </MudGrid>

        @if (_pickedStores.Count > 0 && _pickedDivs.Count > 0)
        {
            var pairCount = _pickedStores.Count * _pickedDivs.Count;
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-3">
                Will deactivate <strong>@pairCount</strong> (Store × Division) combination(s).
                After saving, re-run EOM Generate to apply.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" DropShadow="false"
                   Disabled="@(_pickedStores.Count == 0 || _pickedDivs.Count == 0)"
                   OnClick="Save">
            Deactivate
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public string Country { get; set; } = "";
    [Parameter] public List<(string StoreID, string Name)>  Stores    { get; set; } = new();
    [Parameter] public List<(int DivCode, string Name)>     Divisions { get; set; } = new();
    [Parameter] public HashSet<(string StoreID, int DivCode)> Existing { get; set; } = new();

    private HashSet<string> _pickedStores = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<int>    _pickedDivs   = new();
    private string _storeFilter = "";
    private string _divFilter   = "";

    private IEnumerable<(string StoreID, string Name)> FilteredStores
        => string.IsNullOrWhiteSpace(_storeFilter)
            ? Stores.OrderBy(s => s.StoreID)
            : Stores.Where(s =>
                    s.StoreID.Contains(_storeFilter, StringComparison.OrdinalIgnoreCase) ||
                    (s.Name ?? "").Contains(_storeFilter, StringComparison.OrdinalIgnoreCase))
                  .OrderBy(s => s.StoreID);

    private IEnumerable<(int DivCode, string Name)> FilteredDivisions
        => string.IsNullOrWhiteSpace(_divFilter)
            ? Divisions.OrderBy(d => d.Name)
            : Divisions.Where(d =>
                    (d.Name ?? "").Contains(_divFilter, StringComparison.OrdinalIgnoreCase) ||
                    d.DivCode.ToString().Contains(_divFilter))
                  .OrderBy(d => d.Name);

    private void ToggleStore(string storeId, bool on)
    {
        if (on) _pickedStores.Add(storeId);
        else    _pickedStores.Remove(storeId);
    }
    private void ToggleDiv(int divCode, bool on)
    {
        if (on) _pickedDivs.Add(divCode);
        else    _pickedDivs.Remove(divCode);
    }

    // 1.14.45 — Select/Clear all stores currently visible under the filter.
    // Acts only on the filtered subset so a planner can scope a bulk
    // selection by typing a prefix first (e.g. "BFL-" → tick Select all →
    // every BFL store added, non-BFL untouched).
    private void ToggleAllVisibleStores(bool on)
    {
        foreach (var s in FilteredStores)
        {
            if (on) _pickedStores.Add(s.StoreID);
            else    _pickedStores.Remove(s.StoreID);
        }
    }
    private void ToggleAllVisibleDivs(bool on)
    {
        foreach (var d in FilteredDivisions)
        {
            if (on) _pickedDivs.Add(d.DivCode);
            else    _pickedDivs.Remove(d.DivCode);
        }
    }

    private void Save()
    {
        var pairs = (from s in _pickedStores
                     from d in _pickedDivs
                     select (StoreID: s, DivCode: d)).ToList();
        Dialog.Close(DialogResult.Ok(pairs));
    }
    private void Cancel() => Dialog.Cancel();
}
