<MudNavMenu Class="lpm-nav">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Home</MudNavLink>

    @* 1.14.14: top-level "LPM Variables" flat section replaced with an
       "EOM/SIM" collapsible MudNavGroup. The 5 allocation/reporting pages
       (EOM Generate, LPM SIM Generate, Production Schedule, ADM, LPM SIM
       Reports) live here. Warehouse Boxes moved into Reports (below).
       The grouping matches the corresponding "EOM/SIM" role label
       (formerly "Editor") so admins can map permissions to menu sections
       at a glance. *@
    <MudNavGroup Title="EOM/SIM" Icon="@Icons.Material.Filled.PlayCircle" Expanded="false">
        <MudNavLink Href="lpm/eom/generate"                Icon="@Icons.Material.Filled.PlayCircle">EOM Generate</MudNavLink>
        <MudNavLink Href="lpm/lpm-sim/generate"            Icon="@Icons.Material.Filled.AutoFixHigh">LPM SIM Generate</MudNavLink>
        <MudNavLink Href="lpm/lpm-sim/production-schedule" Icon="@Icons.Material.Filled.CalendarMonth">Production Schedule</MudNavLink>
        <MudNavLink Href="lpm/adm"                         Icon="@Icons.Material.Filled.CalendarViewWeek">ADM (Allocation)</MudNavLink>
        <MudNavLink Href="lpm/lpm-sim/reports"             Icon="@Icons.Material.Filled.Assessment">LPM SIM Reports</MudNavLink>
    </MudNavGroup>

    @* Reports — collapsible. 1.14.14: Warehouse Boxes joined this group
       (was a top-level link in the LPM Variables section). *@
    <MudNavGroup Title="Reports" Icon="@Icons.Material.Filled.Assessment" Expanded="false">
        <MudNavLink Href="lpm/reports/wh-ho-stock" Icon="@Icons.Material.Filled.CompareArrows">WH Stock Position</MudNavLink>
        <MudNavLink Href="lpm/reports/variance"    Icon="@Icons.Material.Filled.ShowChart">Variance Report</MudNavLink>
        <MudNavLink Href="lpm/warehouse-boxes"     Icon="@Icons.Material.Filled.Warehouse">Warehouse Boxes</MudNavLink>
    </MudNavGroup>

    @* Planning Config — operational config (Monthly Weights / Planned Inputs /
       Data Uploads) is visible to all signed-in users; the master-data pages
       below remain gated behind Admin / PlanningManager roles. The section
       header sits OUTSIDE the AuthorizeView so the section name is visible
       even when only the 3 unrestricted items are shown.
       1.14.14: the PlanningManager role's display label is now "Planning
       Config" (RoleName flipped via migration 042). RoleCode unchanged so
       this AuthorizeView keeps working without any further edits. *@
    <div class="lpm-nav-section">Planning Config</div>
    <MudNavLink Href="lpm/monthly-weights"  Icon="@Icons.Material.Filled.EventNote">Monthly Weights</MudNavLink>
    <MudNavLink Href="lpm/planned"          Icon="@Icons.Material.Filled.RequestQuote">Planned Inputs</MudNavLink>
    <MudNavLink Href="lpm/uploads"          Icon="@Icons.Material.Filled.CloudUpload">Data Uploads</MudNavLink>
    <AuthorizeView Roles="Admin,PlanningManager">
        <Authorized>
            <MudNavLink Href="lpm/weekly-sales-target-split" Icon="@Icons.Material.Filled.PieChart">Weekly Sales Target Split</MudNavLink>
            <MudNavLink Href="admin/grades"            Icon="@Icons.Material.Filled.WorkspacePremium">Store Grades</MudNavLink>
            <MudNavLink Href="admin/volume-groups"     Icon="@Icons.Material.Filled.DonutSmall">Volume Groups</MudNavLink>
            <MudNavLink Href="admin/skumax-rules"      Icon="@Icons.Material.Filled.Rule">SKU Max Rules</MudNavLink>
            <MudNavLink Href="admin/store-div-access"  Icon="@Icons.Material.Filled.Block">Store / Division Access</MudNavLink>
            <MudNavLink Href="admin/store-dept-access" Icon="@Icons.Material.Filled.SubdirectoryArrowRight">Store / Department Access</MudNavLink>
            <MudNavLink Href="admin/warehouse-priorities" Icon="@Icons.Material.Filled.Sort">Warehouse Priorities</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <div class="lpm-nav-section">Admin</div>
            <MudNavLink Href="admin/users"         Icon="@Icons.Material.Filled.People">User Access</MudNavLink>
            <MudNavLink Href="admin/audit"         Icon="@Icons.Material.Filled.History">Audit Log</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
