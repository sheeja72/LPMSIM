@inherits LayoutComponentBase
@using System.Reflection

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="lpm-layout">
    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="0"
               Width="260px" Class="lpm-drawer">
        <div class="lpm-brand">
            <div class="lpm-brand-title">Planning Hub <span class="lpm-brand-version" title="@_versionInfo">v@_versionShort</span></div>
            <AuthorizeView>
                <Authorized>
                    @{
                        var role = context.User.IsInRole("Admin")  ? "Admin"
                                 : context.User.IsInRole("Editor") ? "Editor"
                                 : context.User.IsInRole("Viewer") ? "Viewer"
                                 : "User";
                    }
                    <div class="lpm-brand-user">
                        <span class="lpm-role-badge">@role</span>
                    </div>
                    <div class="lpm-brand-username">@context.User.Identity?.Name</div>
                    <div class="lpm-brand-signout">
                        @* Calls the same JS path the idle watchdog uses, so manual
                           Sign Out and 5-min auto-logout end up in identical state. *@
                        <button type="button" class="lpm-signout-btn"
                                onclick="window.lpmSignOut && window.lpmSignOut();">
                            <span style="margin-right:.4rem;">⎋</span> Sign out
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
        <NavMenu />
        <div class="lpm-drawer-footer" title="@_versionInfo">
            Planning Hub · v@_versionShort
        </div>
    </MudDrawer>

    <MudMainContent Class="lpm-main">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary           = "#2563eb",
            Secondary         = "#64748b",
            Background        = "#f4f6fa",
            Surface           = "#ffffff",
            TextPrimary       = "#0f172a",
            TextSecondary     = "#64748b",
            LinesDefault      = "#e5e7eb",
            // 1.14.5: drawer flipped from blue-900 (1.10.x) to golden
            // yellow per user request. Kept in lock-step with the CSS
            // variable --lpm-drawer-bg in app.css — MudBlazor injects an
            // inline style on the drawer surface that beats the CSS var,
            // so both values have to agree. Text + icon flipped from
            // light-slate (readable on blue) to near-black (readable on
            // yellow).
            DrawerBackground  = "#FBC02D",
            DrawerText        = "#0F172A",
            DrawerIcon        = "#0F172A",
        }
    };

    // Version info pulled from the assembly attributes (set in
    // LpmSim.Web.csproj <Version> + <InformationalVersion>). Compact form
    // for the badge, full form for the tooltip.
    private static readonly string _versionShort = ResolveShortVersion();
    private static readonly string _versionInfo  = ResolveInformationalVersion();

    private static string ResolveShortVersion()
    {
        var asm = typeof(MainLayout).Assembly;
        var info = asm.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
                ?? asm.GetName().Version?.ToString()
                ?? "0.0.0";
        // Strip any "+commitsha" suffix that .NET appends on builds with sourcelink.
        var plus = info.IndexOf('+');
        if (plus > 0) info = info[..plus];
        // Strip the trailing description if any: "1.7.0 (Phase G — ...)" → "1.7.0"
        var space = info.IndexOf(' ');
        return space > 0 ? info[..space] : info;
    }

    private static string ResolveInformationalVersion()
    {
        var asm = typeof(MainLayout).Assembly;
        var info = asm.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
                ?? asm.GetName().Version?.ToString()
                ?? "0.0.0";
        var plus = info.IndexOf('+');
        return plus > 0 ? info[..plus] : info;
    }
}
