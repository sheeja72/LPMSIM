{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Connection strings are placeholders only — REAL values must come from
  //   • User Secrets in local dev: dotnet user-secrets set "ConnectionStrings:Lpm"       "<value>"
  //                                dotnet user-secrets set "ConnectionStrings:Warehouse" "<value>"
  //   • App Service application settings / Key Vault references in Azure.
  // NEVER commit credentials to git. The Program.cs guard throws if the
  // value isn't supplied at runtime, so the placeholder is harmless.
  "ConnectionStrings": {
    "Lpm":       "REPLACE_VIA_USER_SECRETS_OR_APP_SETTINGS",
    "Warehouse": "REPLACE_VIA_USER_SECRETS_OR_APP_SETTINGS"
  },

  // ── Authentication ────────────────────────────────────────────────────
  // Auth:Mode = "Negotiate" (default — Windows / Kerberos, current behaviour)
  //          OR "OIDC"      (Microsoft Entra ID SSO with email login)
  //
  // To switch to OIDC:
  //   1. Run db/023_lpmuser_email_index.sql, then populate LPMUser.Email
  //      (e.g. UPDATE LPMUser SET Email='sheeja@bflgroup.ae' WHERE Username='BFLDOMAIN\sheeja')
  //   2. Register an Entra ID single-tenant Web app with redirect URI
  //      http(s)://<host>/signin-oidc and front-channel logout
  //      http(s)://<host>/signout-callback-oidc.
  //   3. Fill the GUIDs / domain below.
  //   4. Put the ClientSecret in User Secrets (NOT this file):
  //        dotnet user-secrets set "AzureAd:ClientSecret" "<value>"
  //   5. Flip Auth:Mode to "OIDC".
  //   6. In IIS: enable Anonymous Authentication, disable Windows Authentication.
  "Auth": {
    "Mode": "Negotiate"
  },
  "AzureAd": {
    "Instance":              "https://login.microsoftonline.com/",
    "Domain":                "REPLACE_WITH_TENANT_DOMAIN",
    "TenantId":              "REPLACE_WITH_TENANT_GUID",
    "ClientId":              "REPLACE_WITH_APP_CLIENT_GUID",
    "CallbackPath":          "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  }
}
