<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\LpmSim.Core\LpmSim.Core.csproj" />
    <ProjectReference Include="..\LpmSim.Data\LpmSim.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="9.0.3" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.8.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.8.0" />
    <PackageReference Include="MudBlazor" Version="7.15.0" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d895eeb3-6c53-45d7-99d2-1c4f7ead54ee</UserSecretsId>
    <!-- App version surfaced in the sidebar footer. Bump on each release;
         AssemblyInformationalVersion is what Assembly.GetCustomAttribute
         reads at runtime. See CHANGELOG.md at the repo root for the
         per-version release notes. -->
    <Version>1.14.81</Version>
    <AssemblyVersion>1.14.81.0</AssemblyVersion>
    <FileVersion>1.14.81.0</FileVersion>
    <InformationalVersion>1.14.81 (Two changes bundled: (1) SIM Boxes — LPM tag columns: Kind (LPM/Non-LPM badge) added to Reports SIM Boxes tab (Generate-preview already had it; also fixed pre-existing placeholder bug where Reports non-rollup hard-coded BoxKind to NULL); LPM Date (raw whboxitems.LPMDt) added to both Reports SIM Boxes and Generate-preview Boxes tabs plus both Excel exports. (2) Excel filename prefix — every batch-level Excel download (8 in Generate + 3 in Reports) now leads with the LPM/NONLPM tag (was a trailing _LPM/_NonLPM suffix; Non-LPM form is now all-caps NONLPM so it can't be misread as LPM at a glance, and Generate-side exports that were untagged previously now carry the prefix too).)</InformationalVersion>
  </PropertyGroup>

</Project>
