    <!-- App version surfaced in the sidebar footer. Bump on each release;
         AssemblyInformationalVersion is what Assembly.GetCustomAttribute
         reads at runtime. See CHANGELOG.md at the repo root for the
         per-version release notes. -->
    <Version>1.14.99</Version>
    <AssemblyVersion>1.14.99.0</AssemblyVersion>
    <FileVersion>1.14.99.0</FileVersion>
    <InformationalVersion>1.14.99 (Eligible Boxes table — new "Closed (excluded from SIM)" row showing closed-box Box / Qty separately for LPM and Non-LPM. Same closed-box predicate the allocator uses (WhBoxItemsSource.BuildIsClosedExpression — UAE: USA..upcboxhead.Closed='Y'; non-UAE: Exclude_Transfers_Sim + CloseR1Pallet). Row is a SUBSET of the LPM / Non-LPM totals above (they include closed boxes per the 1.14.74 operator preference). BoxSegmentCounts record gains 4 new fields with default zero so old call sites compile unchanged.)</InformationalVersion>
  </PropertyGroup>

</Project>
