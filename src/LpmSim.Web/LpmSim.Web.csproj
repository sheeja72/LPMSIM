<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\LpmSim.Core\LpmSim.Core.csproj" />
    <ProjectReference Include="..\LpmSim.Data\LpmSim.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="9.0.3" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.8.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.8.0" />
    <PackageReference Include="MudBlazor" Version="7.15.0" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d895eeb3-6c53-45d7-99d2-1c4f7ead54ee</UserSecretsId>
    <!-- App version surfaced in the sidebar footer. Bump on each release;
         AssemblyInformationalVersion is what Assembly.GetCustomAttribute
         reads at runtime. See CHANGELOG.md at the repo root for the
         per-version release notes. -->
    <Version>1.14.101</Version>
    <AssemblyVersion>1.14.101.0</AssemblyVersion>
    <FileVersion>1.14.101.0</FileVersion>
    <InformationalVersion>1.14.101 hotfix (Closed-box row was invisible because 1.14.99 added 4 per-row EXISTS sub-queries to the main BoxSegments SQL — those inflated the CheckAsync runtime, likely timed out, and the surrounding try/catch swallowed the exception, leaving the whole Eligible Boxes table null. Fix: closed-box rollup is now a SEPARATE query with its own try/catch + uses INNER JOIN to a pre-filtered closed-box set (single index seek instead of N per-row sub-queries). Main BoxSegments table renders even if the closed query fails — closed row just shows 0/0 instead.)</InformationalVersion>
  </PropertyGroup>

</Project>
