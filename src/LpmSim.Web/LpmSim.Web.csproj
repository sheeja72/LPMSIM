<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\LpmSim.Core\LpmSim.Core.csproj" />
    <ProjectReference Include="..\LpmSim.Data\LpmSim.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="9.0.3" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.8.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.8.0" />
    <PackageReference Include="MudBlazor" Version="7.15.0" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d895eeb3-6c53-45d7-99d2-1c4f7ead54ee</UserSecretsId>
    <!-- App version surfaced in the sidebar footer. Bump on each release;
         AssemblyInformationalVersion is what Assembly.GetCustomAttribute
         reads at runtime. See CHANGELOG.md at the repo root for the
         per-version release notes. -->
    <Version>1.14.87</Version>
    <AssemblyVersion>1.14.87.0</AssemblyVersion>
    <FileVersion>1.14.87.0</FileVersion>
    <InformationalVersion>1.14.87 (SIM allocator refactor per planner Option 1 spec — drop Week machinery, use MerchNeedMonth + Grade tiers. Phase 1a/2a caps: SKUMax + MerchNeedMonth (was MerchNeedWeek); legacy EOM Balance entry gate REMOVED (MNM subsumes it). Phase 1b/2b RR: stores grouped by Grade tier (Diamond → Platinum → Gold → Silver), within each tier sorted by MerchNeedMonth Balance DESC (sort key only — most-undersupplied first), per-store quantum varies by tier — 2 units for Diamond+Platinum, 1 unit for Gold+Silver. SKUMax honoured in all 4 phases; MerchNeedMonth is a cap in 1a/2a only (bypassed in 1b/2b — override deliberately lets partial boxes push past monthly demand). Stores without one of the four recognised grades are excluded from RR entirely. Week dropdown removed from SIM Generate page; IgnoreMerchNeed toggle stays (now means ignore MerchNeedMonth in 1a/2a). Report columns labelled "Merch Need (Week)" left as-is for now (informational; allocator no longer reads them).)</InformationalVersion>
  </PropertyGroup>

</Project>
