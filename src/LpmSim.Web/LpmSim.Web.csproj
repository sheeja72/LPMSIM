<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\LpmSim.Core\LpmSim.Core.csproj" />
    <ProjectReference Include="..\LpmSim.Data\LpmSim.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="9.0.3" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.8.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.8.0" />
    <PackageReference Include="MudBlazor" Version="7.15.0" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d895eeb3-6c53-45d7-99d2-1c4f7ead54ee</UserSecretsId>
    <!-- App version surfaced in the sidebar footer. Bump on each release;
         AssemblyInformationalVersion is what Assembly.GetCustomAttribute
         reads at runtime. See CHANGELOG.md at the repo root for the
         per-version release notes. -->
    <Version>1.14.88</Version>
    <AssemblyVersion>1.14.88.0</AssemblyVersion>
    <FileVersion>1.14.88.0</FileVersion>
    <InformationalVersion>1.14.88 hotfix (Country-linkage regression in 1.14.87 RR rewrite — the new grade-tier sort in 1b/2b only used MerchNeedMonth Balance DESC, which mixed parent and child countries inside the same grade. A UAE batch with OMAN linkage could pick an OMAN Diamond store before a UAE Diamond store when OMAN's MNM Balance was higher, violating the "OMAN after UAE" planner rule. Fix: CountryPriority ASC is now the PRIMARY within-tier sort key, MNM Balance DESC the secondary — same shape as the 1a/2a sort. Single-country runs unaffected because every store has CountryPriority = 0 in that case.)</InformationalVersion>
  </PropertyGroup>

</Project>
