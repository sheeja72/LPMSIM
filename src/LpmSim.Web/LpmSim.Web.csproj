<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\LpmSim.Core\LpmSim.Core.csproj" />
    <ProjectReference Include="..\LpmSim.Data\LpmSim.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="9.0.3" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.8.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.8.0" />
    <PackageReference Include="MudBlazor" Version="7.15.0" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d895eeb3-6c53-45d7-99d2-1c4f7ead54ee</UserSecretsId>
    <!-- App version surfaced in the sidebar footer. Bump on each release;
         AssemblyInformationalVersion is what Assembly.GetCustomAttribute
         reads at runtime. See CHANGELOG.md at the repo root for the
         per-version release notes. -->
    <Version>1.14.90</Version>
    <AssemblyVersion>1.14.90.0</AssemblyVersion>
    <FileVersion>1.14.90.0</FileVersion>
    <InformationalVersion>1.14.90 (SIM Generate concurrency gate — when one user (or a same-user double-click) starts SIM Generate for a (Country, RunDate), any second Generate for the same period within the 30-minute stale window is blocked with a friendly Warning Snackbar naming the conflicting user, the batch number, and the GST start time. Implemented via a new SimBatchAlreadyRunningException thrown at the very start of GenerateAsync before any expensive work. Uses the existing 1.14.67 Status='Running' marker on LPM_SimBatch + the existing 30-minute stale-row safety window — no new schema, no migration. Stale Running rows (crashed mid-flight, older than 30 min) don't block new runs.)</InformationalVersion>
  </PropertyGroup>

</Project>
